                                                                                   <http://www.geneontology.org/formats/oboInOwl#id> "nghiep_vu_dac_trung_chuyen_nganh" ;
                                                                                   rdfs:label "Nghiệp vụ đặc trưng chuyên ngành" .


###  http://purl.obolibrary.org/obo/persona_analysis#ngon_ngu_su_dung_trong_cong_viec
<http://purl.obolibrary.org/obo/persona_analysis#ngon_ngu_su_dung_trong_cong_viec> rdf:type owl:Class ;
