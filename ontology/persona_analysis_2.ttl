                                                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#muc_dich_suc_khoe> ;
                                                                             <http://purl.obolibrary.org/obo/IAO_0000115> """Vận động nhằm cải thiện hoặc duy trì chức năng hệ tuần hoàn và sức bền tim phổi.
Ví dụ thực tế từ dữ liệu: đi bộ nhanh buổi sáng để giữ huyết áp ổn định, bơi lội để tăng sức bền tim mạch.""" ;
                                                                             <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                             <http://www.geneontology.org/formats/oboInOwl#id> "muc_tieu_suc_khoe_tim_mach" ;
                                                                             rdfs:label "Mục tiêu sức khỏe tim mạch" .


###  http://purl.obolibrary.org/obo/persona_analysis#muc_tieu_suc_khoe_xuong_khop
<http://purl.obolibrary.org/obo/persona_analysis#muc_tieu_suc_khoe_xuong_khop> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#muc_dich_suc_khoe> ;
