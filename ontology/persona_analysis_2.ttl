@prefix : <http://purl.obolibrary.org/obo/persona_analysis.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.obolibrary.org/obo/persona_analysis.owl> .

<http://purl.obolibrary.org/obo/persona_analysis.owl> rdf:type owl:Ontology ;
                                                       <http://www.geneontology.org/formats/oboInOwl#default-namespace> "persona_analysis" ;
                                                       <http://www.geneontology.org/formats/oboInOwl#hasOBOFormatVersion> "1.2" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.obolibrary.org/obo/IAO_0000115
<http://purl.obolibrary.org/obo/IAO_0000115> rdf:type owl:AnnotationProperty ;
                                             rdfs:label "definition" .


###  http://www.geneontology.org/formats/oboInOwl#default-namespace
<http://www.geneontology.org/formats/oboInOwl#default-namespace> rdf:type owl:AnnotationProperty .


###  http://www.geneontology.org/formats/oboInOwl#hasOBOFormatVersion
<http://www.geneontology.org/formats/oboInOwl#hasOBOFormatVersion> rdf:type owl:AnnotationProperty ;
                                                                   rdfs:label "has_obo_format_version" .


###  http://www.geneontology.org/formats/oboInOwl#hasOBONamespace
<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> rdf:type owl:AnnotationProperty ;
                                                               rdfs:label "has_obo_namespace" .


###  http://www.geneontology.org/formats/oboInOwl#id
<http://www.geneontology.org/formats/oboInOwl#id> rdf:type owl:AnnotationProperty ;
                                                  rdfs:label "id" .


###  http://www.w3.org/2000/01/rdf-schema#label
rdfs:label rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/persona_analysis#correlated_with
<http://purl.obolibrary.org/obo/persona_analysis#correlated_with> rdf:type owl:ObjectProperty ;
                                                                  <http://purl.obolibrary.org/obo/IAO_0000115> "A và B có liên hệ tương quan, thường xuất hiện hoặc thay đổi cùng nhau" ;
                                                                  <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                  <http://www.geneontology.org/formats/oboInOwl#id> "correlated_with" ;
                                                                  rdfs:label "correlated_with" .


###  http://purl.obolibrary.org/obo/persona_analysis#influences
<http://purl.obolibrary.org/obo/persona_analysis#influences> rdf:type owl:ObjectProperty ;
                                                             <http://purl.obolibrary.org/obo/IAO_0000115> "A tác động trực tiếp đến B, làm thay đổi hoặc định hình B" ;
                                                             <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                             <http://www.geneontology.org/formats/oboInOwl#id> "influences" ;
                                                             rdfs:label "influences" .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/persona_analysis#age
<http://purl.obolibrary.org/obo/persona_analysis#age> rdf:type owl:Class ;
                                                      <http://purl.obolibrary.org/obo/IAO_0000115> "Tuổi tính theo năm (Giới hạn từ 18 đến 90 tuổi)." ;
                                                      <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                      <http://www.geneontology.org/formats/oboInOwl#id> "age" ;
                                                      rdfs:label "age" .


###  http://purl.obolibrary.org/obo/persona_analysis#an_dung_gio_ba_bua
<http://purl.obolibrary.org/obo/persona_analysis#an_dung_gio_ba_bua> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#tan_suat_va_gio_giac_an_uong> ;
                                                                     <http://purl.obolibrary.org/obo/IAO_0000115> "Duy trì thói quen ăn sáng, trưa, tối đều đặn tại các khung giờ cố định — phản ánh lối sống có nề nếp và ưu tiên sức khỏe tiêu hóa." ;
                                                                     <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                     <http://www.geneontology.org/formats/oboInOwl#id> "an_dung_gio_ba_bua" ;
                                                                     rdfs:label "Ăn đúng giờ ba bữa" .


###  http://purl.obolibrary.org/obo/persona_analysis#an_khuya_thuong_xuyen
<http://purl.obolibrary.org/obo/persona_analysis#an_khuya_thuong_xuyen> rdf:type owl:Class ;
                                                                        rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#tan_suat_va_gio_giac_an_uong> ;
                                                                        <http://purl.obolibrary.org/obo/IAO_0000115> "Thói quen ăn hoặc ăn vặt sau 9 giờ tối — gắn với lịch sinh hoạt muộn, thức khuya làm việc hoặc thói quen giải trí ban đêm." ;
                                                                        <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                        <http://www.geneontology.org/formats/oboInOwl#id> "an_khuya_thuong_xuyen" ;
                                                                        rdfs:label "Ăn khuya thường xuyên" .


###  http://purl.obolibrary.org/obo/persona_analysis#an_uong_bao_thu_mon_quen
<http://purl.obolibrary.org/obo/persona_analysis#an_uong_bao_thu_mon_quen> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#muc_do_chap_nhan_vi_la> ;
                                                                           <http://purl.obolibrary.org/obo/IAO_0000115> "Xu hướng chỉ ăn các món đã quen thuộc, ít sẵn sàng thử hương vị xa lạ hoặc khác biệt so với thói quen hàng ngày." ;
                                                                           <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                           <http://www.geneontology.org/formats/oboInOwl#id> "an_uong_bao_thu_mon_quen" ;
                                                                           rdfs:label "Ăn uống bảo thủ món quen" .


###  http://purl.obolibrary.org/obo/persona_analysis#an_uong_coi_mo_thu_vi_moi
<http://purl.obolibrary.org/obo/persona_analysis#an_uong_coi_mo_thu_vi_moi> rdf:type owl:Class ;
                                                                            rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#muc_do_chap_nhan_vi_la> ;
                                                                            <http://purl.obolibrary.org/obo/IAO_0000115> "Xu hướng háo hức khám phá hương vị chưa từng thử — sẵn sàng ăn món lạ, đặc sản địa phương hoặc ẩm thực nước ngoài xa lạ." ;
                                                                            <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                            <http://www.geneontology.org/formats/oboInOwl#id> "an_uong_coi_mo_thu_vi_moi" ;
                                                                            rdfs:label "Ăn uống cởi mở thử vị mới" .


###  http://purl.obolibrary.org/obo/persona_analysis#an_vat_rai_rac_ca_ngay
<http://purl.obolibrary.org/obo/persona_analysis#an_vat_rai_rac_ca_ngay> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#tan_suat_va_gio_giac_an_uong> ;
                                                                         <http://purl.obolibrary.org/obo/IAO_0000115> "Thói quen ăn nhiều lần nhỏ trong ngày thay vì tập trung vào 3 bữa chính — thường gắn với công việc bận rộn hoặc sở thích ăn vặt liên tục." ;
                                                                         <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                         <http://www.geneontology.org/formats/oboInOwl#id> "an_vat_rai_rac_ca_ngay" ;
                                                                         rdfs:label "Ăn vặt rải rác cả ngày" .


###  http://purl.obolibrary.org/obo/persona_analysis#anh_huong_dieu_kien_vat_ly_den_hieu_suat
<http://purl.obolibrary.org/obo/persona_analysis#anh_huong_dieu_kien_vat_ly_den_hieu_suat> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#khong_gian_vat_ly_lam_viec> ;
                                                                                           <http://purl.obolibrary.org/obo/IAO_0000115> """Tác động của các yếu tố môi trường như nhiệt độ, ánh sáng, tiếng ồn và không gian đến năng suất và sức khỏe của cá nhân.
Ví dụ thực tế từ dữ liệu: làm ngoài trời nắng nóng ảnh hưởng thể lực công nhân, bếp chật hẹp giới hạn số lượng món có thể chế biến cùng lúc.""" ;
                                                                                           <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                                           <http://www.geneontology.org/formats/oboInOwl#id> "anh_huong_dieu_kien_vat_ly_den_hieu_suat" ;
                                                                                           rdfs:label "Ảnh hưởng điều kiện vật lý đến hiệu suất" .


###  http://purl.obolibrary.org/obo/persona_analysis#anh_huong_nghe_thuat_den_the_gioi_quan
<http://purl.obolibrary.org/obo/persona_analysis#anh_huong_nghe_thuat_den_the_gioi_quan> rdf:type owl:Class ;
                                                                                         rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#cach_thuc_nghe_thuat_tac_dong> ,
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                                           owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#nhan_thuc_ca_nhan_van_hoa>
                                                                                                         ] ,
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                                           owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#the_gioi_quan>
                                                                                                         ] ;
                                                                                         <http://purl.obolibrary.org/obo/IAO_0000115> """Mức độ mà các trải nghiệm nghệ thuật tích lũy theo thời gian định hình nên hệ thống giá trị, niềm tin và cách nhìn nhận cuộc sống của một cá nhân.
Ví dụ thực tế: đọc nhiều văn học khiến người ta đồng cảm hơn với người khác, tiếp xúc với nghệ thuật phản kháng hình thành ý thức xã hội.""" ;
                                                                                         <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                                         <http://www.geneontology.org/formats/oboInOwl#id> "anh_huong_nghe_thuat_den_the_gioi_quan" ;
                                                                                         rdfs:label "Ảnh hưởng nghệ thuật đến thế giới quan" .


###  http://purl.obolibrary.org/obo/persona_analysis#anh_huong_ton_giao_va_tin_nguong
<http://purl.obolibrary.org/obo/persona_analysis#anh_huong_ton_giao_va_tin_nguong> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#boi_canh_xa_hoi_truyen_thong> ,
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                                     owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#the_gioi_quan>
                                                                                                   ] ;
                                                                                   <http://purl.obolibrary.org/obo/IAO_0000115> """Mức độ tín ngưỡng dân gian, tôn giáo hoặc tâm linh tác động đến các thực hành sinh hoạt và quan niệm sống của cá nhân.
Ví dụ thực tế từ dữ liệu: thắp nhang ngày Tết, nấu cháo bằng nồi đất giữ hương vị truyền thống, thả đèn hoa đăng đêm trăng rằm.""" ;
                                                                                   <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                                   <http://www.geneontology.org/formats/oboInOwl#id> "anh_huong_ton_giao_va_tin_nguong" ;
                                                                                   rdfs:label "Ảnh hưởng tôn giáo và tín ngưỡng" .


###  http://purl.obolibrary.org/obo/persona_analysis#arts_persona
<http://purl.obolibrary.org/obo/persona_analysis#arts_persona> rdf:type owl:Class ;
                                                               <http://purl.obolibrary.org/obo/IAO_0000115> """Hình mẫu nghệ thuật xác định mức độ gắn kết của một cá nhân với các hình thức biểu đạt sáng tạo, đồng thời mô tả 
cách thức nghệ thuật tác động và định hình bản sắc cá nhân.""" ;
                                                               <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                               <http://www.geneontology.org/formats/oboInOwl#id> "arts_persona" ;
                                                               rdfs:label "arts_persona" .


###  http://purl.obolibrary.org/obo/persona_analysis#ban_sac_ca_nhan
<http://purl.obolibrary.org/obo/persona_analysis#ban_sac_ca_nhan> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#arts_persona> ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#correlated_with> ;
                                                                                    owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#muc_do_tu_hao_ban_sac_van_hoa>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                    owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#gu_trai_nghiem_van_hoa_am_thuc>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                    owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#nhan_sinh_quan>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                    owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#phong_cach_dich_chuyen>
                                                                                  ] ;
                                                                  <http://purl.obolibrary.org/obo/IAO_0000115> """Tập hợp các đặc điểm, niềm tin, giá trị sống và nét tính cách độc nhất định hình nên cái tôi của một người.
Giúp cá nhân tự nhận thức và phân biệt bản thân trong xã hội.""" ;
                                                                  <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                  <http://www.geneontology.org/formats/oboInOwl#id> "ban_sac_ca_nhan" ;
                                                                  rdfs:label "Bản sắc cá nhân" .


###  http://purl.obolibrary.org/obo/persona_analysis#bao_luu_van_hoa_goc
<http://purl.obolibrary.org/obo/persona_analysis#bao_luu_van_hoa_goc> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#muc_do_tiep_nhan_van_hoa_ben_ngoai> ;
                                                                      <http://purl.obolibrary.org/obo/IAO_0000115> "Xu hướng giữ nguyên các thói quen và giá trị văn hóa truyền thống, ít sẵn sàng tiếp nhận hoặc thay đổi theo ảnh hưởng từ văn hóa bên ngoài." ;
                                                                      <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                      <http://www.geneontology.org/formats/oboInOwl#id> "bao_luu_van_hoa_goc" ;
                                                                      rdfs:label "Bảo lưu văn hóa gốc" .


###  http://purl.obolibrary.org/obo/persona_analysis#bo_bua_sang_thuong_xuyen
<http://purl.obolibrary.org/obo/persona_analysis#bo_bua_sang_thuong_xuyen> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#tan_suat_va_gio_giac_an_uong> ;
                                                                           <http://purl.obolibrary.org/obo/IAO_0000115> "Thói quen không ăn sáng hoặc chỉ ăn rất ít vào buổi sáng — do bận rộn, không có thói quen, hoặc chủ động nhịn để kiểm soát calo." ;
                                                                           <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                           <http://www.geneontology.org/formats/oboInOwl#id> "bo_bua_sang_thuong_xuyen" ;
                                                                           rdfs:label "Bỏ bữa sáng thường xuyên" .


###  http://purl.obolibrary.org/obo/persona_analysis#boi_canh_giai_tri
<http://purl.obolibrary.org/obo/persona_analysis#boi_canh_giai_tri> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#hoat_dong_giai_tri_thoi_gian_ranh> ,
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                      owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#boi_canh_tham_gia_the_thao>
                                                                                    ] ;
                                                                    <http://purl.obolibrary.org/obo/IAO_0000115> """Hoàn cảnh và môi trường xung quanh khi cá nhân thực hiện hoạt động giải trí: một mình hay cùng người khác, 
tại nhà hay ngoài không gian công cộng, định kỳ hay tùy hứng.
Ví dụ thực tế từ dữ liệu: kể chuyện cho con cháu đêm trăng tròn, đốt lửa quây quanh bạn bè, cùng cháu nội chơi cờ vua, 
đến công viên với nhóm khiêu vũ cuối tuần.""" ;
                                                                    <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                    <http://www.geneontology.org/formats/oboInOwl#id> "boi_canh_giai_tri" ;
                                                                    rdfs:label "Bối cảnh giải trí" .


###  http://purl.obolibrary.org/obo/persona_analysis#boi_canh_tham_gia_the_thao
<http://purl.obolibrary.org/obo/persona_analysis#boi_canh_tham_gia_the_thao> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#muc_do_tham_gia_the_thao> ,
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                               owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#boi_canh_giai_tri>
                                                                                             ] ;
                                                                             <http://purl.obolibrary.org/obo/IAO_0000115> """Hoàn cảnh và môi trường xã hội xung quanh việc tập luyện của cá nhân. 
Ví dụ: tập cùng bạn bè, trong cộng đồng khu phố, tại câu lạc bộ địa phương hay tự tập một mình.""" ;
                                                                             <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "persona_analysis" ;
                                                                             <http://www.geneontology.org/formats/oboInOwl#id> "boi_canh_tham_gia_the_thao" ;
                                                                             rdfs:label "Bối cảnh tham gia thể thao" .


###  http://purl.obolibrary.org/obo/persona_analysis#boi_canh_xa_hoi_truyen_thong
<http://purl.obolibrary.org/obo/persona_analysis#boi_canh_xa_hoi_truyen_thong> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#cultural_background> ,
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#anh_huong_nghe_thuat_den_the_gioi_quan>
                                                                                               ] ,
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#gia_tri_cot_loi>
                                                                                               ] ,
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
                                                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/persona_analysis#hinh_thuc_to_chuc_hanh_trinh>
                                                                                               ] ,
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <http://purl.obolibrary.org/obo/persona_analysis#influences> ;
