###  http://purl.obolibrary.org/obo/persona_analysis#nghiep_vu_dac_trung_chuyen_nganh
<http://purl.obolibrary.org/obo/persona_analysis#nghiep_vu_dac_trung_chuyen_nganh> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://purl.obolibrary.org/obo/persona_analysis#tac_vu_dac_thu_cong_viec> ;
