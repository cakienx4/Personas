@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix persona: <http://purl.obolibrary.org/obo/persona#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

persona:age a owl:Class ;
    rdfs:label "age"@vi ;
    rdfs:comment "Tuổi tính theo năm (Giới hạn từ 18 đến 90 tuổi)."@vi .

persona:an_dung_gio_ba_bua a owl:Class ;
    rdfs:label "Ăn đúng giờ ba bữa"@vi ;
    rdfs:comment "Duy trì thói quen ăn sáng, trưa, tối đều đặn tại các khung giờ cố định — phản ánh lối sống có nề nếp và ưu tiên sức khỏe tiêu hóa."@vi ;
    rdfs:subClassOf persona:tan_suat_va_gio_giac_an_uong .

persona:an_khuya_thuong_xuyen a owl:Class ;
    rdfs:label "Ăn khuya thường xuyên"@vi ;
    rdfs:comment "Thói quen ăn hoặc ăn vặt sau 9 giờ tối — gắn với lịch sinh hoạt muộn, thức khuya làm việc hoặc thói quen giải trí ban đêm."@vi ;
    rdfs:subClassOf persona:tan_suat_va_gio_giac_an_uong .

persona:an_uong_bao_thu_mon_quen a owl:Class ;
    rdfs:label "Ăn uống bảo thủ món quen"@vi ;
    rdfs:comment "Xu hướng chỉ ăn các món đã quen thuộc, ít sẵn sàng thử hương vị xa lạ hoặc khác biệt so với thói quen hàng ngày."@vi ;
    rdfs:subClassOf persona:muc_do_chap_nhan_vi_la .

persona:an_uong_coi_mo_thu_vi_moi a owl:Class ;
    rdfs:label "Ăn uống cởi mở thử vị mới"@vi ;
    rdfs:comment "Xu hướng háo hức khám phá hương vị chưa từng thử — sẵn sàng ăn món lạ, đặc sản địa phương hoặc ẩm thực nước ngoài xa lạ."@vi ;
    rdfs:subClassOf persona:muc_do_chap_nhan_vi_la .

persona:an_vat_rai_rac_ca_ngay a owl:Class ;
    rdfs:label "Ăn vặt rải rác cả ngày"@vi ;
    rdfs:comment "Thói quen ăn nhiều lần nhỏ trong ngày thay vì tập trung vào 3 bữa chính — thường gắn với công việc bận rộn hoặc sở thích ăn vặt liên tục."@vi ;
    rdfs:subClassOf persona:tan_suat_va_gio_giac_an_uong .

persona:anh_huong_dieu_kien_vat_ly_den_hieu_suat a owl:Class ;
    rdfs:label "Ảnh hưởng điều kiện vật lý đến hiệu suất"@vi ;
    rdfs:comment "Tác động của các yếu tố môi trường như nhiệt độ, ánh sáng, tiếng ồn và không gian đến năng suất và sức khỏe của cá nhân.\\nVí dụ thực tế từ dữ liệu: làm ngoài trời nắng nóng ảnh hưởng thể lực công nhân, bếp chật hẹp giới hạn số lượng món có thể chế biến cùng lúc."@vi ;
    rdfs:subClassOf persona:khong_gian_vat_ly_lam_viec .

persona:anh_huong_ton_giao_va_tin_nguong a owl:Class ;
    rdfs:label "Ảnh hưởng tôn giáo và tín ngưỡng"@vi ;
    persona:dinh_hinh persona:the_gioi_quan ;
    rdfs:comment "Mức độ tín ngưỡng dân gian, tôn giáo hoặc tâm linh tác động đến các thực hành sinh hoạt và quan niệm sống của cá nhân.\\nVí dụ thực tế từ dữ liệu: thắp nhang ngày Tết, nấu cháo bằng nồi đất giữ hương vị truyền thống, thả đèn hoa đăng đêm trăng rằm."@vi ;
    rdfs:subClassOf persona:boi_canh_xa_hoi_truyen_thong .

persona:bao_luu_van_hoa_goc a owl:Class ;
    rdfs:label "Bảo lưu văn hóa gốc"@vi ;
    rdfs:comment "Xu hướng giữ nguyên các thói quen và giá trị văn hóa truyền thống, ít sẵn sàng tiếp nhận hoặc thay đổi theo ảnh hưởng từ văn hóa bên ngoài."@vi ;
    rdfs:subClassOf persona:muc_do_tiep_nhan_van_hoa_ben_ngoai .

persona:bo_bua_sang_thuong_xuyen a owl:Class ;
    rdfs:label "Bỏ bữa sáng thường xuyên"@vi ;
    rdfs:comment "Thói quen không ăn sáng hoặc chỉ ăn rất ít vào buổi sáng — do bận rộn, không có thói quen, hoặc chủ động nhịn để kiểm soát calo."@vi ;
    rdfs:subClassOf persona:tan_suat_va_gio_giac_an_uong .

persona:cac_buoc_hanh_dong_xu_ly_van_de a owl:Class ;
    rdfs:label "Các bước hành động xử lý vấn đề"@vi ;
    rdfs:comment "Chuỗi hành động cụ thể mà cá nhân thực hiện để giải quyết một tình huống khó khăn sau khi đã phân tích.\\nVí dụ thực tế từ dữ liệu: báo bác sĩ ngay khi phát hiện bất thường, gọi nhà cung cấp khi hàng thiếu đột ngột, kiểm tra lại bản vẽ khi kết quả không khớp."@vi ;
    rdfs:subClassOf persona:phuong_phap_xu_ly_van_de .

persona:cach_to_chuc_cong_viec a owl:Class ;
    rdfs:label "Cách tổ chức công việc"@vi ;
    rdfs:comment "Phương thức sắp xếp không gian, công cụ và thông tin để công việc diễn ra có trật tự và hiệu quả.\\nVí dụ thực tế từ dữ liệu: sắp xếp hàng tạp hóa gọn gàng theo loại, chuẩn bị dụng cụ y tế trước ca trực, bố trí nguyên liệu nấu ăn theo thứ tự sử dụng."@vi ;
    rdfs:subClassOf persona:thoi_quen_lam_viec .

persona:cai_thien_do_linh_hoat a owl:Class ;
    rdfs:label "Cải thiện độ linh hoạt"@vi ;
    rdfs:comment "Quá trình tăng biên độ cử động của khớp và độ mềm dẻo của cơ thông qua tập giãn cơ và yoga.\\nVí dụ thực tế từ dữ liệu: sau 1 tháng tập yoga có thể ngồi xổm phẳng lòng bàn chân."@vi ;
    rdfs:subClassOf persona:cai_thien_the_luc .

persona:cai_thien_suc_ben_tim_mach a owl:Class ;
    rdfs:label "Cải thiện sức bền tim mạch"@vi ;
    rdfs:comment "Quá trình nâng cao khả năng tim phổi duy trì cung cấp oxy cho cơ trong thời gian dài mà không mệt sớm.\\nVí dụ thực tế từ dữ liệu: chạy bộ 30 phút không nghỉ sau khi luyện tập đều đặn."@vi ;
    rdfs:subClassOf persona:cai_thien_the_luc .

persona:cai_thien_suc_manh_co_bap a owl:Class ;
    rdfs:label "Cải thiện sức mạnh cơ bắp"@vi ;
    rdfs:comment "Quá trình tăng khả năng tạo lực tối đa của cơ trong một lần co cơ thông qua tập luyện kháng lực.\\nVí dụ thực tế từ dữ liệu: nâng tạ nặng hơn sau 2 tháng tập, đẩy tạ ngực tăng từ 40kg lên 50kg."@vi ;
    rdfs:subClassOf persona:cai_thien_the_luc .

persona:cai_thien_toc_do_phan_ung a owl:Class ;
    rdfs:label "Cải thiện tốc độ phản ứng"@vi ;
    rdfs:comment "Quá trình rút ngắn thời gian từ khi nhận kích thích đến khi cơ thể phản ứng, quan trọng trong các môn thể thao đòi hỏi phản xạ nhanh.\\nVí dụ thực tế từ dữ liệu: phản xạ đỡ bóng nhanh hơn sau nhiều buổi tập cầu lông."@vi ;
    rdfs:subClassOf persona:cai_thien_the_luc .

persona:cam_thu_nghe_thuat_chieu_sau a owl:Class ;
    rdfs:label "Cảm thụ nghệ thuật chiều sâu"@vi ;
    rdfs:comment "Cách thưởng thức chú ý đến chi tiết nghệ thuật, kỹ thuật và thông điệp của tác phẩm.\\nCá nhân chủ động suy nghĩ, cảm nhận và tìm hiểu ý nghĩa phía sau những gì được thể hiện."@vi ;
    rdfs:subClassOf persona:muc_do_chu_tam_nghe_thuat .

persona:can_nang_co_the a owl:Class ;
    rdfs:label "Cân nặng cơ thể"@vi ;
    rdfs:comment "Tổng khối lượng cơ thể tính bằng kg, là chỉ số dễ đo lường nhất nhưng không phản ánh đầy đủ thành phần cơ thể.\\nThường được dùng như tham chiếu ban đầu trong quản lý vóc dáng."@vi ;
    rdfs:subClassOf persona:chi_so_hinh_the .

persona:cap_do_to_chuc_yeu_thich a owl:Class ;
    rdfs:label "Cấp độ tổ chức yêu thích"@vi ;
    rdfs:comment "Quy mô và tầm ảnh hưởng của đội hoặc câu lạc bộ mà cá nhân gắn bó: từ cấp địa phương, tỉnh/thành đến quốc gia hay quốc tế.\\nVí dụ thực tế từ dữ liệu: ủng hộ câu lạc bộ bóng đá khu phố, theo dõi đội tuyển quốc gia Việt Nam."@vi ;
    rdfs:subClassOf persona:to_chuc_the_thao_yeu_thich .

persona:cap_nhat_kien_thuc_theo_thoi_gian a owl:Class ;
    rdfs:label "Cập nhật kiến thức theo thời gian"@vi ;
    rdfs:comment "Quá trình chủ động tiếp thu kiến thức và phương pháp mới để theo kịp sự phát triển của ngành.\\nVí dụ thực tế từ dữ liệu: điều dưỡng học thêm chứng chỉ tim mạch, kỹ sư cập nhật phần mềm thiết kế mới, người làm ẩm thực thử công thức cải tiến."@vi ;
    rdfs:subClassOf persona:kien_thuc_chuyen_nganh .

persona:chat_luong_dau_ra a owl:Class ;
    rdfs:label "Chất lượng đầu ra"@vi ;
    rdfs:comment "Mức độ sản phẩm hoặc dịch vụ tạo ra đáp ứng tiêu chuẩn và kỳ vọng đặt ra ban đầu.\\nVí dụ thực tế từ dữ liệu: phở đúng vị, công trình không thấm dột, bánh cống giữ được độ giòn đặc trưng."@vi ;
    rdfs:subClassOf persona:hieu_qua_thuc_hien_cong_viec .

persona:che_do_an_theo_van_hoa_truyen_thong a owl:Class ;
    rdfs:label "Chế độ ăn theo văn hóa truyền thống"@vi ;
    rdfs:comment "Cách ăn uống tuân theo thói quen và nguyên tắc ẩm thực được truyền lại từ gia đình hoặc cộng đồng văn hóa gốc.\\nVí dụ thực tế: ăn cơm 3 bữa theo nếp gia đình, giữ các món ăn truyền thống ngày lễ."@vi ;
    rdfs:subClassOf persona:che_do_an_uong_ca_nhan .

persona:che_do_dinh_duong_co_chu_dich a owl:Class ;
    rdfs:label "Chế độ dinh dưỡng có chủ đích"@vi ;
    rdfs:comment "Cách ăn uống được thiết kế có chủ đích nhằm đạt mục tiêu sức khỏe cụ thể — tăng cơ, giảm cân, tăng sức đề kháng hoặc cân bằng dinh dưỡng."@vi ;
    rdfs:subClassOf persona:che_do_an_uong_ca_nhan .

persona:che_do_kieng_thuc_pham a owl:Class ;
    rdfs:label "Chế độ kiêng thực phẩm"@vi ;
    rdfs:comment "Tập hợp quy tắc loại trừ hoặc hạn chế các nhóm thực phẩm nhất định khỏi bữa ăn.\\nVí dụ thực tế: kiêng đường, ăn chay hoàn toàn, không ăn gluten, hạn chế dầu mỡ."@vi ;
    rdfs:subClassOf persona:che_do_an_uong_ca_nhan .

persona:chi_so_bmi a owl:Class ;
    rdfs:label "Chỉ số BMI"@vi ;
    rdfs:comment "Tỷ số giữa cân nặng và bình phương chiều cao, được dùng như thước đo sơ bộ để đánh giá người thiếu cân, bình thường, thừa cân hay béo phì.\\nCó giới hạn khi không phân biệt được mỡ và cơ."@vi ;
    rdfs:subClassOf persona:chi_so_hinh_the .

persona:chia_se_am_thuc_tren_mang_xa_hoi a owl:Class ;
    rdfs:label "Chia sẻ ẩm thực trên mạng xã hội"@vi ;
    rdfs:comment "Đăng ảnh món ăn, viết review quán hoặc chia sẻ công thức lên các nền tảng mạng xã hội — Facebook, Instagram, TikTok — để lan truyền trải nghiệm ẩm thực."@vi ;
    rdfs:subClassOf persona:hanh_vi_chia_se_am_thuc .

persona:chia_se_cong_thuc_trong_gia_dinh a owl:Class ;
    rdfs:label "Chia sẻ công thức trong gia đình"@vi ;
    rdfs:comment "Truyền đạt kiến thức nấu ăn cho người thân trong gia đình — dạy con, cháu hoặc chia sẻ công thức gia truyền để giữ gìn truyền thống ẩm thực."@vi ;
    rdfs:subClassOf persona:hanh_vi_chia_se_am_thuc .

persona:chien_thuat_trong_thi_dau a owl:Class ;
    rdfs:label "Chiến thuật trong thi đấu"@vi ;
    rdfs:comment "Cách lựa chọn và phối hợp các hành động trong khi thi đấu để tối ưu hóa cơ hội chiến thắng.\\nVí dụ thực tế từ dữ liệu: chơi phòng thủ chắc khi đang dẫn điểm, khai thác điểm yếu đối thủ trong cầu lông."@vi ;
    rdfs:subClassOf persona:ky_nang_the_thao .

persona:chieu_sau_phan_tich_thi_dau a owl:Class ;
    rdfs:label "Chiều sâu phân tích thi đấu"@vi ;
    rdfs:comment "Mức độ tìm hiểu kỹ thuật, chiến thuật và dữ liệu thi đấu mà cá nhân đào sâu khi theo dõi thể thao.\\nPhân biệt giữa người chỉ xem kết quả thắng thua và người phân tích đội hình, cách chơi từng trận."@vi ;
    rdfs:subClassOf persona:muc_do_quan_tam_theo_doi .

persona:chuan_muc_cong_dong_dia_phuong a owl:Class ;
    rdfs:label "Chuẩn mực cộng đồng địa phương"@vi ;
    persona:dinh_hinh persona:tieu_chuan_dao_duc_ca_nhan ;
    rdfs:comment "Các quy ước, kỳ vọng và tiêu chuẩn hành vi ngầm định được cộng đồng địa phương xung quanh cá nhân chia sẻ và thực thi.\\nVí dụ thực tế từ dữ liệu: thói quen tụ tập vỉa hè, văn hóa chợ truyền thống, nếp sống khu phố tập thể, giao lưu hàng xóm trong khu nhà ống."@vi ;
    rdfs:subClassOf persona:boi_canh_xa_hoi_truyen_thong .

persona:chuan_muc_ung_xu_noi_bo a owl:Class ;
    rdfs:label "Chuẩn mực ứng xử nội bộ"@vi ;
    rdfs:comment "Các quy tắc hành vi ngầm định hoặc tường minh điều chỉnh cách các thành viên đối xử với nhau trong tổ chức.\\nVí dụ thực tế từ dữ liệu: gọi nhau bằng chức danh trong bệnh viện, chia sẻ thông tin giá cả trong cộng đồng tiểu thương."@vi ;
    rdfs:subClassOf persona:van_hoa_doanh_nghiep .

persona:chuc_nang_san_xuat_hoac_dich_vu a owl:Class ;
    rdfs:label "Chức năng sản xuất hoặc dịch vụ"@vi ;
    rdfs:comment "Vai trò kinh tế cốt lõi của một ngành nghề: tạo ra hàng hóa vật chất (sản xuất) hoặc cung cấp giá trị phi vật chất (dịch vụ).\\nVí dụ thực tế từ dữ liệu: nông nghiệp trồng rau là sản xuất, điều dưỡng chăm sóc bệnh nhân là dịch vụ, bán tạp hóa là thương mại dịch vụ."@vi ;
    rdfs:subClassOf persona:nganh_nghe .

persona:chuyen_nganh_hoac_tu_khoi_nghiep a owl:Class ;
    rdfs:label "Chuyển ngành hoặc tự khởi nghiệp"@vi ;
    rdfs:comment "Quyết định thay đổi hướng đi nghề nghiệp bằng cách sang lĩnh vực mới hoặc tự tạo ra cơ sở kinh doanh của riêng mình.\\nVí dụ thực tế từ dữ liệu: từ xây dựng chuyển sang quản lý tài chính cá nhân, mở xưởng sửa chữa thiết bị nông nghiệp riêng."@vi ;
    rdfs:subClassOf persona:phat_trien_su_nghiep .

persona:co_hay_khong_tham_gia_van_dong a owl:Class ;
    rdfs:label "Có hay không tham gia vận động"@vi ;
    rdfs:comment "Xác định nhị phân liệu cá nhân có thực hiện bất kỳ hình thức hoạt động thể chất nào trong sinh hoạt thường ngày hay không.\\nLà bước phân loại đầu tiên trước khi xét đến hình thức và mức độ cụ thể."@vi ;
    rdfs:subClassOf persona:tinh_trang_tham_gia_the_thao .

persona:co_hoc_co_the_trong_van_dong a owl:Class ;
    rdfs:label "Cơ học cơ thể trong vận động"@vi ;
    rdfs:comment "Cách các phần cơ thể phối hợp và di chuyển để tạo ra lực và chuyển động hiệu quả nhất.\\nVí dụ thực tế: sử dụng đúng trọng tâm khi chạy, phối hợp tay chân nhịp nhàng khi bơi."@vi ;
    rdfs:subClassOf persona:ky_thuat_van_dong .

persona:co_so_vat_chat_va_ha_tang a owl:Class ;
    rdfs:label "Cơ sở vật chất và hạ tầng"@vi ;
    rdfs:comment "Trang thiết bị, công cụ và điều kiện kỹ thuật được trang bị tại nơi làm việc hỗ trợ cá nhân thực hiện công việc.\\nVí dụ thực tế từ dữ liệu: thiết bị y tế tại bệnh viện, máy móc tại công trình xây dựng, quầy hàng và kệ tủ tại tiệm tạp hóa."@vi ;
    rdfs:subClassOf persona:khong_gian_vat_ly_lam_viec .

persona:coi_mo_tiep_nhan_van_hoa_ben_ngoai a owl:Class ;
    rdfs:label "Cởi mở tiếp nhận văn hóa bên ngoài"@vi ;
    rdfs:comment "Sẵn sàng học hỏi, thử nghiệm và tích hợp các yếu tố từ văn hóa khác vào lối sống — coi đó là sự làm giàu thêm cho bản sắc cá nhân."@vi ;
    rdfs:subClassOf persona:muc_do_tiep_nhan_van_hoa_ben_ngoai .

persona:coi_mo_voi_am_thuc_quoc_te a owl:Class ;
    rdfs:label "Cởi mở với ẩm thực quốc tế"@vi ;
    rdfs:comment "Sẵn sàng và hứng thú khám phá các nền ẩm thực từ nhiều quốc gia và văn hóa khác nhau — thích thử sushi Nhật, mì Ý, cà ri Thái hay các món ít phổ biến hơn."@vi ;
    rdfs:subClassOf persona:su_coi_mo_voi_am_thuc_quoc_te .

persona:cong_viec_cot_loi a owl:Class ;
    rdfs:label "Công việc cốt lõi"@vi ;
    rdfs:comment "Hoạt động trực tiếp tạo ra giá trị chính và là lý do tồn tại của vai trò nghề nghiệp của cá nhân.\\nVí dụ thực tế từ dữ liệu: điều dưỡng chăm sóc bệnh nhân, nông dân trồng và thu hoạch rau, thợ lắp đặt hệ thống kỹ thuật tại công trình."@vi ;
    rdfs:subClassOf persona:hoat_dong_nghe_nghiep .

persona:country a owl:Class ;
    rdfs:label "country"@vi ;
    rdfs:comment "Quốc gia cư trú (Giá trị cố định: Việt Nam)."@vi .

persona:cung_co a owl:ObjectProperty ;
    rdfs:label "cung_co"@vi ;
    rdfs:comment "A làm B mạnh hơn hoặc ổn định hơn; B đã tồn tại sẵn và A củng cố thêm"@vi .

persona:cuong_do_cam_xuc_tich_cuc_voi_van_dong a owl:Class ;
    rdfs:label "Cường độ cảm xúc tích cực với vận động"@vi ;
    rdfs:comment "Mức độ niềm vui, hứng khởi và sự thỏa mãn mà cá nhân cảm nhận được khi tham gia hoặc nghĩ đến hoạt động thể chất.\\nPhân biệt giữa người vận động vì bắt buộc và người thực sự yêu thích cảm giác vận động."@vi ;
    rdfs:subClassOf persona:muc_do_hung_thu_van_dong .

persona:cuong_do_lam_viec a owl:Class ;
    rdfs:label "Cường độ làm việc"@vi ;
    persona:tac_dong persona:che_do_an_uong_ca_nhan,
        persona:muc_do_hung_thu_van_dong ;
    rdfs:comment "Mức độ nỗ lực thể chất và tinh thần mà cá nhân bỏ ra trong mỗi đơn vị thời gian làm việc.\\nPhân biệt giữa làm việc nhẹ nhàng thong thả và làm việc với cường độ cao, áp lực liên tục."@vi ;
    rdfs:subClassOf persona:muc_do_dau_tu_thoi_gian_va_nguon_luc .

persona:cuong_do_van_dong_uu_tien a owl:Class ;
    rdfs:label "Cường độ vận động ưu tiên"@vi ;
    rdfs:comment "Mức gắng sức thể chất mà cá nhân cảm thấy phù hợp và chủ động tìm kiếm trong hoạt động vận động."@vi ;
    rdfs:subClassOf persona:thien_huong_loai_hinh_van_dong .

persona:dac_diem_tinh_cach_noi_bat a owl:Class ;
    rdfs:label "Đặc điểm tính cách nổi bật"@vi ;
    persona:tuong_quan persona:phuong_tien_bieu_dat_nghe_thuat ;
    rdfs:comment "Các nét tính cách ổn định, nhất quán và rõ ràng định hình cách cá nhân tư duy, cảm nhận và hành xử.\\nVí dụ: hướng ngoại / hướng nội, cầu toàn, sáng tạo, thực dụng, đồng cảm cao."@vi ;
    rdfs:subClassOf persona:ban_sac_ca_nhan .

persona:dam_me_ben_vung_dai_han a owl:Class ;
    rdfs:label "Đam mê bền vững dài hạn"@vi ;
    rdfs:comment "Đam mê duy trì qua nhiều năm, không bị gián đoạn bởi thay đổi hoàn cảnh hay giai đoạn khó khăn trong cuộc sống.\\nVí dụ thực tế: giữ gìn hội hoa phượng đỏ từ những năm 90, dù nghỉ hưu vẫn tiếp tục dạy nấu ăn truyền thống."@vi ;
    rdfs:subClassOf persona:muc_do_kien_tri_dam_me .

persona:dam_me_theo_giai_doan a owl:Class ;
    rdfs:label "Đam mê theo giai đoạn"@vi ;
    rdfs:comment "Đam mê xuất hiện mạnh trong một thời kỳ nhất định nhưng có thể giảm hoặc thay đổi theo biến động của cuộc sống — công việc, gia đình hoặc sức khỏe."@vi ;
    rdfs:subClassOf persona:muc_do_kien_tri_dam_me .

persona:danh_sach_dong_tac_va_bai_tap a owl:Class ;
    rdfs:label "Danh sách động tác và bài tập"@vi ;
    rdfs:comment "Tập hợp các hoạt động vận động cụ thể được chọn lọc và đưa vào chương trình tập luyện.\\nVí dụ thực tế từ dữ liệu: squat, plank, bơi sải, đi bộ nhanh, đá bóng rondo luyện phản xạ."@vi ;
    rdfs:subClassOf persona:he_thong_bai_tap .

persona:danh_tieng_nghe_nghiep a owl:Class ;
    rdfs:label "Danh tiếng nghề nghiệp"@vi ;
    rdfs:comment "Mức độ được công nhận và đánh giá cao của cá nhân trong cộng đồng nghề nghiệp hoặc cộng đồng khách hàng.\\nVí dụ thực tế từ dữ liệu: được biết đến là người làm bánh đa cua ngon nhất khu vực, được bệnh nhân tin tưởng và giới thiệu nhau."@vi ;
    rdfs:subClassOf persona:phat_trien_su_nghiep .

persona:dao_duc_hinh_thanh_tu_giao_duc_gia_dinh a owl:Class ;
    rdfs:label "Đạo đức hình thành từ giáo dục gia đình"@vi ;
    rdfs:comment "Tiêu chuẩn đúng sai được truyền dạy trực tiếp từ cha mẹ, ông bà và môi trường gia đình — thường là nền tảng đạo đức sớm nhất và ổn định nhất."@vi ;
    rdfs:subClassOf persona:tieu_chuan_dao_duc_ca_nhan .

persona:dao_duc_hinh_thanh_tu_ton_giao a owl:Class ;
    rdfs:label "Đạo đức hình thành từ tôn giáo"@vi ;
    rdfs:comment "Tiêu chuẩn đúng sai dựa trên giáo lý, điều răn và hệ thống đạo đức của một tín ngưỡng hoặc tôn giáo cụ thể mà cá nhân theo."@vi ;
    rdfs:subClassOf persona:tieu_chuan_dao_duc_ca_nhan .

persona:dao_duc_hinh_thanh_tu_trai_nghiem_ca_nhan a owl:Class ;
    rdfs:label "Đạo đức hình thành từ trải nghiệm cá nhân"@vi ;
    rdfs:comment "Tiêu chuẩn đúng sai được đúc kết từ các sự kiện, va chạm và bài học trong cuộc sống riêng của cá nhân — có thể khác biệt hoặc bổ sung cho những gì được dạy từ bên ngoài."@vi ;
    rdfs:subClassOf persona:tieu_chuan_dao_duc_ca_nhan .

persona:dao_duc_hinh_thanh_tu_van_hoa a owl:Class ;
    rdfs:label "Đạo đức hình thành từ văn hóa"@vi ;
    rdfs:comment "Tiêu chuẩn đúng sai được hấp thụ từ các chuẩn mực, phong tục và giá trị của cộng đồng văn hóa mà cá nhân lớn lên và sinh sống."@vi ;
    rdfs:subClassOf persona:tieu_chuan_dao_duc_ca_nhan .

persona:dao_tao_bai_ban_co_to_chuc a owl:Class ;
    rdfs:label "Đào tạo bài bản có tổ chức"@vi ;
    rdfs:comment "Tích lũy kiến thức và kỹ năng qua các chương trình học chính thức — trường học, khóa đào tạo nghề, chương trình chứng chỉ có cấu trúc bài bản."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tich_luy_kinh_nghiem .

persona:dat_tour_tron_goi a owl:Class ;
    rdfs:label "Đặt tour trọn gói"@vi ;
    rdfs:comment "Sử dụng dịch vụ lữ hành tổ chức toàn bộ hành trình theo chương trình định sẵn — phù hợp người muốn tiết kiệm công sức lên kế hoạch."@vi ;
    rdfs:subClassOf persona:hinh_thuc_to_chuc_hanh_trinh .

persona:dau_ra_cu_the_can_hoan_thanh a owl:Class ;
    rdfs:label "Đầu ra cụ thể cần hoàn thành"@vi ;
    rdfs:comment "Kết quả hữu hình hoặc có thể đo lường mà nhiệm vụ nghề nghiệp yêu cầu cá nhân tạo ra.\\nVí dụ thực tế từ dữ liệu: mẻ bánh đa thành phẩm, hồ sơ bệnh nhân được cập nhật đầy đủ, hạng mục công trình được nghiệm thu."@vi ;
    rdfs:subClassOf persona:nhiem_vu_nghe_nghiep .

persona:dau_tu_tai_chinh_vao_nghe_nghiep a owl:Class ;
    rdfs:label "Đầu tư tài chính vào nghề nghiệp"@vi ;
    rdfs:comment "Số tiền cá nhân chi ra để duy trì hoặc phát triển hoạt động nghề nghiệp: mua công cụ, học thêm, mở rộng cơ sở.\\nVí dụ thực tế từ dữ liệu: mua phân bón và hạt giống, đóng học phí lấy chứng chỉ điều dưỡng, nhập hàng tạp hóa."@vi ;
    rdfs:subClassOf persona:muc_do_dau_tu_thoi_gian_va_nguon_luc .

persona:di_chuyen_giua_cac_dia_diem a owl:Class ;
    rdfs:label "Di chuyển giữa các địa điểm"@vi ;
    rdfs:comment "Cách thức và phương tiện cá nhân sử dụng để di chuyển giữa các điểm trong cùng vùng hoặc thành phố — taxi, xe buýt, thuê xe, đi bộ."@vi ;
    rdfs:subClassOf persona:hoat_dong_luu_tru_va_di_chuyen .

persona:dia_danh_va_moi_truong_song_thuo_nho a owl:Class ;
    rdfs:label "Địa danh và môi trường sống thuở nhỏ"@vi ;
    persona:dinh_hinh persona:nguyen_tac_song_nen_tang,
        persona:nhom_thuc_pham_uu_tien ;
    rdfs:comment "Nơi chốn cụ thể mà cá nhân sinh ra, lớn lên và hình thành ký ức đầu đời.\\nVí dụ thực tế từ dữ liệu: khu nhà tập thể Hải Phòng, nhà ống 4 tầng khu Nghi Sơn, căn hộ quận Bình Thạnh, phố cổ Hà Nội với những con ngõ uốn quanh."@vi ;
    rdfs:subClassOf persona:nguon_goc_hoac_nen_tang_van_hoa .

persona:dia_diem_lam_viec_cu_the a owl:Class ;
    rdfs:label "Địa điểm làm việc cụ thể"@vi ;
    rdfs:comment "Vị trí địa lý và không gian thực tế nơi cá nhân thực hiện công việc hàng ngày.\\nVí dụ thực tế từ dữ liệu: bệnh viện tư quận Bình Thạnh, công trình xây dựng ngoài trời, tiệm tạp hóa tầng 1 nhà ống, ruộng rau ngoại thành, căn bếp 10m²."@vi ;
    rdfs:subClassOf persona:khong_gian_vat_ly_lam_viec .

persona:dia_diem_tap_luyen_thuong_xuyen a owl:Class ;
    rdfs:label "Địa điểm tập luyện thường xuyên"@vi ;
    rdfs:comment "Nơi cố định mà cá nhân thực hiện hoạt động thể chất định kỳ.\\nVí dụ thực tế từ dữ liệu: công viên gần nhà, hồ bơi quận, sân bóng khu phố, phòng gym, hay tại nhà."@vi ;
    rdfs:subClassOf persona:boi_canh_tham_gia_the_thao .

persona:dinh_hinh a owl:ObjectProperty ;
    rdfs:label "dinh_hinh"@vi ;
    rdfs:comment "A quyết định bản chất hoặc hướng đi của B; B phụ thuộc vào A để hình thành hoặc định hướng"@vi .

persona:dinh_huong_ly_tuong a owl:Class ;
    rdfs:label "Định hướng lý tưởng"@vi ;
    rdfs:comment "Xu hướng theo đuổi hình mẫu hoàn hảo và không thỏa hiệp với những gì kém lý tưởng — giữ vững tiêu chuẩn cao dù điều kiện thực tế không cho phép."@vi ;
    rdfs:subClassOf persona:dinh_huong_thuc_te_voi_ly_tuong .

persona:dinh_huong_thuc_te a owl:Class ;
    rdfs:label "Định hướng thực tế"@vi ;
    rdfs:comment "Xu hướng ưu tiên các giải pháp khả thi và chấp nhận những gì có thể đạt được trong điều kiện thực tế — sẵn sàng thỏa hiệp để tiến về phía trước."@vi ;
    rdfs:subClassOf persona:dinh_huong_thuc_te_voi_ly_tuong .

persona:dinh_kien_va_quan_diem_tiem_an a owl:Class ;
    rdfs:label "Định kiến và quan điểm tiềm ẩn"@vi ;
    persona:tuong_quan persona:niem_tin_ve_su_thay_doi ;
    rdfs:comment "Các nhận định, thành kiến hoặc kỳ vọng được hình thành từ nền tảng văn hóa và tồn tại ngầm trong tư duy cá nhân mà không phải lúc nào cũng được ý thức rõ ràng.\\nVí dụ thực tế: coi trọng bằng cấp chính thức hơn kinh nghiệm thực tế, xem đàn ông là trụ cột kinh tế gia đình."@vi ;
    rdfs:subClassOf persona:nhan_thuc_ca_nhan_van_hoa .

persona:do_chinh_xac_dong_tac a owl:Class ;
    rdfs:label "Độ chính xác động tác"@vi ;
    rdfs:comment "Mức độ thực hiện đúng hình thức kỹ thuật của một động tác so với chuẩn mực của môn thể thao.\\nVí dụ thực tế: đúng tư thế squat không gù lưng, đúng kỹ thuật bơi sải không vặn hông."@vi ;
    rdfs:subClassOf persona:ky_thuat_van_dong .

persona:do_chinh_xac_trong_thuc_hanh a owl:Class ;
    rdfs:label "Độ chính xác trong thực hành"@vi ;
    rdfs:comment "Mức độ không sai sót khi cá nhân thực hiện một thao tác hoặc quy trình nghề nghiệp cụ thể.\\nVí dụ thực tế từ dữ liệu: tiêm bắp đúng vị trí và liều lượng, lắp điện đúng sơ đồ không để rò rỉ, nấu phở đúng tỷ lệ gia vị."@vi ;
    rdfs:subClassOf persona:ky_nang_thuc_hanh_nghe_nghiep .

persona:do_tin_cay_nghe_nghiep a owl:Class ;
    rdfs:label "Độ tin cậy nghề nghiệp"@vi ;
    rdfs:comment "Mức độ mà những người xung quanh có thể tin tưởng vào cam kết và hành động của cá nhân trong công việc.\\nVí dụ thực tế từ dữ liệu: luôn hoàn thành đúng hạn, không để đồng nghiệp phải nhắc nhở, nói là làm."@vi ;
    rdfs:subClassOf persona:tinh_nhat_quan_hanh_vi .

persona:doi_tuong_dam_me a owl:Class ;
    rdfs:label "Đối tượng đam mê"@vi ;
    rdfs:comment "Hoạt động, lĩnh vực hoặc chủ đề cụ thể là tâm điểm của đam mê cá nhân.\\nVí dụ thực tế từ dữ liệu: đam mê ẩm thực truyền thống Hải Phòng, đam mê nghệ thuật chèo, đam mê vẽ tranh phong cảnh với màu rực rỡ, đam mê truyền dạy công thức gia truyền."@vi ;
    rdfs:subClassOf persona:dam_me_ca_nhan .

persona:dong_luc_dong_gop_cho_xa_hoi a owl:Class ;
    rdfs:label "Động lực đóng góp cho xã hội"@vi ;
    rdfs:comment "Mong muốn công việc tạo ra giá trị vượt ra ngoài lợi ích cá nhân — đóng góp cho cộng đồng, phát triển ngành nghề hoặc giải quyết vấn đề xã hội."@vi ;
    rdfs:subClassOf persona:dong_luc_phat_trien_su_nghiep .

persona:dong_luc_giai_toa_cam_xuc a owl:Class ;
    rdfs:label "Động lực giải tỏa cảm xúc"@vi ;
    rdfs:comment "Nhu cầu dùng sáng tạo như kênh giải phóng cảm xúc tích tụ — buồn bã, căng thẳng, hạnh phúc — thay vì mục tiêu nghệ thuật thuần túy."@vi ;
    rdfs:subClassOf persona:dong_luc_sang_tao_nghe_thuat .

persona:dong_luc_lo_cho_gia_dinh a owl:Class ;
    rdfs:label "Động lực lo cho gia đình"@vi ;
    rdfs:comment "Mong muốn phát triển sự nghiệp xuất phát từ trách nhiệm và tình cảm với gia đình — xây nhà cho cha mẹ, lo học phí cho con, đảm bảo cuộc sống ổn định cho người thân."@vi ;
    rdfs:subClassOf persona:dong_luc_phat_trien_su_nghiep .

persona:dong_luc_quyen_luc_trong_quan_he a owl:Class ;
    rdfs:label "Động lực quyền lực trong quan hệ"@vi ;
    rdfs:comment "Sự phân bổ ảnh hưởng và thẩm quyền trong mạng lưới quan hệ nghề nghiệp của cá nhân.\\nPhản ánh ai có tiếng nói quyết định, ai phụ thuộc vào ai và cách cá nhân điều hướng sự chênh lệch quyền lực đó."@vi ;
    rdfs:subClassOf persona:van_hoa_doanh_nghiep .

persona:dong_luc_tim_kiem_niem_vui a owl:Class ;
    rdfs:label "Động lực tìm kiếm niềm vui"@vi ;
    rdfs:comment "Sáng tạo nghệ thuật xuất phát từ niềm vui thuần túy của quá trình làm — không áp lực kết quả hay đánh giá từ người ngoài."@vi ;
    rdfs:subClassOf persona:dong_luc_sang_tao_nghe_thuat .

persona:dong_luc_truyen_nghe_va_bao_ton_truyen_thong a owl:Class ;
    rdfs:label "Động lực truyền nghề và bảo tồn truyền thống"@vi ;
    rdfs:comment "Mong muốn phát triển sự nghiệp để có đủ uy tín và nền tảng truyền dạy nghề truyền thống cho thế hệ sau.\\nVí dụ thực tế: muốn được phong nghệ nhân để có thể mở lớp dạy nấu ăn truyền thống."@vi ;
    rdfs:subClassOf persona:dong_luc_phat_trien_su_nghiep .

persona:dong_luc_truyen_tai_thong_diep a owl:Class ;
    rdfs:label "Động lực truyền tải thông điệp"@vi ;
    rdfs:comment "Mong muốn dùng nghệ thuật để bày tỏ quan điểm, phản ánh xã hội hoặc kể câu chuyện có ý nghĩa với người khác."@vi ;
    rdfs:subClassOf persona:dong_luc_sang_tao_nghe_thuat .

persona:dong_luc_tu_khang_dinh_ban_than a owl:Class ;
    rdfs:label "Động lực tự khẳng định bản thân"@vi ;
    rdfs:comment "Mong muốn phát triển sự nghiệp để chứng minh năng lực và giá trị của mình — vượt qua giới hạn xuất phát điểm, được công nhận và tôn trọng."@vi ;
    rdfs:subClassOf persona:dong_luc_phat_trien_su_nghiep .

persona:du_lich_cap_doi a owl:Class ;
    rdfs:label "Du lịch cặp đôi"@vi ;
    rdfs:comment "Đi cùng người thân thiết — bạn đời, vợ/chồng — lịch trình ưu tiên trải nghiệm chung và kết nối tình cảm."@vi ;
    rdfs:subClassOf persona:quy_mo_nhom_du_lich .

persona:du_lich_gia_dinh_nho a owl:Class ;
    rdfs:label "Du lịch gia đình nhỏ"@vi ;
    rdfs:comment "Đi cùng gia đình nhỏ 3–5 người, lịch trình cần cân bằng nhu cầu của các thành viên khác nhau, thường ưu tiên an toàn và tiện lợi."@vi ;
    rdfs:subClassOf persona:quy_mo_nhom_du_lich .

persona:du_lich_mot_minh a owl:Class ;
    rdfs:label "Du lịch một mình"@vi ;
    rdfs:comment "Đi solo, tự do hoàn toàn về lịch trình và quyết định, không phụ thuộc vào sở thích của người khác.\\nThường gắn với nhu cầu khám phá bản thân hoặc tận hưởng sự tự do tuyệt đối."@vi ;
    rdfs:subClassOf persona:quy_mo_nhom_du_lich .

persona:du_lich_nhom_ban_be a owl:Class ;
    rdfs:label "Du lịch nhóm bạn bè"@vi ;
    rdfs:comment "Đi cùng nhóm bạn từ 4 người trở lên, lịch trình sôi động, ưu tiên hoạt động tập thể và trải nghiệm chung, đòi hỏi sự phối hợp trong quyết định."@vi ;
    rdfs:subClassOf persona:quy_mo_nhom_du_lich .

persona:dung_cu_bep_truyen_thong a owl:Class ;
    rdfs:label "Dụng cụ bếp truyền thống"@vi ;
    rdfs:comment "Các công cụ và thiết bị nấu ăn thủ công hoặc cổ điển — nồi đất, bếp củi, bếp gas thông thường, chảo gang, cối đá."@vi ;
    rdfs:subClassOf persona:thiet_bi_va_dung_cu_nau_an_su_dung .

persona:duy_tri_moi_quan_he_qua_the_thao a owl:Class ;
    rdfs:label "Duy trì mối quan hệ qua thể thao"@vi ;
    rdfs:comment "Việc sử dụng hoạt động thể chất định kỳ như dịp gặp gỡ và củng cố các mối quan hệ đã có.\\nVí dụ thực tế từ dữ liệu: đá bóng cùng nhóm bạn cũ mỗi cuối tuần, đi bơi cùng đồng nghiệp sau giờ làm."@vi ;
    rdfs:subClassOf persona:muc_dich_ket_noi_xa_hoi .

persona:duy_tri_tinh_than_soi_dong a owl:Class ;
    rdfs:label "Duy trì tinh thần sôi động"@vi ;
    rdfs:comment "Vận động như cách giữ cho năng lượng và tinh thần tích cực, tránh cảm giác uể oải hay trì trệ.\\nVí dụ thực tế từ dữ liệu: tập thể dục buổi sáng để vào ngày mới với năng lượng tốt."@vi ;
    rdfs:subClassOf persona:muc_dich_giai_tri_tinh_than .

persona:education_level a owl:Class ;
    rdfs:label "education_level"@vi ;
    rdfs:comment "Cấp học cao nhất đã hoàn thành: Không học vấn, Tiểu học, THCS, THPT, Trung cấp / Cao đẳng, Đại học, Sau đại học."@vi .

persona:gan_bo_cam_xuc_voi_doi_the_thao a owl:Class ;
    rdfs:label "Gắn bó cảm xúc với đội thể thao"@vi ;
    rdfs:comment "Mức độ đồng nhất cảm xúc của cá nhân với thành tích và vận mệnh của đội yêu thích: vui khi đội thắng, buồn khi đội thua.\\nPhản ánh đội không chỉ là đối tượng theo dõi mà là một phần trong danh tính của người hâm mộ."@vi ;
    rdfs:subClassOf persona:su_ung_ho_tinh_than .

persona:gia_dinh_da_the_he a owl:Class ;
    rdfs:label "Gia đình đa thế hệ"@vi ;
    rdfs:comment "Hình thức gia đình có từ 3 thế hệ trở lên cùng chung sống dưới một mái nhà — ông bà, cha mẹ, con cái.\\nTạo ra môi trường truyền dạy giá trị trực tiếp và gắn kết văn hóa giữa các thế hệ."@vi ;
    rdfs:subClassOf persona:cau_truc_gia_dinh .

persona:gia_dinh_hat_nhan a owl:Class ;
    rdfs:label "Gia đình hạt nhân"@vi ;
    rdfs:comment "Hình thức gia đình chỉ gồm cha mẹ và con cái, không có ông bà hoặc họ hàng cùng chung sống.\\nThường gắn với lối sống đô thị hiện đại và mức độ độc lập cao hơn trong các quyết định gia đình."@vi ;
    rdfs:subClassOf persona:cau_truc_gia_dinh .

persona:gia_tri_ca_nhan_gan_voi_van_dong a owl:Class ;
    rdfs:label "Giá trị cá nhân gắn với vận động"@vi ;
    rdfs:comment "Lý do sâu xa khiến cá nhân đặt một loại hình vận động lên hàng đầu, phản ánh điều cá nhân trân trọng nhất qua hoạt động thể chất.\\nPhân biệt giữa người vận động vì sức khỏe, vì hình thể hay vì tính cạnh tranh đua tranh."@vi ;
    rdfs:subClassOf persona:su_uu_tien_van_dong .

persona:gia_tri_coi_trong_gia_dinh a owl:Class ;
    rdfs:label "Giá trị coi trọng gia đình"@vi ;
    rdfs:comment "Giá trị sống ẩn hiện qua việc ưu tiên dành thời gian và tâm sức cho các thành viên gia đình trong các hoạt động thường ngày.\\nVí dụ thực tế: kể chuyện cho con cháu nghe đêm trăng tròn, cùng cháu nội chơi cờ vua mỗi tối."@vi ;
    rdfs:subClassOf persona:gia_tri_phong_cach_song_an_hien .

persona:gia_tri_dong_gop_ca_nhan a owl:Class ;
    rdfs:label "Giá trị đóng góp cá nhân"@vi ;
    rdfs:comment "Tác động và ý nghĩa của việc hoàn thành nhiệm vụ đối với tổ chức hoặc cộng đồng mà cá nhân phục vụ.\\nVí dụ thực tế từ dữ liệu: bệnh nhân phục hồi tốt nhờ chăm sóc đúng, công trình hoàn thành đúng tiến độ phục vụ người dân, truyền nghề giữ gìn ẩm thực truyền thống."@vi ;
    rdfs:subClassOf persona:nhiem_vu_nghe_nghiep .

persona:gia_tri_gan_bo_cong_dong a owl:Class ;
    rdfs:label "Giá trị gắn bó cộng đồng"@vi ;
    rdfs:comment "Giá trị sống ẩn hiện qua việc đầu tư thời gian và công sức vào các hoạt động tập thể của cộng đồng địa phương.\\nVí dụ thực tế: duy trì hội hoa phượng đỏ dù đã nghỉ hưu, tổ chức đèn hoa đăng sông Cấm hàng năm."@vi ;
    rdfs:subClassOf persona:gia_tri_phong_cach_song_an_hien .

persona:gia_tri_song_ca_nhan a owl:Class ;
    rdfs:label "Giá trị sống cá nhân"@vi ;
    persona:dinh_hinh persona:loai_hinh_so_thich ;
    rdfs:comment "Những điều mà cá nhân cho là quan trọng nhất và sẵn sàng ưu tiên, hy sinh hoặc bảo vệ trong cuộc sống.\\nVí dụ: tự do cá nhân, gia đình, sự thành đạt, lòng trung thực, sự an toàn hoặc kết nối cộng đồng."@vi ;
    rdfs:subClassOf persona:ban_sac_ca_nhan .

persona:gia_tri_to_chuc a owl:Class ;
    rdfs:label "Giá trị tổ chức"@vi ;
    rdfs:comment "Các nguyên tắc cốt lõi mà tổ chức đề cao và kỳ vọng mọi thành viên thể hiện trong công việc hàng ngày.\\nVí dụ thực tế từ dữ liệu: bệnh viện đề cao an toàn bệnh nhân, tiệm tạp hóa gia đình coi trọng uy tín với khách quen lâu năm."@vi ;
    rdfs:subClassOf persona:van_hoa_doanh_nghiep .

persona:gia_tri_tran_trong_truyen_thong a owl:Class ;
    rdfs:label "Giá trị trân trọng truyền thống"@vi ;
    rdfs:comment "Giá trị sống ẩn hiện qua việc chủ động duy trì các thói quen và thực hành truyền thống dù có đủ điều kiện hiện đại hóa.\\nVí dụ thực tế: vẫn nấu nồi đất dù có lò vi sóng, giữ công thức bánh đúng chuẩn dù đã nghỉ hưu."@vi ;
    rdfs:subClassOf persona:gia_tri_phong_cach_song_an_hien .

persona:giai_tri_de_bao_ton_van_hoa a owl:Class ;
    rdfs:label "Giải trí để bảo tồn văn hóa"@vi ;
    rdfs:comment "Hoạt động giải trí gắn với sứ mệnh gìn giữ và truyền dạy các giá trị văn hóa truyền thống cho thế hệ sau.\\nVí dụ thực tế: nghe cải lương để hoài niệm, duy trì lớp múa quan họ sân đình, dạy làm nem cua bể cho lớp trẻ."@vi ;
    rdfs:subClassOf persona:chuc_nang_giai_tri_doi_voi_ca_nhan .

persona:giai_tri_de_giai_toa_stress a owl:Class ;
    rdfs:label "Giải trí để giải tỏa stress"@vi ;
    rdfs:comment "Hoạt động giải trí đóng vai trò van xả, giúp cá nhân thoát khỏi áp lực công việc và căng thẳng tích tụ trong cuộc sống hàng ngày."@vi ;
    rdfs:subClassOf persona:chuc_nang_giai_tri_doi_voi_ca_nhan .

persona:giai_tri_de_ket_noi_xa_hoi a owl:Class ;
    rdfs:label "Giải trí để kết nối xã hội"@vi ;
    rdfs:comment "Hoạt động giải trí đóng vai trò cầu nối, giúp cá nhân duy trì và mở rộng các mối quan hệ xã hội trong cộng đồng.\\nVí dụ thực tế: nhảy truyền thống để giao lưu, cùng cháu nội chơi cờ vua, đến công viên với nhóm khiêu vũ cuối tuần."@vi ;
    rdfs:subClassOf persona:chuc_nang_giai_tri_doi_voi_ca_nhan .

persona:giai_tri_don_thuan_tim_niem_vui a owl:Class ;
    rdfs:label "Giải trí đơn thuần tìm niềm vui"@vi ;
    rdfs:comment "Hoạt động giải trí không gắn với mục tiêu xã hội hay ý nghĩa lớn hơn — chỉ đơn giản vì bản thân hoạt động đó mang lại niềm vui và sự thoải mái."@vi ;
    rdfs:subClassOf persona:chuc_nang_giai_tri_doi_voi_ca_nhan .

persona:giam_stress_bang_the_chat a owl:Class ;
    rdfs:label "Giảm stress bằng thể chất"@vi ;
    rdfs:comment "Cơ chế sử dụng vận động như công cụ giải phóng căng thẳng tâm lý tích tụ.\\nVí dụ thực tế từ dữ liệu: đá bóng mạnh để xả stress, chạy bộ một mình để đầu óc trống rỗng."@vi ;
    rdfs:subClassOf persona:muc_dich_giai_tri_tinh_than .

persona:giam_thieu_nguy_co_chan_thuong a owl:Class ;
    rdfs:label "Giảm thiểu nguy cơ chấn thương"@vi ;
    rdfs:comment "Tác dụng bảo vệ cơ thể của việc thực hiện đúng kỹ thuật, tránh các tư thế xấu gây áp lực quá mức lên khớp và cơ.\\nVí dụ thực tế: kỹ thuật nâng tạ đúng tránh chấn thương lưng, kỹ thuật chạy đúng tránh đau đầu gối."@vi ;
    rdfs:subClassOf persona:ky_thuat_van_dong .

persona:giang_day_ky_nang_nau_an a owl:Class ;
    rdfs:label "Giảng dạy kỹ năng nấu ăn"@vi ;
    rdfs:comment "Chủ động dạy người khác cách nấu — từ hướng dẫn không chính thức cho cháu hay bạn bè đến tổ chức buổi học nấu ăn có cấu trúc."@vi ;
    rdfs:subClassOf persona:hanh_vi_chia_se_am_thuc .

persona:giao_luu_qua_the_thao a owl:Class ;
    rdfs:label "Giao lưu qua thể thao"@vi ;
    rdfs:comment "Việc sử dụng hoạt động thể chất như cầu nối để gặp gỡ và làm quen với người mới.\\nVí dụ thực tế từ dữ liệu: tham gia câu lạc bộ chạy bộ để quen thêm bạn, tham gia đội bóng khu phố để biết hàng xóm."@vi ;
    rdfs:subClassOf persona:muc_dich_ket_noi_xa_hoi .

persona:giong_dieu_than_mat_gan_gui a owl:Class ;
    rdfs:label "Giọng điệu thân mật gần gũi"@vi ;
    rdfs:comment "Phong cách viết tự sự dùng ngôn ngữ đời thường, tự nhiên và gần gũi — tạo cảm giác chân thật và dễ đồng cảm với người đọc."@vi ;
    rdfs:subClassOf persona:giong_dieu_va_phong_cach_viet_tu_su .

persona:giong_dieu_trang_trong a owl:Class ;
    rdfs:label "Giọng điệu trang trọng"@vi ;
    rdfs:comment "Phong cách viết tự sự dùng ngôn ngữ chính thức, lịch sự và có khoảng cách — phù hợp với môi trường chuyên nghiệp hoặc khi muốn tạo ấn tượng nghiêm túc."@vi ;
    rdfs:subClassOf persona:giong_dieu_va_phong_cach_viet_tu_su .

persona:hanh_dong_nghe_nghiep_cu_the a owl:Class ;
    rdfs:label "Hành động nghề nghiệp cụ thể"@vi ;
    rdfs:comment "Các thao tác đơn lẻ có thể quan sát được mà cá nhân thực hiện trong quá trình làm việc.\\nVí dụ thực tế từ dữ liệu: tiêm bắp, đo huyết áp, tưới rau, vận hành máy móc, ghi chép sổ sách tạp hóa."@vi ;
    rdfs:subClassOf persona:hoat_dong_nghe_nghiep .

persona:hanh_dong_tap_luyen_hang_ngay a owl:Class ;
    rdfs:label "Hành động tập luyện hàng ngày"@vi ;
    rdfs:comment "Các việc làm cụ thể và có thể thực hiện ngay trong từng buổi tập, là biểu hiện trực tiếp của kế hoạch tổng thể.\\nVí dụ thực tế từ dữ liệu: hôm nay chạy 20 phút, làm 3 hiệp plank 30 giây, bơi 20 vòng hồ 25m."@vi ;
    rdfs:subClassOf persona:ke_hoach_tap_luyen .

persona:hanh_phuc_la_gia_dinh_sum_vay a owl:Class ;
    rdfs:label "Hạnh phúc là gia đình sum vầy"@vi ;
    rdfs:comment "Định nghĩa hạnh phúc gắn với sự gần gũi, hòa thuận và đầy đủ của các thành viên gia đình — coi gia đình là nguồn ý nghĩa và sự thỏa mãn cao nhất."@vi ;
    rdfs:subClassOf persona:quan_niem_hanh_phuc .

persona:hanh_phuc_la_lam_dieu_minh_yeu a owl:Class ;
    rdfs:label "Hạnh phúc là làm điều mình yêu"@vi ;
    rdfs:comment "Định nghĩa hạnh phúc gắn với việc được theo đuổi đam mê và làm công việc có ý nghĩa với bản thân mỗi ngày — không bị ép buộc bởi áp lực ngoài ý muốn."@vi ;
    rdfs:subClassOf persona:quan_niem_hanh_phuc .

persona:hanh_phuc_la_suc_khoe_tot a owl:Class ;
    rdfs:label "Hạnh phúc là sức khỏe tốt"@vi ;
    rdfs:comment "Định nghĩa hạnh phúc gắn với thể trạng khỏe mạnh và tinh thần an ổn — coi sức khỏe là nền tảng của mọi thứ khác trong cuộc sống."@vi ;
    rdfs:subClassOf persona:quan_niem_hanh_phuc .

persona:hanh_phuc_la_tu_do_tai_chinh a owl:Class ;
    rdfs:label "Hạnh phúc là tự do tài chính"@vi ;
    rdfs:comment "Định nghĩa hạnh phúc gắn với việc đạt được mức tài chính đủ để không bị ràng buộc bởi tiền bạc và có thể lựa chọn cuộc sống theo ý muốn."@vi ;
    rdfs:subClassOf persona:quan_niem_hanh_phuc .

persona:hanh_trinh_nghe_nghiep_da_qua a owl:Class ;
    rdfs:label "Hành trình nghề nghiệp đã qua"@vi ;
    rdfs:comment "Các giai đoạn, vị trí và sự kiện quan trọng trong lịch sử làm việc của cá nhân tính đến thời điểm hiện tại.\\nVí dụ thực tế từ dữ liệu: từng làm xây dựng rồi chuyển sang quản lý tài chính cá nhân, đã nghỉ hưu nhưng vẫn tiếp tục dạy nghề truyền thống, nhiều năm kinh nghiệm quản lý tiệm tạp hóa từ thời còn nhỏ."@vi ;
    rdfs:subClassOf persona:su_nghiep_ca_nhan .

persona:he_thong_nang_luong_su_dung a owl:Class ;
    rdfs:label "Hệ thống năng lượng sử dụng"@vi ;
    rdfs:comment "Cơ chế sinh lý cung cấp năng lượng cho cơ thể trong quá trình vận động: hệ ưa khí cho bài tập bền lâu hay hệ yếm khí cho bài tập cường độ cao ngắn.\\nẢnh hưởng trực tiếp đến loại bài tập phù hợp với mục tiêu."@vi ;
    rdfs:subClassOf persona:he_thong_bai_tap .

persona:hoa_nhap_cong_dong_qua_the_thao a owl:Class ;
    rdfs:label "Hòa nhập cộng đồng qua thể thao"@vi ;
    rdfs:comment "Sử dụng hoạt động thể chất như phương tiện để trở thành thành viên được chấp nhận trong một cộng đồng địa phương.\\nVí dụ thực tế từ dữ liệu: tham gia đội thể thao khu phố để gắn bó với cộng đồng nơi ở mới."@vi ;
    rdfs:subClassOf persona:muc_dich_ket_noi_xa_hoi .

persona:hoat_dong_ho_tro_va_phoi_hop a owl:Class ;
    rdfs:label "Hoạt động hỗ trợ và phối hợp"@vi ;
    rdfs:comment "Các việc làm không trực tiếp tạo ra sản phẩm nhưng cần thiết để công việc cốt lõi diễn ra trơn tru.\\nVí dụ thực tế từ dữ liệu: báo cáo với bác sĩ, sắp xếp hàng trước khi mở cửa, liên lạc với nhà cung cấp nhập hàng."@vi ;
    rdfs:subClassOf persona:hoat_dong_nghe_nghiep .

persona:hoat_dong_tham_quan a owl:Class ;
    rdfs:label "Hoạt động tham quan"@vi ;
    rdfs:comment "Các hành động cụ thể nhằm khám phá và tiếp nhận giá trị tại điểm đến.\\nVí dụ thực tế: đi bộ khám phá phố cổ, thăm bảo tàng, tham quan di tích lịch sử, chụp ảnh cảnh quan."@vi ;
    rdfs:subClassOf persona:hoat_dong_hanh_trinh_hoac_lu_hanh .

persona:hoc_ky_nang_tu_nguoi_than_gia_dinh a owl:Class ;
    rdfs:label "Học kỹ năng từ người thân gia đình"@vi ;
    rdfs:comment "Tiếp thu kinh nghiệm thông qua quan sát và thực hành cùng cha mẹ, ông bà hoặc anh chị em trong bối cảnh sinh hoạt gia đình hàng ngày."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tich_luy_kinh_nghiem .

persona:hoc_nau_bang_thu_nghiem_ban_nang a owl:Class ;
    rdfs:label "Học nấu bằng thử nghiệm bản năng"@vi ;
    rdfs:comment "Tự khám phá và sáng tạo công thức thông qua thử nghiệm trực tiếp — không theo công thức cố định, phụ thuộc vào cảm nhận và phán đoán cá nhân."@vi ;
    rdfs:subClassOf persona:nguon_hoc_nau_an .

persona:hoc_nau_qua_lop_hoc_chinh_thuc a owl:Class ;
    rdfs:label "Học nấu qua lớp học chính thức"@vi ;
    rdfs:comment "Tiếp thu kỹ năng nấu ăn qua các khóa học có cấu trúc với giảng viên hướng dẫn — từ lớp nấu ăn cộng đồng đến trường đào tạo đầu bếp chuyên nghiệp."@vi ;
    rdfs:subClassOf persona:nguon_hoc_nau_an .

persona:hoc_nau_tu_gia_dinh_truyen_lai a owl:Class ;
    rdfs:label "Học nấu từ gia đình truyền lại"@vi ;
    rdfs:comment "Tiếp thu kỹ năng và công thức nấu ăn qua việc quan sát và thực hành cùng người thân trong gia đình — bà, mẹ hoặc các thế hệ trước."@vi ;
    rdfs:subClassOf persona:nguon_hoc_nau_an .

persona:hoc_nau_tu_video_truc_tuyen a owl:Class ;
    rdfs:label "Học nấu từ video trực tuyến"@vi ;
    rdfs:comment "Tự học nấu ăn qua nội dung video trên YouTube, TikTok hoặc các nền tảng ẩm thực trực tuyến mà không cần hướng dẫn trực tiếp."@vi ;
    rdfs:subClassOf persona:nguon_hoc_nau_an .

persona:hoc_ngon_ngu_phong_tuc_ban_dia a owl:Class ;
    rdfs:label "Học ngôn ngữ phong tục bản địa"@vi ;
    rdfs:comment "Chủ động tìm hiểu tiếng địa phương, nghi lễ và quy tắc ứng xử trước và trong chuyến đi để giao tiếp và hòa nhập tốt hơn."@vi ;
    rdfs:subClassOf persona:muc_do_hoa_nhap_van_hoa_ban_dia .

persona:ke_hoach_cung_nhac a owl:Class ;
    rdfs:label "Kế hoạch cứng nhắc"@vi ;
    rdfs:comment "Xu hướng giữ nguyên lịch trình đã định dù gặp thay đổi ngoài ý muốn — cần sự chắc chắn và trật tự để cảm thấy an tâm trong chuyến đi."@vi ;
    rdfs:subClassOf persona:muc_do_linh_hoat_ke_hoach .

persona:ke_hoach_hoc_chung_chi_chuyen_nganh a owl:Class ;
    rdfs:label "Kế hoạch học chứng chỉ chuyên ngành"@vi ;
    rdfs:comment "Dự định theo đuổi chứng chỉ hoặc bằng cấp bổ sung trong lĩnh vực nghề nghiệp hiện tại để nâng cao năng lực và cơ hội thăng tiến.\\nVí dụ thực tế: học chứng chỉ điều dưỡng tim mạch, chứng chỉ kỹ thuật nông nghiệp."@vi ;
    rdfs:subClassOf persona:ke_hoach_hoc_tap_nang_cao .

persona:ke_hoach_hoc_ky_nang_mem a owl:Class ;
    rdfs:label "Kế hoạch học kỹ năng mềm"@vi ;
    rdfs:comment "Dự định tham gia các khóa học phát triển năng lực cá nhân không gắn với chuyên môn kỹ thuật — nhiếp ảnh, ngoại ngữ, kỹ năng giao tiếp, quản lý thời gian."@vi ;
    rdfs:subClassOf persona:ke_hoach_hoc_tap_nang_cao .

persona:ke_hoach_hoc_len_cap_cao_hon a owl:Class ;
    rdfs:label "Kế hoạch học lên cấp cao hơn"@vi ;
    rdfs:comment "Dự định tiếp tục học tập ở bậc học cao hơn bằng cấp hiện có — từ trung cấp lên cao đẳng, từ cao đẳng lên đại học.\\nVí dụ thực tế: học lên cao đẳng kỹ thuật dù đang đi làm toàn thời gian."@vi ;
    rdfs:subClassOf persona:ke_hoach_hoc_tap_nang_cao .

persona:ke_hoach_hoc_quan_ly_va_lanh_dao a owl:Class ;
    rdfs:label "Kế hoạch học quản lý và lãnh đạo"@vi ;
    rdfs:comment "Dự định trang bị kiến thức và kỹ năng quản lý để đảm nhận vai trò lãnh đạo hoặc mở rộng quy mô kinh doanh.\\nVí dụ thực tế: tham gia khóa quản lý và tổ chức sự kiện, học kỹ năng quản lý nhân sự."@vi ;
    rdfs:subClassOf persona:ke_hoach_hoc_tap_nang_cao .

persona:ke_hoach_linh_hoat a owl:Class ;
    rdfs:label "Kế hoạch linh hoạt"@vi ;
    rdfs:comment "Sẵn sàng điều chỉnh lịch trình khi gặp thời tiết xấu, cơ hội mới hay gợi ý hay từ người địa phương — xem thay đổi là phần tự nhiên của chuyến đi."@vi ;
    rdfs:subClassOf persona:muc_do_linh_hoat_ke_hoach .

persona:kenh_giao_tiep_uu_tien_nghe_nghiep a owl:Class ;
    rdfs:label "Kênh giao tiếp ưu tiên nghề nghiệp"@vi ;
    rdfs:comment "Hình thức trao đổi thông tin mà cá nhân chủ động chọn trong bối cảnh công việc.\\nVí dụ thực tế từ dữ liệu: giao tiếp trực tiếp mặt đối mặt tại quầy bán hàng, qua điện thoại khi phối hợp nhóm thi công, qua sổ giao ban trong bệnh viện."@vi ;
    rdfs:subClassOf persona:phong_cach_giao_tiep_nghe_nghiep .

persona:ket_cau_thuc_pham_ua_thich a owl:Class ;
    rdfs:label "Kết cấu thực phẩm ưa thích"@vi ;
    rdfs:comment "Thiên hướng của cá nhân đối với cấu trúc vật lý của thực phẩm khi ăn.\\nVí dụ thực tế: thích đồ giòn rau ráu, ưa thức ăn mềm dễ nhai, chuộng kết cấu dai sần hoặc không thích đồ nhão bột."@vi ;
    rdfs:subClassOf persona:khau_vi_ca_nhan .

persona:ket_hop_linh_hoat_tu_tuc_va_tour a owl:Class ;
    rdfs:label "Kết hợp linh hoạt tự túc và tour"@vi ;
    rdfs:comment "Kết hợp tự đặt một số hạng mục và dùng tour cho phần còn lại — cân bằng giữa sự chủ động và tiện lợi."@vi ;
    rdfs:subClassOf persona:hinh_thuc_to_chuc_hanh_trinh .

persona:ket_qua_dau_ra_cong_viec a owl:Class ;
    rdfs:label "Kết quả đầu ra công việc"@vi ;
    rdfs:comment "Sản phẩm, dịch vụ hoặc thành quả cụ thể được tạo ra khi cá nhân hoàn thành một tác vụ nghề nghiệp.\\nVí dụ thực tế từ dữ liệu: bệnh nhân được chăm sóc đúng phác đồ, công trình lắp đặt đúng tiêu chuẩn, mẻ bánh đa cua thành phẩm."@vi ;
    rdfs:subClassOf persona:vai_tro_quyet_dinh_trong_cong_viec .

persona:kha_nang_ap_dung_quy_trinh_ky_thuat a owl:Class ;
    rdfs:label "Khả năng áp dụng quy trình kỹ thuật"@vi ;
    rdfs:comment "Mức độ cá nhân có thể triển khai đúng các bước kỹ thuật được quy định trong một quy trình chuyên ngành.\\nVí dụ thực tế từ dữ liệu: thực hiện đúng quy trình chăm sóc hậu phẫu, lắp đặt hệ thống điện theo tiêu chuẩn kỹ thuật."@vi ;
    rdfs:subClassOf persona:nang_luc_ky_thuat .

persona:kha_nang_ca_nhan a owl:Class ;
    rdfs:label "Khả năng cá nhân"@vi ;
    rdfs:comment "Năng lực tự nhiên hoặc được rèn luyện mà cá nhân có thể huy động để thực hiện một loại công việc nhất định.\\nKhác với kỹ năng ở chỗ khả năng mang tính tiềm năng, còn kỹ năng là đã được thực hành thành thục."@vi ;
    rdfs:subClassOf persona:tap_hop_nang_luc .

persona:kha_nang_dieu_chinh_phong_cach_giao_tiep a owl:Class ;
    rdfs:label "Khả năng điều chỉnh phong cách giao tiếp"@vi ;
    rdfs:comment "Mức độ cá nhân thay đổi cách truyền đạt và lắng nghe cho phù hợp với từng đối tượng và mục đích khác nhau.\\nVí dụ thực tế từ dữ liệu: giải thích đơn giản cho bệnh nhân cao tuổi, dùng ngôn ngữ kỹ thuật với đồng nghiệp, thuyết phục bằng số liệu với cấp trên."@vi ;
    rdfs:subClassOf persona:phong_cach_giao_tiep_nghe_nghiep .

persona:kha_nang_du_doan_hanh_vi a owl:Class ;
    rdfs:label "Khả năng dự đoán hành vi"@vi ;
    rdfs:comment "Mức độ mà đồng nghiệp hoặc cấp trên có thể biết trước cách cá nhân sẽ phản ứng hoặc hành động trong một tình huống nhất định.\\nLà nền tảng của niềm tin trong môi trường làm việc nhóm."@vi ;
    rdfs:subClassOf persona:tinh_nhat_quan_hanh_vi .

persona:kha_nang_duy_tri_nhat_quan a owl:Class ;
    rdfs:label "Khả năng duy trì nhất quán"@vi ;
    rdfs:comment "Mức độ cá nhân giữ được chất lượng và tốc độ ổn định qua nhiều lần thực hiện cùng một nhiệm vụ theo thời gian.\\nVí dụ thực tế từ dữ liệu: mỗi mẻ bánh đều đạt chất lượng như nhau, mỗi ca trực đều tuân thủ đúng quy trình."@vi ;
    rdfs:subClassOf persona:hieu_qua_thuc_hien_cong_viec .

persona:kha_nang_thich_ung_tinh_huong_phat_sinh a owl:Class ;
    rdfs:label "Khả năng thích ứng tình huống phát sinh"@vi ;
    rdfs:comment "Mức độ cá nhân xử lý hiệu quả các tình huống bất ngờ, bất thường không có trong quy trình chuẩn hoặc lý thuyết đã học.\\nVí dụ thực tế từ dữ liệu: xử lý ca bệnh có biến chứng ngoài dự kiến, ứng phó khi thiếu nguyên liệu trong quá trình làm bánh."@vi ;
    rdfs:subClassOf persona:ky_nang_thuc_hanh_nghe_nghiep .

persona:kha_nang_van_hanh_cong_cu a owl:Class ;
    rdfs:label "Khả năng vận hành công cụ"@vi ;
    rdfs:comment "Mức độ thành thục trong việc sử dụng các thiết bị, phần mềm hoặc công cụ chuyên ngành để hoàn thành nhiệm vụ.\\nVí dụ thực tế từ dữ liệu: vận hành phần mềm thiết kế 3D, sử dụng thiết bị đo huyết áp và điện tâm đồ, dùng máy tính xử lý hành chính."@vi ;
    rdfs:subClassOf persona:nang_luc_ky_thuat .

persona:khach_hang_muc_tieu a owl:Class ;
    rdfs:label "Khách hàng mục tiêu"@vi ;
    rdfs:comment "Nhóm người hoặc tổ chức cụ thể mà cá nhân hướng đến phục vụ trong hoạt động nghề nghiệp.\\nVí dụ thực tế từ dữ liệu: bệnh nhân tại bệnh viện tư, người dân trong khu phố mua tạp hóa, lớp trẻ học làm nem cua bể."@vi ;
    rdfs:subClassOf persona:phan_khuc_thi_truong .

persona:kham_pha_co_dinh_huong_ke_hoach a owl:Class ;
    rdfs:label "Khám phá có định hướng kế hoạch"@vi ;
    rdfs:comment "Xu hướng bám sát lịch trình đã chuẩn bị, ít rời bỏ kế hoạch dù gặp cơ hội ngẫu nhiên — cần sự chắc chắn để cảm thấy an tâm."@vi ;
    rdfs:subClassOf persona:muc_do_kham_pha_tu_phat .

persona:kham_pha_tu_phat_linh_hoat a owl:Class ;
    rdfs:label "Khám phá tự phát linh hoạt"@vi ;
    rdfs:comment "Xu hướng sẵn sàng rời bỏ lịch trình để thử những điều ngoài kế hoạch khi gặp gợi ý hay hoặc cảm hứng nhất thời trong chuyến đi."@vi ;
    rdfs:subClassOf persona:muc_do_kham_pha_tu_phat .

persona:khau_phan_an_uong a owl:Class ;
    rdfs:label "Khẩu phần ăn uống"@vi ;
    rdfs:comment "Lượng thức ăn và calo được kiểm soát trong mỗi bữa nhằm đạt mục tiêu cân nặng và hình thể.\\nVí dụ thực tế từ dữ liệu: ăn vừa đủ no không ăn thừa, đếm calo khi cần giảm cân, tăng khẩu phần khi tập tăng cơ."@vi ;
    rdfs:subClassOf persona:thoi_quen_dinh_duong .

persona:kho_tang_cong_thuc_va_mon_an_biet_nau a owl:Class ;
    rdfs:label "Kho tàng công thức và món ăn biết nấu"@vi ;
    rdfs:comment "Tập hợp các công thức và món ăn cụ thể mà cá nhân đã nắm vững và có thể thực hiện một cách tự tin.\\nVí dụ thực tế từ dữ liệu: biết làm bánh cuốn, nấu phở chuẩn vị Hà Nội, nấu hủ tiếu, làm bánh mì."@vi ;
    rdfs:subClassOf persona:nang_luc_nau_nuong .

persona:khoi_goi_cam_xuc_qua_am_thanh a owl:Class ;
    rdfs:label "Khơi gợi cảm xúc qua âm thanh"@vi ;
    persona:tuong_quan persona:dong_luc_sang_tao_nghe_thuat ;
    rdfs:comment "Các đặc tính âm nhạc hoặc âm thanh kích hoạt phản ứng cảm xúc của người nghe.\\nVí dụ: giai điệu buồn gợi nỗi nhớ, nhịp điệu hối hả tạo phấn khích, âm sắc nhạc cụ đặc trưng gợi ký ức."@vi ;
    rdfs:subClassOf persona:co_che_khoi_goi_cam_xuc .

persona:khoi_goi_cam_xuc_qua_hinh_anh a owl:Class ;
    rdfs:label "Khơi gợi cảm xúc qua hình ảnh"@vi ;
    rdfs:comment "Các đặc tính thị giác của tác phẩm tạo ra phản ứng cảm xúc.\\nVí dụ: màu sắc tương phản tạo căng thẳng, bố cục bất cân xứng gây bất an, ánh sáng ấm áp gợi cảm giác an toàn."@vi ;
    rdfs:subClassOf persona:co_che_khoi_goi_cam_xuc .

persona:khoi_goi_cam_xuc_qua_tu_su a owl:Class ;
    rdfs:label "Khơi gợi cảm xúc qua tự sự"@vi ;
    rdfs:comment "Các yếu tố kể chuyện trong tác phẩm tạo ra sự đồng cảm hoặc xúc động.\\nVí dụ: tình tiết chạm đến ký ức cá nhân, nhân vật phản chiếu cuộc đời người xem, cái kết bất ngờ làm thay đổi cách hiểu toàn bộ câu chuyện."@vi ;
    rdfs:subClassOf persona:co_che_khoi_goi_cam_xuc .

persona:khong_gian_van_dong_uu_tien a owl:Class ;
    rdfs:label "Không gian vận động ưu tiên"@vi ;
    rdfs:comment "Thiên hướng của cá nhân về môi trường vật lý khi thực hiện hoạt động thể chất: trong nhà hay ngoài trời."@vi ;
    rdfs:subClassOf persona:thien_huong_loai_hinh_van_dong .

persona:kiem_soat_ngoai_hinh a owl:Class ;
    rdfs:label "Kiểm soát ngoại hình"@vi ;
    rdfs:comment "Mong muốn duy trì hoặc thay đổi vẻ bề ngoài tổng thể của cơ thể thông qua vận động.\\nPhản ánh chuẩn hình thể mà cá nhân tự đặt ra cho bản thân."@vi ;
    rdfs:subClassOf persona:muc_dich_giu_voc_dang .

persona:kien_thuc_trong_tap_hop_nang_luc a owl:Class ;
    rdfs:label "Kiến thức trong tập hợp năng lực"@vi ;
    rdfs:comment "Phần tri thức lý thuyết và hiểu biết nền tảng đóng góp vào bộ năng lực tổng thể của cá nhân.\\nHỗ trợ các kỹ năng thực hành bằng cách cung cấp khung lý giải và định hướng khi gặp tình huống mới."@vi ;
    rdfs:subClassOf persona:tap_hop_nang_luc .

persona:kieu_trai_nghiem_am_thuc a owl:Class ;
    rdfs:label "Kiểu trải nghiệm ẩm thực"@vi ;
    rdfs:comment "Ưu tiên khám phá văn hóa ẩm thực địa phương là hoạt động trọng tâm của chuyến đi.\\nVí dụ thực tế: tour chợ, lớp nấu ăn, tìm quán đặc sản ít người biết."@vi ;
    rdfs:subClassOf persona:kieu_trai_nghiem_uu_tien .

persona:kieu_trai_nghiem_kham_pha_mao_hiem a owl:Class ;
    rdfs:label "Kiểu trải nghiệm khám phá mạo hiểm"@vi ;
    rdfs:comment "Ưu tiên các hoạt động có yếu tố thách thức thể chất hoặc tinh thần — leo núi, lặn biển, đi rừng, vượt thác."@vi ;
    rdfs:subClassOf persona:kieu_trai_nghiem_uu_tien .

persona:kieu_trai_nghiem_nghi_duong a owl:Class ;
    rdfs:label "Kiểu trải nghiệm nghỉ dưỡng"@vi ;
    rdfs:comment "Ưu tiên nghỉ ngơi và tái tạo năng lượng — nằm biển, spa, ngủ đủ giấc — thay vì lịch trình tham quan dày đặc."@vi ;
    rdfs:subClassOf persona:kieu_trai_nghiem_uu_tien .

persona:kieu_trai_nghiem_van_hoa_lich_su a owl:Class ;
    rdfs:label "Kiểu trải nghiệm văn hóa lịch sử"@vi ;
    rdfs:comment "Ưu tiên tìm hiểu di sản và bản sắc văn hóa tại điểm đến — thăm bảo tàng, làng nghề, di tích và sinh hoạt cộng đồng bản địa."@vi ;
    rdfs:subClassOf persona:kieu_trai_nghiem_uu_tien .

persona:kinh_nghiem_tich_luy_trong_xu_ly a owl:Class ;
    rdfs:label "Kinh nghiệm tích lũy trong xử lý"@vi ;
    rdfs:comment "Bộ nhớ về các tình huống đã gặp và cách giải quyết thành công trong quá khứ, được huy động như nguồn lực chính khi gặp vấn đề tương tự.\\nVí dụ thực tế từ dữ liệu: thợ lành nghề nhìn máy là biết hỏng chỗ nào dù không có bản vẽ, người bán tạp hóa biết hàng nào sắp khan hiếm qua kinh nghiệm nhiều năm."@vi ;
    rdfs:subClassOf persona:phuong_phap_xu_ly_van_de .

persona:ky_nang_quan_ly_ban_than a owl:Class ;
    rdfs:label "Kỹ năng quản lý bản thân"@vi ;
    rdfs:comment "Khả năng tự tổ chức, kiểm soát thời gian và duy trì kỷ luật cá nhân trong công việc lẫn sinh hoạt.\\nVí dụ thực tế từ dữ liệu: quản lý thời gian cá nhân, làm việc theo quy trình, sắp xếp gọn gàng."@vi ;
    rdfs:subClassOf persona:ky_nang_ca_nhan .

persona:ky_nang_quan_ly_va_to_chuc a owl:Class ;
    rdfs:label "Kỹ năng quản lý và tổ chức"@vi ;
    persona:cung_co persona:dieu_kien_to_chuc ;
    persona:dinh_hinh persona:hinh_thuc_tham_gia_the_thao ;
    rdfs:comment "Khả năng điều phối nguồn lực, con người và quy trình để đạt mục tiêu trong phạm vi công việc hoặc cộng đồng.\\nVí dụ thực tế từ dữ liệu: quản lý hàng tồn kho tiệm tạp hóa, tính toán lợi nhuận, tổ chức sự kiện cộng đồng, quản lý nhóm thi công."@vi ;
    rdfs:subClassOf persona:ky_nang_chuyen_mon_cot_loi .

persona:ky_thuat_dac_thu_mon_the_thao a owl:Class ;
    rdfs:label "Kỹ thuật đặc thù môn thể thao"@vi ;
    rdfs:comment "Các thao tác vận động có quy tắc và chuẩn mực riêng chỉ xuất hiện trong một môn thể thao cụ thể.\\nVí dụ thực tế từ dữ liệu: kỹ thuật smash cầu lông, kỹ thuật lộn vòng khi bơi sải, kỹ thuật sút phạt góc trong bóng đá."@vi ;
    rdfs:subClassOf persona:ky_nang_the_thao .

persona:ky_thuat_nau_co_ban a owl:Class ;
    rdfs:label "Kỹ thuật nấu cơ bản"@vi ;
    rdfs:comment "Mức thành thạo các thao tác chế biến đơn giản nhất — luộc, chiên, xào, kho đơn giản — đủ để chuẩn bị bữa ăn hàng ngày."@vi ;
    rdfs:subClassOf persona:trinh_do_ky_thuat_nau_an .

persona:ky_thuat_nau_nang_cao a owl:Class ;
    rdfs:label "Kỹ thuật nấu nâng cao"@vi ;
    rdfs:comment "Mức thành thạo các kỹ thuật chuyên sâu như ẩm thực Âu, phân tử ẩm thực, tạo hình tinh xảo hoặc chế biến nguyên liệu đặc biệt đòi hỏi đào tạo bài bản."@vi ;
    rdfs:subClassOf persona:trinh_do_ky_thuat_nau_an .

persona:ky_thuat_nau_trung_cap a owl:Class ;
    rdfs:label "Kỹ thuật nấu trung cấp"@vi ;
    rdfs:comment "Mức thành thạo các kỹ thuật chế biến phức tạp hơn — hầm, kho lâu, làm bánh, phối hương liệu — tạo ra món ăn có chiều sâu hương vị."@vi ;
    rdfs:subClassOf persona:trinh_do_ky_thuat_nau_an .

persona:lam_viec_thuc_te_lau_nam a owl:Class ;
    rdfs:label "Làm việc thực tế lâu năm"@vi ;
    rdfs:comment "Tích lũy kinh nghiệm qua quá trình trực tiếp tham gia công việc trong thời gian dài — kinh nghiệm hình thành từ thực tế cọ xát, không qua lớp học chính thức."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tich_luy_kinh_nghiem .

persona:le_hoi_va_su_kien_van_hoa_gan_bo a owl:Class ;
    rdfs:label "Lễ hội và sự kiện văn hóa gắn bó"@vi ;
    persona:dinh_hinh persona:nguon_goc_hinh_thanh_so_thich ;
    persona:tac_dong persona:gu_trai_nghiem_van_hoa_am_thuc ;
    rdfs:comment "Các dịp lễ hội, sự kiện cộng đồng hoặc nghi lễ theo mùa mà cá nhân tham gia thường xuyên và gắn bó cảm xúc sâu sắc.\\nVí dụ thực tế từ dữ liệu: lễ hội hoa phượng đỏ Hải Phòng, hội hoa đăng sông Cấm, lễ hội Gióng Sóc Sơn, lễ hội áo dài, lễ hội đâm trâu Cần Thơ."@vi ;
    rdfs:subClassOf persona:nguon_goc_hoac_nen_tang_van_hoa .

persona:lich_trinh_ca_nhan_hang_ngay a owl:Class ;
    rdfs:label "Lịch trình cá nhân hàng ngày"@vi ;
    rdfs:comment "Thời gian biểu mà cá nhân duy trì để thực hiện các nhiệm vụ nghề nghiệp theo thứ tự cố định.\\nVí dụ thực tế từ dữ liệu: ra đồng lúc sáng sớm trước khi nắng, mở tiệm đúng giờ chợ, đến bệnh viện theo ca xoay."@vi ;
    rdfs:subClassOf persona:thoi_quen_lam_viec .

persona:lo_trinh_phat_trien_the_chat a owl:Class ;
    rdfs:label "Lộ trình phát triển thể chất"@vi ;
    rdfs:comment "Chuỗi các giai đoạn và mốc tiến bộ được sắp xếp có thứ tự dẫn từ trạng thái hiện tại đến mục tiêu thể thao.\\nLà bản đồ chỉ đường để cá nhân biết mình đang ở đâu và bước tiếp theo là gì."@vi ;
    rdfs:subClassOf persona:ke_hoach_tap_luyen .

persona:loai_hinh_khong_gian_lam_viec a owl:Class ;
    rdfs:label "Loại hình không gian làm việc"@vi ;
    rdfs:comment "Phân loại môi trường vật lý nơi công việc diễn ra theo tính chất của không gian.\\nVí dụ thực tế từ dữ liệu: trong nhà có điều hòa (văn phòng, bệnh viện), ngoài trời (công trình, ruộng đồng), tại nhà kiêm nơi kinh doanh (tiệm tạp hóa)."@vi ;
    rdfs:subClassOf persona:khong_gian_vat_ly_lam_viec .

persona:loai_thuc_pham_tieu_thu a owl:Class ;
    rdfs:label "Loại thực phẩm tiêu thụ"@vi ;
    rdfs:comment "Các nhóm và loại thức ăn cụ thể mà cá nhân thường xuyên đưa vào chế độ ăn nhằm hỗ trợ mục tiêu vóc dáng.\\nVí dụ thực tế từ dữ liệu: ăn nhiều rau xanh và cá, hạn chế đồ chiên rán và đường, bổ sung protein sau buổi tập."@vi ;
    rdfs:subClassOf persona:thoi_quen_dinh_duong .

persona:luu_tru_homestay_gan_gui_dia_phuong a owl:Class ;
    rdfs:label "Lưu trú homestay gần gũi địa phương"@vi ;
    rdfs:comment "Thiên hướng chọn ở nhà dân hoặc homestay để có trải nghiệm gần gũi với lối sống và con người bản địa hơn là môi trường khách sạn tách biệt."@vi ;
    rdfs:subClassOf persona:so_thich_loai_hinh_luu_tru .

persona:luu_tru_hostel_tiet_kiem_giao_luu a owl:Class ;
    rdfs:label "Lưu trú hostel tiết kiệm và giao lưu"@vi ;
    rdfs:comment "Thiên hướng chọn hostel để tiết kiệm chi phí và có cơ hội gặp gỡ, giao lưu với những khách du lịch khác đến từ nhiều nơi."@vi ;
    rdfs:subClassOf persona:so_thich_loai_hinh_luu_tru .

persona:luu_tru_khach_san_tien_nghi a owl:Class ;
    rdfs:label "Lưu trú khách sạn tiện nghi"@vi ;
    rdfs:comment "Thiên hướng chọn khách sạn với tiện ích đầy đủ, dịch vụ chuyên nghiệp và mức độ thoải mái cao khi đi du lịch."@vi ;
    rdfs:subClassOf persona:so_thich_loai_hinh_luu_tru .

persona:luu_tru_va_sinh_hoat_cung_nguoi_ban_dia a owl:Class ;
    rdfs:label "Lưu trú và sinh hoạt cùng người bản địa"@vi ;
    rdfs:comment "Chủ động chọn ở nhà dân và tham gia sinh hoạt thường ngày của người địa phương thay vì tách biệt trong môi trường du lịch."@vi ;
    rdfs:subClassOf persona:muc_do_hoa_nhap_van_hoa_ban_dia .

persona:mang_hep_va_cu_the a owl:Class ;
    rdfs:label "Mảng hẹp và cụ thể"@vi ;
    rdfs:comment "Lĩnh vực con được xác định rõ ràng và có phạm vi giới hạn trong một ngành nghề rộng hơn mà cá nhân lựa chọn làm trọng tâm.\\nVí dụ thực tế từ dữ liệu: trong điều dưỡng chuyên mảng tim mạch, trong kỹ thuật cơ khí chuyên thiết bị nông nghiệp, trong ẩm thực chuyên món truyền thống Hải Phòng."@vi ;
    rdfs:subClassOf persona:pham_vi_chuyen_mon_hoa .

persona:mang_luoi_quan_he_nghe_nghiep a owl:Class ;
    rdfs:label "Mạng lưới quan hệ nghề nghiệp"@vi ;
    rdfs:comment "Tập hợp các mối kết nối với đồng nghiệp, đối tác, khách hàng và người cố vấn được xây dựng trong quá trình làm việc.\\nVí dụ thực tế từ dữ liệu: mạng lưới bạn hàng của tiệm tạp hóa, đồng nghiệp bệnh viện giới thiệu cơ hội học thêm."@vi ;
    rdfs:subClassOf persona:phat_trien_su_nghiep .

persona:marital_status a owl:Class ;
    rdfs:label "marital_status"@vi ;
    rdfs:comment "Tình trạng mối quan hệ: Độc thân, Đã kết hôn, Góa, Ly thân"@vi .

persona:mo_hinh_quan_tri a owl:Class ;
    rdfs:label "Mô hình quản trị"@vi ;
    rdfs:comment "Cách thức tổ chức được điều hành và cấu trúc quyền lực được phân bổ trong tổ chức.\\nVí dụ thực tế từ dữ liệu: chủ hộ tự quyết toàn bộ trong tiệm tạp hóa, hệ thống phân cấp rõ ràng trong bệnh viện với bác sĩ trưởng và điều dưỡng trưởng."@vi ;
    rdfs:subClassOf persona:dieu_kien_to_chuc .

persona:moi_truong_xa_hoi_tap_luyen a owl:Class ;
    rdfs:label "Môi trường xã hội tập luyện"@vi ;
    rdfs:comment "Tính chất các mối quan hệ xã hội xung quanh hoạt động tập luyện của cá nhân.\\nVí dụ thực tế từ dữ liệu: tập cùng nhóm bạn thân, trong đội thể thao khu phố, hay hoàn toàn một mình không giao lưu."@vi ;
    rdfs:subClassOf persona:boi_canh_tham_gia_the_thao .

persona:mon_an_yeu_thich a owl:Class ;
    rdfs:label "Món ăn yêu thích"@vi ;
    rdfs:comment "Các món ăn cụ thể mang lại sự thỏa mãn cao nhất cho cá nhân và được chủ động tìm kiếm hoặc nấu thường xuyên.\\nVí dụ thực tế từ dữ liệu: hủ tiếu, bánh mì, cơm tấm, phở, bánh cuốn."@vi ;
    rdfs:subClassOf persona:so_thich_an_uong_ca_nhan .

persona:mong_muon_dat_thanh_tich a owl:Class ;
    rdfs:label "Mong muốn đạt thành tích"@vi ;
    rdfs:comment "Khao khát giành chiến thắng hoặc đạt kết quả cụ thể có thể đo lường được trong thi đấu thể thao.\\nVí dụ thực tế từ dữ liệu: muốn vào vòng chung kết giải phong trào, muốn cải thiện thứ hạng trong đội."@vi ;
    rdfs:subClassOf persona:muc_dich_thi_dau_canh_tranh .

persona:muc_dich_tap_luyen_hay_thi_dau a owl:Class ;
    rdfs:label "Mục đích tập luyện hay thi đấu"@vi ;
    rdfs:comment "Lý do chính mà cá nhân chọn một môn thể thao cụ thể: để rèn luyện sức khỏe thường ngày hay để tranh tài có kết quả thắng thua.\\nXác định mức độ nghiêm túc và đầu tư vào môn đó."@vi ;
    rdfs:subClassOf persona:mon_the_thao_yeu_thich .

persona:muc_do_anh_huong_den_ket_qua a owl:Class ;
    rdfs:label "Mức độ ảnh hưởng đến kết quả"@vi ;
    rdfs:comment "Tầm quan trọng của một kỹ năng hoặc năng lực cụ thể đối với chất lượng và sự thành công của đầu ra công việc.\\nPhân biệt kỹ năng có ảnh hưởng lớn (thiếu là hỏng) và kỹ năng bổ trợ (thiếu vẫn làm được nhưng kém hơn)."@vi ;
    rdfs:subClassOf persona:vai_tro_quyet_dinh_trong_cong_viec .

persona:muc_do_deu_dan_duy_tri a owl:Class ;
    rdfs:label "Mức độ đều đặn duy trì"@vi ;
    rdfs:comment "Tính ổn định theo thời gian của thói quen vận động, phân biệt giữa người tập đều đặn không ngắt quãng và người tập theo đợt rồi bỏ.\\nVí dụ thực tế từ dữ liệu: duy trì đi bộ sáng đều đặn cả năm với chỉ tập mạnh trước dịp hè rồi bỏ."@vi ;
    rdfs:subClassOf persona:tan_suat_tham_gia_the_thao .

persona:muc_do_kien_tri_duy_tri_van_dong a owl:Class ;
    rdfs:label "Mức độ kiên trì duy trì vận động"@vi ;
    rdfs:comment "Khả năng duy trì thói quen vận động ổn định qua thời gian dù gặp trở ngại như thời tiết xấu, bận rộn hay mệt mỏi.\\nPhản ánh sức mạnh của động lực nội tại với hoạt động thể chất."@vi ;
    rdfs:subClassOf persona:muc_do_hung_thu_van_dong .

persona:muc_do_lam_chu_ky_thuat a owl:Class ;
    rdfs:label "Mức độ làm chủ kỹ thuật"@vi ;
    rdfs:comment "Trình độ mà cá nhân không chỉ thực hiện được mà còn hiểu sâu, có thể điều chỉnh và xử lý ngoại lệ trong kỹ thuật đó.\\nPhân biệt giữa người làm được theo hướng dẫn và người thực sự làm chủ kỹ thuật có thể dạy lại cho người khác."@vi ;
    rdfs:subClassOf persona:nang_luc_ky_thuat .

persona:muc_do_on_dinh_hanh_vi a owl:Class ;
    rdfs:label "Mức độ ổn định hành vi"@vi ;
    rdfs:comment "Tần suất mà cá nhân hành xử theo cùng một cách nhất quán bất kể hoàn cảnh bên ngoài thay đổi.\\nPhân biệt người luôn đúng giờ và đúng quy trình dù điều kiện thay đổi với người dễ bị tác động bởi tâm trạng hay áp lực."@vi ;
    rdfs:subClassOf persona:tinh_nhat_quan_hanh_vi .

persona:muc_do_tap_trung_chuyen_mon a owl:Class ;
    rdfs:label "Mức độ tập trung chuyên môn"@vi ;
    rdfs:comment "Cường độ mà cá nhân dồn năng lực và thời gian vào một lĩnh vực hẹp thay vì dàn trải sang nhiều hướng.\\nĐo lường bằng tỷ lệ thời gian và công sức dành cho mảng chuyên sâu so với toàn bộ hoạt động nghề nghiệp."@vi ;
    rdfs:subClassOf persona:pham_vi_chuyen_mon_hoa .

persona:muc_do_tu_chu_trong_cong_viec a owl:Class ;
    rdfs:label "Mức độ tự chủ trong công việc"@vi ;
    rdfs:comment "Phạm vi quyết định mà cá nhân được trao hoặc tự tạo trong việc thực hiện nhiệm vụ hàng ngày mà không cần xin phép.\\nVí dụ thực tế từ dữ liệu: chủ tiệm tạp hóa tự quyết mọi thứ, điều dưỡng phải theo y lệnh bác sĩ, kỹ sư tự thiết kế nhưng cần phê duyệt."@vi ;
    rdfs:subClassOf persona:dieu_kien_to_chuc .

persona:muc_tieu_cai_thien_hinh_the a owl:Class ;
    rdfs:label "Mục tiêu cải thiện hình thể"@vi ;
    rdfs:comment "Vận động nhằm thay đổi cơ thể theo hướng gần hơn với tiêu chuẩn thẩm mỹ cá nhân mong muốn.\\nVí dụ thực tế từ dữ liệu: tập bụng để có cơ bụng phẳng, tập tay để có cánh tay săn chắc."@vi ;
    rdfs:subClassOf persona:hoat_dong_the_chat_giu_voc_dang .

persona:muc_tieu_cong_tac_ket_hop_du_lich a owl:Class ;
    rdfs:label "Mục tiêu công tác kết hợp du lịch"@vi ;
    rdfs:comment "Chuyến đi xuất phát từ lý do công việc nhưng tranh thủ thêm thời gian khám phá điểm đến ngoài giờ làm."@vi ;
    rdfs:subClassOf persona:muc_tieu_chuyen_di .

persona:muc_tieu_cong_viec_de_ra a owl:Class ;
    rdfs:label "Mục tiêu công việc đề ra"@vi ;
    rdfs:comment "Đích đến cụ thể và có thể đo lường mà cá nhân hoặc tổ chức xác định cần đạt được qua hoạt động nghề nghiệp.\\nVí dụ thực tế từ dữ liệu: hoàn thành ca trực không để xảy ra sự cố, bán hết hàng nhập trong tuần, giao công trình đúng tiến độ."@vi ;
    rdfs:subClassOf persona:hieu_qua_thuc_hien_cong_viec .

persona:muc_tieu_duy_tri_hinh_the a owl:Class ;
    rdfs:label "Mục tiêu duy trì hình thể"@vi ;
    rdfs:comment "Vận động nhằm giữ nguyên vóc dáng hiện tại mà không để thay đổi theo hướng không mong muốn.\\nVí dụ thực tế từ dữ liệu: tập cardio nhẹ đều đặn để không tăng cân dù ăn uống bình thường."@vi ;
    rdfs:subClassOf persona:hoat_dong_the_chat_giu_voc_dang .

persona:muc_tieu_giam_tang_hay_duy_tri_can a owl:Class ;
    rdfs:label "Mục tiêu giảm, tăng hay duy trì cân"@vi ;
    rdfs:comment "Hướng điều chỉnh cân nặng mà cá nhân đặt ra làm đích đến của quá trình kiểm soát.\\nVí dụ thực tế từ dữ liệu: giảm 3kg trước hè, tăng 2kg cơ sau 3 tháng tập tạ, duy trì cân nặng hiện tại ổn định."@vi ;
    rdfs:subClassOf persona:kiem_soat_can_nang .

persona:muc_tieu_keo_dai_tuoi_tho a owl:Class ;
    rdfs:label "Mục tiêu kéo dài tuổi thọ"@vi ;
    rdfs:comment "Vận động với mong muốn sống lâu hơn và duy trì chất lượng sức khỏe ở tuổi già.\\nVí dụ thực tế từ dữ liệu: người lớn tuổi đi bộ đều đặn để sống khỏe đến già, tập nhẹ nhàng để không phụ thuộc vào thuốc."@vi ;
    rdfs:subClassOf persona:muc_dich_suc_khoe .

persona:muc_tieu_kham_pha_dia_danh_uoc_mo a owl:Class ;
    rdfs:label "Mục tiêu khám phá địa danh ước mơ"@vi ;
    rdfs:comment "Chuyến đi thực hiện mong muốn đến một nơi đã nằm trong danh sách ước mơ từ lâu — khám phá điều mới, tích lũy trải nghiệm chưa từng có."@vi ;
    rdfs:subClassOf persona:muc_tieu_chuyen_di .

persona:muc_tieu_ky_niem_dac_biet a owl:Class ;
    rdfs:label "Mục tiêu kỷ niệm đặc biệt"@vi ;
    rdfs:comment "Chuyến đi gắn với một dịp có ý nghĩa cá nhân — sinh nhật, kỷ niệm ngày cưới, tốt nghiệp hoặc cột mốc quan trọng trong cuộc sống."@vi ;
    rdfs:subClassOf persona:muc_tieu_chuyen_di .

persona:muc_tieu_nghi_ngoi_tai_tao a owl:Class ;
    rdfs:label "Mục tiêu nghỉ ngơi tái tạo"@vi ;
    rdfs:comment "Mục đích chính là phục hồi thể lực và tinh thần sau thời gian căng thẳng — không đặt lịch trình áp lực, ưu tiên nghỉ ngơi hoàn toàn."@vi ;
    rdfs:subClassOf persona:muc_tieu_chuyen_di .

persona:muc_tieu_suc_khoe_tim_mach a owl:Class ;
    rdfs:label "Mục tiêu sức khỏe tim mạch"@vi ;
    rdfs:comment "Vận động nhằm cải thiện hoặc duy trì chức năng hệ tuần hoàn và sức bền tim phổi.\\nVí dụ thực tế từ dữ liệu: đi bộ nhanh buổi sáng để giữ huyết áp ổn định, bơi lội để tăng sức bền tim mạch."@vi ;
    rdfs:subClassOf persona:muc_dich_suc_khoe .

persona:muc_tieu_suc_khoe_xuong_khop a owl:Class ;
    rdfs:label "Mục tiêu sức khỏe xương khớp"@vi ;
    rdfs:comment "Vận động nhằm duy trì độ linh hoạt, mật độ xương và giảm nguy cơ thoái hóa khớp.\\nVí dụ thực tế từ dữ liệu: tập yoga để giữ linh hoạt khớp gối, đi bộ nhẹ để tránh loãng xương khi lớn tuổi."@vi ;
    rdfs:subClassOf persona:muc_dich_suc_khoe .

persona:muc_tieu_tai_chinh_ho_tro_nguoi_than a owl:Class ;
    rdfs:label "Mục tiêu tài chính hỗ trợ người thân"@vi ;
    rdfs:comment "Đích đến tài chính gắn với việc đảm bảo điều kiện sống tốt hơn cho gia đình — xây nhà, lo học phí, \\ncải thiện điều kiện sinh hoạt cho cha mẹ hoặc con cái."@vi ;
    rdfs:subClassOf persona:muc_tieu_tai_chinh_ca_nhan .

persona:muc_tieu_tai_chinh_on_dinh_cuoc_song a owl:Class ;
    rdfs:label "Mục tiêu tài chính ổn định cuộc sống"@vi ;
    rdfs:comment "Đích đến tài chính ở mức đủ sống ổn định và tự lo được cho bản thân — không cần giàu có nhưng không phải lo âu về chi phí hàng ngày."@vi ;
    rdfs:subClassOf persona:muc_tieu_tai_chinh_ca_nhan .

persona:muc_tieu_tai_chinh_tich_luy_tai_san a owl:Class ;
    rdfs:label "Mục tiêu tài chính tích lũy tài sản"@vi ;
    rdfs:comment "Đích đến tài chính gắn với việc sở hữu tài sản cụ thể — mua nhà, mua đất, tích lũy tiết kiệm đủ để tự chủ tài chính."@vi ;
    rdfs:subClassOf persona:muc_tieu_tai_chinh_ca_nhan .

persona:muc_tieu_tang_cuong_he_mien_dich a owl:Class ;
    rdfs:label "Mục tiêu tăng cường hệ miễn dịch"@vi ;
    rdfs:comment "Vận động nhằm nâng cao khả năng phòng bệnh và phục hồi của cơ thể.\\nVí dụ thực tế từ dữ liệu: tập thể dục đều đặn để ít ốm vặt, vận động ngoài trời để tăng sức đề kháng."@vi ;
    rdfs:subClassOf persona:muc_dich_suc_khoe .

persona:nang_luc_nghe_nghiep_theo_thoi_gian a owl:Class ;
    rdfs:label "Năng lực nghề nghiệp theo thời gian"@vi ;
    rdfs:comment "Sự thay đổi và tiến bộ trong khả năng chuyên môn của cá nhân qua các giai đoạn trong sự nghiệp.\\nPhản ánh quá trình học hỏi tích lũy liên tục từ thực tế công việc và đào tạo bổ sung."@vi ;
    rdfs:subClassOf persona:phat_trien_su_nghiep .

persona:nang_luc_rieng_biet_de_thuc_hien_tac_vu a owl:Class ;
    rdfs:label "Năng lực riêng biệt để thực hiện tác vụ"@vi ;
    rdfs:comment "Kỹ năng hoặc kiến thức chuyên biệt mà người không thuộc ngành nghề đó không thể thực hiện được nếu không qua đào tạo.\\nVí dụ thực tế từ dữ liệu: kỹ năng tiêm bắp đúng kỹ thuật, kỹ năng thiết kế hệ thống tưới tiêu, kỹ năng làm bánh cuốn đúng độ mỏng."@vi ;
    rdfs:subClassOf persona:tac_vu_dac_thu_cong_viec .

persona:nang_luong_nap_vao a owl:Class ;
    rdfs:label "Năng lượng nạp vào"@vi ;
    rdfs:comment "Tổng lượng calo từ thức ăn và đồ uống mà cơ thể nhận được trong một ngày, là một vế của phương trình cân bằng năng lượng.\\nViệc kiểm soát năng lượng nạp vào là yếu tố then chốt trong quản lý cân nặng."@vi ;
    rdfs:subClassOf persona:kiem_soat_can_nang .

persona:nang_luong_tieu_hao_qua_van_dong a owl:Class ;
    rdfs:label "Năng lượng tiêu hao qua vận động"@vi ;
    rdfs:comment "Lượng calo cơ thể đốt cháy thông qua các hoạt động thể chất từ nhẹ nhàng đến cường độ cao.\\nVí dụ thực tế từ dữ liệu: đi bộ 30 phút tiêu thụ khoảng 150 calo, bơi 45 phút tiêu thụ khoảng 400 calo."@vi ;
    rdfs:subClassOf persona:kiem_soat_can_nang .

persona:ngay_nghi_phuc_hoi_trong_lich a owl:Class ;
    rdfs:label "Ngày nghỉ phục hồi trong lịch"@vi ;
    rdfs:comment "Các ngày được dành để cơ thể phục hồi hoàn toàn, không tập hoặc chỉ vận động nhẹ.\\nLà thành phần bắt buộc trong lịch trình khoa học để tránh chấn thương và tăng hiệu quả tập."@vi ;
    rdfs:subClassOf persona:lich_trinh_tap_luyen .

persona:nghe_thuat_hinh_thanh_dong_cam_xa_hoi a owl:Class ;
    rdfs:label "Nghệ thuật hình thành đồng cảm xã hội"@vi ;
    rdfs:comment "Mức độ mà tiếp xúc với văn học, điện ảnh hay nghệ thuật nhân văn giúp cá nhân đồng cảm và thấu hiểu người khác hơn trong cuộc sống thực."@vi ;
    rdfs:subClassOf persona:anh_huong_nghe_thuat_den_the_gioi_quan .

persona:nghe_thuat_hinh_thanh_y_thuc_xa_hoi a owl:Class ;
    rdfs:label "Nghệ thuật hình thành ý thức xã hội"@vi ;
    rdfs:comment "Mức độ mà tiếp xúc với nghệ thuật phản kháng hoặc chính trị hình thành nên nhận thức và thái độ của cá nhân đối với các vấn đề bất công, quyền lực và cộng đồng."@vi ;
    rdfs:subClassOf persona:anh_huong_nghe_thuat_den_the_gioi_quan .

persona:nghiep_vu_dac_trung_chuyen_nganh a owl:Class ;
    rdfs:label "Nghiệp vụ đặc trưng chuyên ngành"@vi ;
    rdfs:comment "Thao tác hoặc quy trình chỉ tồn tại trong một ngành nghề hoặc vị trí cụ thể, không phổ biến ở các nghề khác.\\nVí dụ thực tế từ dữ liệu: đọc điện tâm đồ chỉ có trong y tế, thẩm định bản vẽ kỹ thuật chỉ có trong kỹ thuật xây dựng, tráng bánh đa chỉ có trong nghề làm bánh truyền thống."@vi ;
    rdfs:subClassOf persona:tac_vu_dac_thu_cong_viec .

persona:ngon_ngu_su_dung_trong_cong_viec a owl:Class ;
    rdfs:label "Ngôn ngữ sử dụng trong công việc"@vi ;
    rdfs:comment "Cách dùng từ ngữ, thuật ngữ và văn phong đặc trưng của cá nhân khi giao tiếp nghề nghiệp.\\nVí dụ thực tế từ dữ liệu: điều dưỡng dùng thuật ngữ y khoa với bác sĩ và ngôn ngữ đơn giản với bệnh nhân, người bán tạp hóa nói chuyện thân mật với khách quen."@vi ;
    rdfs:subClassOf persona:phong_cach_giao_tiep_nghe_nghiep .

persona:nguon_luc_duoc_cap_phat a owl:Class ;
    rdfs:label "Nguồn lực được cấp phát"@vi ;
    rdfs:comment "Tài nguyên, công cụ, ngân sách và nhân lực mà tổ chức cung cấp cho cá nhân để thực hiện công việc.\\nVí dụ thực tế từ dữ liệu: thiết bị y tế bệnh viện cấp cho điều dưỡng, vốn nhập hàng của tiệm tạp hóa, máy móc công trường cấp cho đội thi công."@vi ;
    rdfs:subClassOf persona:dieu_kien_to_chuc .

persona:nguong_toi_thieu_van_dong a owl:Class ;
    rdfs:label "Ngưỡng tối thiểu vận động"@vi ;
    rdfs:comment "Mức hoạt động thể chất thấp nhất mà cá nhân duy trì, dù chỉ là đi bộ nhẹ hoặc leo cầu thang hàng ngày.\\nPhân biệt người hoàn toàn tĩnh tại với người có chút vận động trong sinh hoạt."@vi ;
    rdfs:subClassOf persona:tinh_trang_tham_gia_the_thao .

persona:nguyen_ly_chuyen_nganh a owl:Class ;
    rdfs:label "Nguyên lý chuyên ngành"@vi ;
    rdfs:comment "Các quy luật nền tảng chi phối cách hoạt động trong một lĩnh vực, là cơ sở để lý giải và dự đoán kết quả.\\nVí dụ thực tế từ dữ liệu: nguyên lý trao đổi chất trong dinh dưỡng, nguyên lý chịu lực trong thiết kế kết cấu."@vi ;
    rdfs:subClassOf persona:kien_thuc_chuyen_nganh .

persona:nguyen_tac_ca_nhan_hoa a owl:Class ;
    rdfs:label "Nguyên tắc cá nhân hóa"@vi ;
    rdfs:comment "Quy tắc điều chỉnh chương trình tập phù hợp với thể trạng, mục tiêu và giới hạn riêng của từng người.\\nVí dụ: người mới tập không áp dụng giáo án của vận động viên chuyên nghiệp."@vi ;
    rdfs:subClassOf persona:nguyen_tac_tap_luyen .

persona:nguyen_tac_dac_hieu_hoa a owl:Class ;
    rdfs:label "Nguyên tắc đặc hiệu hóa"@vi ;
    rdfs:comment "Quy tắc chỉ tập đúng các kỹ năng và nhóm cơ liên quan đến môn thể thao hoặc mục tiêu cụ thể.\\nVí dụ: cầu thủ bóng đá tập chạy nước rút và xử lý bóng, không tập nâng tạ nặng không liên quan."@vi ;
    rdfs:subClassOf persona:nguyen_tac_tap_luyen .

persona:nguyen_tac_phuc_hoi a owl:Class ;
    rdfs:label "Nguyên tắc phục hồi"@vi ;
    rdfs:comment "Quy tắc đảm bảo cơ thể có đủ thời gian nghỉ ngơi giữa các buổi tập để tái tạo và phát triển mạnh hơn.\\nVí dụ: xen kẽ ngày tập và ngày nghỉ, ngủ đủ giấc, không tập cùng một nhóm cơ liên tiếp hai ngày."@vi ;
    rdfs:subClassOf persona:nguyen_tac_tap_luyen .

persona:nguyen_tac_tang_tai_dan a owl:Class ;
    rdfs:label "Nguyên tắc tăng tải dần"@vi ;
    rdfs:comment "Quy tắc tập luyện yêu cầu tăng dần khối lượng hoặc cường độ theo thời gian để cơ thể tiếp tục thích nghi và tiến bộ.\\nVí dụ: tuần này chạy 3km, tuần sau tăng lên 3.5km để không bị giậm chân tại chỗ."@vi ;
    rdfs:subClassOf persona:nguyen_tac_tap_luyen .

persona:nhan_thuc_cam_xuc_va_dong_luc_noi_tam a owl:Class ;
    rdfs:label "Nhận thức cảm xúc và động lực nội tâm"@vi ;
    rdfs:comment "Khả năng cá nhân nhận biết trạng thái cảm xúc hiện tại và hiểu điều gì thực sự thúc đẩy mình hành động trong các tình huống khác nhau."@vi ;
    rdfs:subClassOf persona:tu_nhan_thuc_ban_than .

persona:nhan_thuc_nang_luc_ban_than a owl:Class ;
    rdfs:label "Nhận thức năng lực bản thân"@vi ;
    rdfs:comment "Khả năng cá nhân xác định chính xác điểm mạnh và điểm yếu của mình trong công việc, học tập và các lĩnh vực cụ thể."@vi ;
    rdfs:subClassOf persona:tu_nhan_thuc_ban_than .

persona:nhan_thuc_quy_luat_nhan_qua a owl:Class ;
    rdfs:label "Nhận thức quy luật nhân quả"@vi ;
    rdfs:comment "Niềm tin vào mối liên hệ tất yếu giữa hành động và kết quả — tin rằng điều tốt sinh ra điều tốt, hành động xấu sẽ dẫn đến hệ quả tiêu cực."@vi ;
    rdfs:subClassOf persona:nhan_thuc_ve_tu_nhien_va_xa_hoi .

persona:nhan_thuc_vai_tro_tu_nhien a owl:Class ;
    rdfs:label "Nhận thức vai trò tự nhiên"@vi ;
    rdfs:comment "Cách cá nhân nhìn nhận mối quan hệ giữa con người và thiên nhiên — từ coi tự nhiên là nguồn nuôi dưỡng cần bảo vệ đến xem đó là môi trường cần chinh phục và khai thác."@vi ;
    rdfs:subClassOf persona:nhan_thuc_ve_tu_nhien_va_xa_hoi .

persona:nhan_thuc_ve_cong_bang_xa_hoi a owl:Class ;
    rdfs:label "Nhận thức về công bằng xã hội"@vi ;
    rdfs:comment "Quan điểm của cá nhân về mức độ công bằng trong cơ hội, phân phối tài nguyên và quyền lực trong xã hội — từ tin xã hội về cơ bản công bằng đến nhận thức rõ các bất bình đẳng có hệ thống."@vi ;
    rdfs:subClassOf persona:nhan_thuc_ve_tu_nhien_va_xa_hoi .

persona:nhiem_vu_duoc_giao a owl:Class ;
    rdfs:label "Nhiệm vụ được giao"@vi ;
    rdfs:comment "Các trách nhiệm và công việc mà cấp trên hoặc tổ chức chính thức giao cho cá nhân đảm nhận.\\nVí dụ thực tế từ dữ liệu: điều dưỡng được phân công phụ trách buồng bệnh cụ thể, kỹ sư được giao hạng mục lắp đặt hệ thống tưới tiêu."@vi ;
    rdfs:subClassOf persona:nhiem_vu_nghe_nghiep .

persona:nhiem_vu_trong_cong_viec a owl:Class ;
    rdfs:label "Nhiệm vụ trong công việc"@vi ;
    rdfs:comment "Đơn vị công việc có mục tiêu rõ ràng và kết quả đầu ra cụ thể mà cá nhân cần hoàn thành.\\nVí dụ thực tế từ dữ liệu: chăm sóc ca bệnh trong buổi trực, thu hoạch rau đưa chợ, kiểm kê hàng tồn kho cuối ngày."@vi ;
    rdfs:subClassOf persona:hoat_dong_nghe_nghiep .

persona:nhiem_vu_tu_xac_dinh a owl:Class ;
    rdfs:label "Nhiệm vụ tự xác định"@vi ;
    rdfs:comment "Các công việc mà cá nhân chủ động nhận ra và đảm nhận ngoài phạm vi được giao vì trách nhiệm hoặc đam mê.\\nVí dụ thực tế từ dữ liệu: dạy nghề truyền thống cho lớp trẻ dù đã nghỉ hưu, tự sửa máy nhỏ trong xưởng không chờ thợ bên ngoài."@vi ;
    rdfs:subClassOf persona:nhiem_vu_nghe_nghiep .

persona:nhin_kho_khan_la_bat_cong_hoac_ly_do_bo_cuoc a owl:Class ;
    rdfs:label "Nhìn khó khăn là bất công hoặc lý do bỏ cuộc"@vi ;
    rdfs:comment "Thái độ quy trách nhiệm khó khăn cho hoàn cảnh bên ngoài — xem nghịch cảnh là bất công và dễ từ bỏ khi gặp trở ngại lớn."@vi ;
    rdfs:subClassOf persona:thai_do_doi_voi_kho_khan_va_mat_mat .

persona:nhin_kho_khan_la_co_hoi_truong_thanh a owl:Class ;
    rdfs:label "Nhìn khó khăn là cơ hội trưởng thành"@vi ;
    rdfs:comment "Thái độ chuyển hóa nghịch cảnh thành động lực — xem thất bại và mất mát là bài học và bước đệm để phát triển bản thân."@vi ;
    rdfs:subClassOf persona:thai_do_doi_voi_kho_khan_va_mat_mat .

persona:nhip_do_day_dac_nhieu_diem a owl:Class ;
    rdfs:label "Nhịp độ dày đặc nhiều điểm"@vi ;
    rdfs:comment "Lịch trình tham quan tối đa số địa điểm trong thời gian ngắn nhất — di chuyển liên tục, tối ưu thời gian để không bỏ lỡ điểm nào."@vi ;
    rdfs:subClassOf persona:nhip_do_hanh_trinh .

persona:nhip_do_tham_sau_tung_diem a owl:Class ;
    rdfs:label "Nhịp độ thấm sâu từng điểm"@vi ;
    rdfs:comment "Ở lâu tại ít điểm đến để trải nghiệm sâu thay vì đi nhiều nơi qua loa — dành nhiều ngày tại một nơi, khám phá từng góc nhỏ và tích lũy cảm nhận theo thời gian."@vi ;
    rdfs:subClassOf persona:nhip_do_hanh_trinh .

persona:nhom_co_muc_tieu a owl:Class ;
    rdfs:label "Nhóm cơ mục tiêu"@vi ;
    rdfs:comment "Các nhóm cơ cụ thể mà hệ thống bài tập nhắm đến để tác động và phát triển.\\nVí dụ thực tế: nhóm cơ ngực và tay trong tập tạ, nhóm cơ lõi trong yoga, cơ tim và phổi trong cardio."@vi ;
    rdfs:subClassOf persona:he_thong_bai_tap .

persona:nhom_nhu_cau_cu_the a owl:Class ;
    rdfs:label "Nhóm nhu cầu cụ thể"@vi ;
    rdfs:comment "Tập hợp các vấn đề, mong muốn hoặc đòi hỏi đặc thù mà khách hàng mục tiêu cần được đáp ứng.\\nVí dụ thực tế từ dữ liệu: nhu cầu chăm sóc sức khỏe sau phẫu thuật, nhu cầu mua hàng thiết yếu gần nhà, nhu cầu học nghề truyền thống."@vi ;
    rdfs:subClassOf persona:phan_khuc_thi_truong .

persona:nhu_cau_do_suc_voi_nguoi_khac a owl:Class ;
    rdfs:label "Nhu cầu đo sức với người khác"@vi ;
    rdfs:comment "Động lực muốn biết mình đứng ở đâu so với các đối thủ cùng trình độ.\\nVí dụ thực tế từ dữ liệu: tham gia giải cầu lông phong trào để thử sức, thi đấu bóng đá khu phố để đo trình độ."@vi ;
    rdfs:subClassOf persona:muc_dich_thi_dau_canh_tranh .

persona:niem_tin_ve_ban_than a owl:Class ;
    rdfs:label "Niềm tin về bản thân"@vi ;
    rdfs:comment "Các xác tín cốt lõi mà cá nhân nắm giữ về năng lực, giá trị và vị trí của mình trong thế giới.\\nVí dụ: tin rằng mình có thể thay đổi và phát triển, hay tin rằng năng lực là cố định từ khi sinh ra."@vi ;
    rdfs:subClassOf persona:he_thong_niem_tin_ca_nhan .

persona:niem_tin_ve_the_gioi_va_nguoi_khac a owl:Class ;
    rdfs:label "Niềm tin về thế giới và người khác"@vi ;
    rdfs:comment "Quan điểm của cá nhân về bản chất con người và cách vận hành của xã hội.\\nVí dụ: tin vào lòng tốt phổ quát và sự hợp tác, hay hoài nghi về động cơ ẩn sau mọi hành vi xã hội."@vi ;
    rdfs:subClassOf persona:he_thong_niem_tin_ca_nhan .

persona:noi_dung_tu_su_nang_luc a owl:Class ;
    rdfs:label "Nội dung tự sự năng lực"@vi ;
    rdfs:comment "Thông tin thực chất được truyền tải trong đoạn văn mô tả năng lực: bối cảnh làm việc, các kỹ năng nổi bật và thành tích cụ thể.\\nVí dụ thực tế từ dữ liệu: 'Có tay nghề nấu ăn từ căn bếp 10m2, khéo tay trang trí nhà cửa với hoa giấy handmade.'"@vi ;
    rdfs:subClassOf persona:doan_van_ban_tu_su_nang_luc .

persona:occupation a owl:Class ;
    rdfs:label "occupation"@vi ;
    rdfs:comment "Nhóm ngành nghề; bao gồm 20 loại khác nhau, ví dụ: Buôn bán / kinh doanh, Kỹ thuật viên / kỹ sư, Công nhân / lao động phổ thông."@vi .

persona:pham_vi_loai_hinh_hep a owl:Class ;
    rdfs:label "Phạm vi loại hình hẹp"@vi ;
    rdfs:comment "Cá nhân chỉ gắn bó với một hoặc một vài thể loại nghệ thuật nhất định.\\nVí dụ thực tế: chỉ nghe nhạc dân ca, chỉ xem phim hành động, không quan tâm đến hội họa hay sân khấu."@vi ;
    rdfs:subClassOf persona:pham_vi_loai_hinh_nghe_thuat_tiep_can .

persona:pham_vi_loai_hinh_rong a owl:Class ;
    rdfs:label "Phạm vi loại hình rộng"@vi ;
    rdfs:comment "Cá nhân trải nghiệm đa dạng nhiều hình thức nghệ thuật khác nhau.\\nVí dụ thực tế: vừa xem phim, nghe nhạc, đi triển lãm hội họa, xem kịch và đọc văn học."@vi ;
    rdfs:subClassOf persona:pham_vi_loai_hinh_nghe_thuat_tiep_can .

persona:phan_biet_ban_than_qua_moi_truong_xa_hoi a owl:Class ;
    rdfs:label "Phân biệt bản thân qua môi trường xã hội"@vi ;
    rdfs:comment "Xu hướng chủ động chọn lọc các nhóm, cộng đồng và mối quan hệ phù hợp với bản sắc của mình, đồng thời tránh xa các môi trường không tương thích."@vi ;
    rdfs:subClassOf persona:su_phan_biet_ban_than_trong_xa_hoi .

persona:phan_biet_ban_than_qua_ngon_ngu_giao_tiep a owl:Class ;
    rdfs:label "Phân biệt bản thân qua ngôn ngữ giao tiếp"@vi ;
    rdfs:comment "Cách thức cá nhân dùng từ ngữ, giọng điệu và phong cách diễn đạt để tạo dấu ấn riêng và phân biệt bản thân trong mắt người khác."@vi ;
    rdfs:subClassOf persona:su_phan_biet_ban_than_trong_xa_hoi .

persona:phan_biet_ban_than_qua_phong_cach_song a owl:Class ;
    rdfs:label "Phân biệt bản thân qua phong cách sống"@vi ;
    rdfs:comment "Cách thức cá nhân thể hiện cái tôi thông qua các lựa chọn sinh hoạt thường ngày — ăn mặc, tiêu dùng, thói quen và nơi lui tới."@vi ;
    rdfs:subClassOf persona:su_phan_biet_ban_than_trong_xa_hoi .

persona:phan_biet_voi_nhiem_vu_hanh_chinh_chung a owl:Class ;
    rdfs:label "Phân biệt với nhiệm vụ hành chính chung"@vi ;
    rdfs:comment "Ranh giới giữa tác vụ đặc thù nghề nghiệp và các công việc hành chính phổ quát mà bất kỳ ai cũng có thể làm.\\nVí dụ thực tế từ dữ liệu: điền hồ sơ bệnh nhân là hành chính chung, nhưng đọc và giải thích kết quả xét nghiệm là tác vụ đặc thù điều dưỡng."@vi ;
    rdfs:subClassOf persona:tac_vu_dac_thu_cong_viec .

persona:phan_khuc_theo_dia_ly a owl:Class ;
    rdfs:label "Phân khúc theo địa lý"@vi ;
    rdfs:comment "Cách phân chia thị trường dựa trên vị trí địa lý của khách hàng hoặc phạm vi hoạt động của cá nhân.\\nVí dụ thực tế từ dữ liệu: bán hàng trong khu phố, phục vụ bệnh nhân trong quận, tổ chức sự kiện trong toàn thành phố."@vi ;
    rdfs:subClassOf persona:phan_khuc_thi_truong .

persona:phan_khuc_theo_nhan_khau_hoc a owl:Class ;
    rdfs:label "Phân khúc theo nhân khẩu học"@vi ;
    rdfs:comment "Cách phân chia thị trường theo đặc điểm dân số như tuổi, giới tính, trình độ học vấn hoặc thu nhập của nhóm khách hàng.\\nVí dụ thực tế từ dữ liệu: dạy nghề ẩm thực cho lớp trẻ, phục vụ người cao tuổi tại bệnh viện, bán hàng thiết yếu cho gia đình lao động phổ thông."@vi ;
    rdfs:subClassOf persona:phan_khuc_thi_truong .

persona:phan_khuc_theo_quy_mo_doanh_nghiep a owl:Class ;
    rdfs:label "Phân khúc theo quy mô doanh nghiệp"@vi ;
    rdfs:comment "Cách phân chia thị trường dựa trên quy mô của tổ chức khách hàng: hộ gia đình, doanh nghiệp nhỏ, vừa hay lớn.\\nVí dụ thực tế từ dữ liệu: tiệm tạp hóa phục vụ hộ gia đình lẻ, kỹ sư xây dựng làm việc cho công ty thầu lớn."@vi ;
    rdfs:subClassOf persona:phan_khuc_thi_truong .

persona:phan_ung_ban_nang_va_hoc_hoi a owl:Class ;
    rdfs:label "Phản ứng bản năng và học hỏi"@vi ;
    rdfs:comment "Sự phân biệt giữa phản ứng tức thời có tính bẩm sinh và phản ứng được hình thành qua rèn luyện và kinh nghiệm.\\nVí dụ: người bẩm sinh bình tĩnh trước áp lực với người học được cách giữ bình tĩnh qua nhiều năm làm việc căng thẳng."@vi ;
    rdfs:subClassOf persona:xu_huong_phan_ung_tinh_huong .

persona:phan_ung_truoc_ap_luc_thoi_han a owl:Class ;
    rdfs:label "Phản ứng trước áp lực thời hạn"@vi ;
    rdfs:comment "Kiểu hành vi và cảm xúc mà cá nhân thể hiện khi thời gian hoàn thành công việc bị thu hẹp đột ngột.\\nVí dụ thực tế từ dữ liệu: tăng tốc xử lý ca bệnh khi có ca cấp cứu, đẩy nhanh tiến độ thi công khi gần đến hạn bàn giao."@vi ;
    rdfs:subClassOf persona:xu_huong_phan_ung_tinh_huong .

persona:phan_ung_truoc_phe_binh_tu_cap_tren a owl:Class ;
    rdfs:label "Phản ứng trước phê bình từ cấp trên"@vi ;
    rdfs:comment "Cách cá nhân tiếp nhận và ứng xử khi nhận được góp ý tiêu cực hoặc bị chỉ trích từ người có thẩm quyền.\\nPhân biệt giữa người cởi mở lắng nghe và điều chỉnh, và người phòng thủ hoặc bị tác động tiêu cực đến hiệu suất."@vi ;
    rdfs:subClassOf persona:xu_huong_phan_ung_tinh_huong .

persona:phan_ung_truoc_xung_dot_dong_nghiep a owl:Class ;
    rdfs:label "Phản ứng trước xung đột đồng nghiệp"@vi ;
    rdfs:comment "Kiểu hành vi mà cá nhân chọn khi nảy sinh mâu thuẫn với người cùng làm việc.\\nVí dụ thực tế từ dữ liệu: chủ động trao đổi thẳng thắn để giải quyết, nhờ người trung gian hòa giải, hoặc im lặng né tránh xung đột."@vi ;
    rdfs:subClassOf persona:xu_huong_phan_ung_tinh_huong .

persona:phan_xa_the_thao a owl:Class ;
    rdfs:label "Phản xạ thể thao"@vi ;
    rdfs:comment "Khả năng phản ứng tức thời và chính xác với các kích thích trong môn thể thao mà không cần suy nghĩ ý thức.\\nVí dụ thực tế từ dữ liệu: đỡ bóng phản xạ trong bóng bàn, phán đoán đúng hướng bóng trong cầu lông."@vi ;
    rdfs:subClassOf persona:ky_nang_the_thao .

persona:phat_trien_theo_chieu_rong a owl:Class ;
    rdfs:label "Phát triển theo chiều rộng"@vi ;
    rdfs:comment "Chiến lược nghề nghiệp ưu tiên mở rộng sang nhiều lĩnh vực khác nhau thay vì chuyên sâu một mảng.\\nBiểu hiện qua việc tích lũy nhiều kỹ năng đa dạng ở mức độ khá thay vì xuất sắc trong một chuyên môn."@vi ;
    rdfs:subClassOf persona:pham_vi_chuyen_mon_hoa .

persona:phat_trien_theo_chieu_sau a owl:Class ;
    rdfs:label "Phát triển theo chiều sâu"@vi ;
    rdfs:comment "Chiến lược nghề nghiệp ưu tiên đào sâu năng lực trong một lĩnh vực hẹp đến mức thành thạo vượt trội.\\nBiểu hiện qua việc liên tục học thêm, thực hành và cập nhật trong cùng một chuyên môn theo thời gian."@vi ;
    rdfs:subClassOf persona:pham_vi_chuyen_mon_hoa .

persona:phong_cach_viet_ngan_gon_suc_tich a owl:Class ;
    rdfs:label "Phong cách viết ngắn gọn súc tích"@vi ;
    rdfs:comment "Cách trình bày năng lực bằng ngôn ngữ cô đọng, chỉ nêu điểm cốt lõi — không dài dòng, không giải thích thừa."@vi ;
    rdfs:subClassOf persona:giong_dieu_va_phong_cach_viet_tu_su .

persona:phuc_hoi_sinh_hoc_sau_tap a owl:Class ;
    rdfs:label "Phục hồi sinh học sau tập"@vi ;
    rdfs:comment "Quá trình cơ thể sửa chữa và tái tạo sợi cơ bị phá vỡ sau tập luyện kháng lực, là giai đoạn thực sự tạo ra tăng trưởng cơ bắp.\\nĐòi hỏi đủ thời gian nghỉ ngơi, ngủ đủ giấc và dinh dưỡng protein phù hợp."@vi ;
    rdfs:subClassOf persona:phat_trien_co_bap .

persona:phuong_thuc_theo_doi_tien_do a owl:Class ;
    rdfs:label "Phương thức theo dõi tiến độ"@vi ;
    rdfs:comment "Cách cá nhân kiểm soát và đánh giá mức độ hoàn thành nhiệm vụ trong ngày làm việc.\\nVí dụ thực tế từ dữ liệu: ghi sổ tay theo dõi bệnh nhân, kiểm đếm hàng tồn cuối ngày, đánh dấu hạng mục đã hoàn thành trong bản vẽ thi công."@vi ;
    rdfs:subClassOf persona:thoi_quen_lam_viec .

persona:phuong_tien_linh_hoat_kham_pha a owl:Class ;
    rdfs:label "Phương tiện linh hoạt khám phá"@vi ;
    rdfs:comment "Ưu tiên phương tiện cho phép tự do thay đổi lịch trình và khám phá ngoài kế hoạch.\\nVí dụ thực tế: thuê xe máy, thuê xe đạp, đi bộ."@vi ;
    rdfs:subClassOf persona:so_thich_phuong_tien_di_chuyen .

persona:phuong_tien_muu_sinh a owl:Class ;
    rdfs:label "Phương tiện mưu sinh"@vi ;
    rdfs:comment "Cách thức cụ thể mà một cá nhân sử dụng hoạt động nghề nghiệp để tạo ra thu nhập đảm bảo cuộc sống.\\nVí dụ thực tế từ dữ liệu: bán sản phẩm nông nghiệp ra chợ, nhận lương điều dưỡng tại bệnh viện tư, thu lợi nhuận từ tiệm tạp hóa gia đình."@vi ;
    rdfs:subClassOf persona:nganh_nghe .

persona:phuong_tien_ngam_canh_trai_nghiem a owl:Class ;
    rdfs:label "Phương tiện ngắm cảnh trải nghiệm"@vi ;
    rdfs:comment "Ưu tiên phương tiện mang lại trải nghiệm di chuyển thú vị và cảnh quan đẹp dọc đường, không chỉ đơn thuần để đến đích.\\nVí dụ thực tế: tàu hỏa ngắm cảnh, tàu thuyền ven sông."@vi ;
    rdfs:subClassOf persona:so_thich_phuong_tien_di_chuyen .

persona:phuong_tien_tiet_kiem_thoi_gian a owl:Class ;
    rdfs:label "Phương tiện tiết kiệm thời gian"@vi ;
    rdfs:comment "Ưu tiên tốc độ và hiệu quả trong di chuyển để dành tối đa thời gian cho điểm đến.\\nVí dụ thực tế: máy bay, tàu cao tốc."@vi ;
    rdfs:subClassOf persona:so_thich_phuong_tien_di_chuyen .

persona:phuong_tien_vat_ly_truyen_thong a owl:Class ;
    rdfs:label "Phương tiện vật lý truyền thống"@vi ;
    rdfs:comment "Chất liệu và công cụ hữu hình được dùng để tạo ra tác phẩm nghệ thuật.\\nVí dụ: màu sơn dầu, than chì, nhạc cụ truyền thống, sân khấu biểu diễn, đất sét."@vi ;
    rdfs:subClassOf persona:phuong_tien_bieu_dat_nghe_thuat .

persona:qua_trinh_lap_lai_va_dieu_chinh a owl:Class ;
    rdfs:label "Quá trình lặp lại và điều chỉnh"@vi ;
    rdfs:comment "Cơ chế học kỹ năng thể thao thông qua thực hành nhiều lần kết hợp nhận phản hồi để sửa sai và hoàn thiện.\\nVí dụ thực tế từ dữ liệu: tập đi tập lại kỹ thuật sút bóng và điều chỉnh theo lời huấn luyện viên."@vi ;
    rdfs:subClassOf persona:ky_nang_the_thao .

persona:quan_he_voi_cap_tren_va_cap_duoi a owl:Class ;
    rdfs:label "Quan hệ với cấp trên và cấp dưới"@vi ;
    rdfs:comment "Tính chất của mối quan hệ quyền lực dọc trong tổ chức và cách cá nhân điều hướng sự khác biệt về thẩm quyền.\\nVí dụ thực tế từ dữ liệu: điều dưỡng phối hợp và báo cáo cho bác sĩ, quản lý dự án điều phối nhóm người phía dưới."@vi ;
    rdfs:subClassOf persona:van_hoa_doanh_nghiep .

persona:quan_he_voi_doi_tac_va_khach_hang a owl:Class ;
    rdfs:label "Quan hệ với đối tác và khách hàng"@vi ;
    rdfs:comment "Chất lượng kết nối giữa cá nhân với các bên bên ngoài tổ chức có liên quan đến hoạt động nghề nghiệp.\\nVí dụ thực tế từ dữ liệu: khách hàng quen mua tạp hóa nhiều năm, bệnh nhân tin tưởng điều dưỡng, nhà cung cấp hàng quen của tiệm."@vi ;
    rdfs:subClassOf persona:van_hoa_doanh_nghiep .

persona:quan_he_voi_dong_nghiep a owl:Class ;
    rdfs:label "Quan hệ với đồng nghiệp"@vi ;
    rdfs:comment "Chất lượng kết nối và mức độ hợp tác giữa cá nhân với những người cùng vị trí hoặc cùng nhóm làm việc.\\nVí dụ thực tế từ dữ liệu: đồng nghiệp cùng chơi cầu lông sau giờ làm, phối hợp ăn ý với nhóm thi công, chia sẻ kinh nghiệm với đồng nghiệp điều dưỡng."@vi ;
    rdfs:subClassOf persona:van_hoa_doanh_nghiep .

persona:quan_ly_can_nang_vi_tham_my a owl:Class ;
    rdfs:label "Quản lý cân nặng vì thẩm mỹ"@vi ;
    rdfs:comment "Vận động nhằm đạt và duy trì số cân cụ thể xuất phát từ tiêu chí ngoại hình, không chỉ vì sức khỏe.\\nVí dụ thực tế từ dữ liệu: tập cardio để giảm 3kg trước hè, duy trì cân nặng để mặc vừa quần áo ưa thích."@vi ;
    rdfs:subClassOf persona:muc_dich_giu_voc_dang .

persona:quan_ly_dat_phong_va_hanh_ly a owl:Class ;
    rdfs:label "Quản lý đặt phòng và hành lý"@vi ;
    rdfs:comment "Các tác vụ hành chính trong chuyến đi liên quan đến đặt và check-in nơi lưu trú, bảo quản và vận chuyển hành lý giữa các điểm dừng chân."@vi ;
    rdfs:subClassOf persona:hoat_dong_luu_tru_va_di_chuyen .

persona:quy_chuan_nghe_nghiep a owl:Class ;
    rdfs:label "Quy chuẩn nghề nghiệp"@vi ;
    rdfs:comment "Các tiêu chuẩn, quy định và yêu cầu bắt buộc được ngành nghề hoặc cơ quan quản lý đặt ra mà cá nhân phải nắm và tuân thủ.\\nVí dụ thực tế từ dữ liệu: quy chuẩn vệ sinh an toàn thực phẩm khi làm bánh, quy trình tiêm thuốc an toàn trong điều dưỡng."@vi ;
    rdfs:subClassOf persona:kien_thuc_chuyen_nganh .

persona:quy_mo_to_chuc a owl:Class ;
    rdfs:label "Quy mô tổ chức"@vi ;
    rdfs:comment "Kích thước của tổ chức nơi cá nhân làm việc tính theo số nhân sự, doanh thu hoặc phạm vi hoạt động.\\nVí dụ thực tế từ dữ liệu: hộ kinh doanh gia đình 1–2 người, bệnh viện tư nhân vừa, công ty xây dựng nhiều hạng mục."@vi ;
    rdfs:subClassOf persona:dieu_kien_to_chuc .

persona:quy_thoi_gian_danh_cho_nghe_nghiep a owl:Class ;
    rdfs:label "Quỹ thời gian dành cho nghề nghiệp"@vi ;
    rdfs:comment "Tổng số giờ thực tế trong ngày, tuần mà cá nhân sử dụng cho hoạt động nghề nghiệp.\\nVí dụ thực tế từ dữ liệu: ra đồng từ sáng sớm đến chiều tối, làm ca đêm tại bệnh viện, mở tiệm từ sáng đến tối mỗi ngày."@vi ;
    rdfs:subClassOf persona:muc_do_dau_tu_thoi_gian_va_nguon_luc .

persona:quy_trinh_cong_viec a owl:Class ;
    rdfs:label "Quy trình công việc"@vi ;
    rdfs:comment "Chuỗi các bước được thực hiện theo thứ tự nhất định để hoàn thành một nhiệm vụ hoặc tạo ra một đầu ra cụ thể.\\nVí dụ thực tế từ dữ liệu: quy trình chăm sóc hậu phẫu, quy trình lắp đặt hệ thống điện, quy trình làm bánh đa cua từ ngâm gạo đến tráng bánh."@vi ;
    rdfs:subClassOf persona:hoat_dong_nghe_nghiep .

persona:quy_trinh_ra_quyet_dinh a owl:Class ;
    rdfs:label "Quy trình ra quyết định"@vi ;
    rdfs:comment "Cách thức các quyết định quan trọng được đưa ra trong tổ chức: ai có quyền quyết định, cần phê duyệt những cấp nào.\\nVí dụ thực tế từ dữ liệu: điều dưỡng cần y lệnh bác sĩ mới được tiêm thuốc, kỹ sư cần phê duyệt bản vẽ trước khi thi công."@vi ;
    rdfs:subClassOf persona:dieu_kien_to_chuc .

persona:ra_quyet_dinh_bang_cam_xuc_truc_giac a owl:Class ;
    rdfs:label "Ra quyết định bằng cảm xúc trực giác"@vi ;
    rdfs:comment "Xu hướng đưa ra lựa chọn dựa trên cảm nhận nội tâm, trực giác và cảm xúc tức thời hơn là phân tích dữ liệu có hệ thống."@vi ;
    rdfs:subClassOf persona:phuong_thuc_ra_quyet_dinh_ca_nhan .

persona:ra_quyet_dinh_bang_phan_tich_ly_tri a owl:Class ;
    rdfs:label "Ra quyết định bằng phân tích lý trí"@vi ;
    rdfs:comment "Xu hướng cân nhắc dữ liệu, so sánh phương án và suy luận có hệ thống trước khi đưa ra lựa chọn — ít bị cảm xúc chi phối."@vi ;
    rdfs:subClassOf persona:phuong_thuc_ra_quyet_dinh_ca_nhan .

persona:ra_quyet_dinh_dua_tren_y_kien_nguoi_khac a owl:Class ;
    rdfs:label "Ra quyết định dựa trên ý kiến người khác"@vi ;
    rdfs:comment "Xu hướng tham khảo ý kiến người thân, bạn bè hoặc chuyên gia trước khi quyết định — coi trọng sự đồng thuận và tránh hành động đơn độc."@vi ;
    rdfs:subClassOf persona:phuong_thuc_ra_quyet_dinh_ca_nhan .

persona:region a owl:Class ;
    rdfs:label "region"@vi ;
    rdfs:comment "Tỉnh hoặc Thành phố trực thuộc trung ương nơi cư trú (1 trong 6 địa điểm): Thủ Đô Hà Nội, Thành Phố Hồ Chí Minh, Thành Phố Hải Phòng, Thành Phố Đà Nẵng, Thành Phố Cần Thơ, Tỉnh Đồng Nai."@vi .

persona:rủ_ban_be_cung_kham_pha_am_thuc a owl:Class ;
    rdfs:label "Rủ bạn bè cùng khám phá ẩm thực"@vi ;
    rdfs:comment "Chủ động tìm quán mới và rủ bạn bè hoặc đồng nghiệp cùng đi thử — chia sẻ trải nghiệm ẩm thực qua hình thức gặp gỡ trực tiếp."@vi ;
    rdfs:subClassOf persona:hanh_vi_chia_se_am_thuc .

persona:sex a owl:Class ;
    rdfs:label "sex"@vi ;
    rdfs:comment "Giới tính sinh học (Nam, Nữ)."@vi .

persona:so_lan_tap_trong_tuan a owl:Class ;
    rdfs:label "Số lần tập trong tuần"@vi ;
    rdfs:comment "Tổng số buổi tập luyện hoặc vận động mà cá nhân thực hiện trong vòng 7 ngày.\\nVí dụ thực tế từ dữ liệu: đi bộ 7 ngày/tuần, đá bóng 1 lần/tuần vào cuối tuần, bơi lội 3 lần/tuần."@vi ;
    rdfs:subClassOf persona:tan_suat_tham_gia_the_thao .

persona:so_thich_am_thuc_dia_phuong a owl:Class ;
    rdfs:label "Sở thích ẩm thực địa phương"@vi ;
    persona:dinh_hinh persona:so_thich_diem_den ;
    persona:tac_dong persona:gu_trai_nghiem_van_hoa_am_thuc ;
    rdfs:comment "Mức độ hứng thú và xu hướng khám phá, thử nghiệm các món ăn đặc sản vùng miền tại điểm đến.\\nVí dụ thực tế: chủ động tìm quán vỉa hè bình dân, thử đặc sản địa phương thay vì ăn đồ quen thuộc."@vi ;
    rdfs:subClassOf persona:so_thich_dac_trung_du_lich .

persona:so_thich_cong_dong_va_giao_luu a owl:Class ;
    rdfs:label "Sở thích cộng đồng và giao lưu"@vi ;
    rdfs:comment "Nhóm sở thích gắn với sinh hoạt tập thể và kết nối con người.\\nVí dụ thực tế: tham gia khiêu vũ truyền thống, sinh hoạt hội nhóm, tổ chức sự kiện cộng đồng, dạy nghề cho lớp trẻ."@vi ;
    rdfs:subClassOf persona:loai_hinh_so_thich .

persona:so_thich_hinh_thanh_tu_gia_dinh_truyen_thong a owl:Class ;
    rdfs:label "Sở thích hình thành từ gia đình truyền thống"@vi ;
    rdfs:comment "Sở thích được truyền lại hoặc khơi dậy từ môi trường gia đình và truyền thống dòng họ.\\nVí dụ thực tế: gia đình có truyền thống nghệ thuật sân khấu nên gắn bó với hát chèo, mẹ làm bánh nên thích nấu nướng từ nhỏ."@vi ;
    rdfs:subClassOf persona:nguon_goc_hinh_thanh_so_thich .

persona:so_thich_hinh_thanh_tu_moi_truong_song a owl:Class ;
    rdfs:label "Sở thích hình thành từ môi trường sống"@vi ;
    rdfs:comment "Sở thích nảy sinh từ đặc điểm địa lý, cảnh quan hoặc nhịp sống của nơi cá nhân lớn lên.\\nVí dụ thực tế: lớn lên gần chợ nổi nên thích chèo xuồng, sống ven biển nên gắn bó với câu cá và bơi lội."@vi ;
    rdfs:subClassOf persona:nguon_goc_hinh_thanh_so_thich .

persona:so_thich_hinh_thanh_tu_nguoi_truyen_cam_hung a owl:Class ;
    rdfs:label "Sở thích hình thành từ người truyền cảm hứng"@vi ;
    rdfs:comment "Sở thích được khơi dậy bởi một người cụ thể — người thân, bạn bè hoặc thầy cô — giới thiệu và truyền niềm đam mê.\\nVí dụ thực tế: cháu nội dạy dùng điện thoại nên tò mò về nhiếp ảnh kỹ thuật số, bạn rủ đi lớp khiêu vũ rồi mê từ đó."@vi ;
    rdfs:subClassOf persona:nguon_goc_hinh_thanh_so_thich .

persona:so_thich_muc_nhe_thinh_thoang a owl:Class ;
    rdfs:label "Sở thích mức nhẹ thỉnh thoảng"@vi ;
    rdfs:comment "Mức đầu tư thấp — chỉ thực hiện khi có dịp hoặc cảm hứng, không có lịch cố định và không đặt mục tiêu phát triển."@vi ;
    rdfs:subClassOf persona:muc_do_dau_tu_vao_so_thich .

persona:so_thich_muc_sau_co_cam_ket a owl:Class ;
    rdfs:label "Sở thích mức sâu có cam kết"@vi ;
    rdfs:comment "Mức đầu tư cao — dành thời gian đều đặn, có mục tiêu rõ ràng và liên tục tìm cách nâng cao kỹ năng hoặc kiến thức trong lĩnh vực đó.\\nVí dụ thực tế: mỗi sáng thứ Bảy tham gia lớp múa quan họ, mỗi cuối tuần đến công viên nhảy truyền thống."@vi ;
    rdfs:subClassOf persona:muc_do_dau_tu_vao_so_thich .

persona:so_thich_nghe_thuat_thu_cong a owl:Class ;
    rdfs:label "Sở thích nghệ thuật thủ công"@vi ;
    rdfs:comment "Nhóm sở thích gắn với việc tạo ra sản phẩm bằng tay hoặc thực hành các loại hình nghệ thuật.\\nVí dụ thực tế: làm tranh thạch cao, vẽ tranh thủy mặc, thêu thùa, làm đèn hoa đăng, nặn tượng."@vi ;
    rdfs:subClassOf persona:loai_hinh_so_thich .

persona:so_thich_thien_nhien_va_ngoai_troi a owl:Class ;
    rdfs:label "Sở thích thiên nhiên và ngoài trời"@vi ;
    rdfs:comment "Nhóm sở thích gắn với môi trường tự nhiên và các hoạt động ngoài trời.\\nVí dụ thực tế: nuôi chim bồ câu, chăm vườn rau sân thượng, chèo xuồng kênh rạch, câu cá."@vi ;
    rdfs:subClassOf persona:loai_hinh_so_thich .

persona:song_de_cong_hien_cho_xa_hoi a owl:Class ;
    rdfs:label "Sống để cống hiến cho xã hội"@vi ;
    rdfs:comment "Quan niệm ý nghĩa cuộc sống nằm ở việc tạo ra giá trị cho người khác và cộng đồng — sự đóng góp và để lại dấu ấn tích cực là mục tiêu tối thượng."@vi ;
    rdfs:subClassOf persona:quan_niem_y_nghia_cuoc_song .

persona:song_de_nuoi_day_con_cai a owl:Class ;
    rdfs:label "Sống để nuôi dạy con cái"@vi ;
    rdfs:comment "Quan niệm ý nghĩa cuộc sống gắn với việc làm cha mẹ tốt, nuôi dưỡng và định hướng thế hệ tiếp theo — con cái là lý do và động lực sống lớn nhất."@vi ;
    rdfs:subClassOf persona:quan_niem_y_nghia_cuoc_song .

persona:song_de_trai_nghiem_phong_phu a owl:Class ;
    rdfs:label "Sống để trải nghiệm phong phú"@vi ;
    rdfs:comment "Quan niệm ý nghĩa cuộc sống nằm ở việc tích lũy càng nhiều trải nghiệm đa dạng càng tốt — du lịch, gặp gỡ, thử nghiệm cái mới là cách sống đáng giá nhất."@vi ;
    rdfs:subClassOf persona:quan_niem_y_nghia_cuoc_song .

persona:song_de_tu_hoan_thien_ban_than a owl:Class ;
    rdfs:label "Sống để tự hoàn thiện bản thân"@vi ;
    rdfs:comment "Quan niệm ý nghĩa cuộc sống nằm ở hành trình liên tục học hỏi, phát triển và trở thành phiên bản tốt hơn của chính mình."@vi ;
    rdfs:subClassOf persona:quan_niem_y_nghia_cuoc_song .

persona:su_dung_cong_nghe_muc_chuyen_nganh a owl:Class ;
    rdfs:label "Sử dụng công nghệ mức chuyên ngành"@vi ;
    rdfs:comment "Khả năng vận hành phần mềm hoặc thiết bị kỹ thuật số chuyên biệt của một lĩnh vực nghề nghiệp cụ thể — phần mềm thiết kế, hệ thống quản lý y tế, công cụ kỹ thuật số chuyên ngành."@vi ;
    rdfs:subClassOf persona:ky_nang_cong_nghe_va_cong_cu_so .

persona:su_dung_cong_nghe_muc_hanh_chinh a owl:Class ;
    rdfs:label "Sử dụng công nghệ mức hành chính"@vi ;
    rdfs:comment "Khả năng dùng máy tính và các công cụ số cơ bản phục vụ công tác hành chính, văn phòng — soạn thảo văn bản, bảng tính, in ấn, email."@vi ;
    rdfs:subClassOf persona:ky_nang_cong_nghe_va_cong_cu_so .

persona:su_dung_cong_nghe_muc_tieu_dung a owl:Class ;
    rdfs:label "Sử dụng công nghệ mức tiêu dùng"@vi ;
    rdfs:comment "Khả năng dùng điện thoại thông minh và ứng dụng phổ thông trong sinh hoạt hàng ngày — thanh toán, tìm kiếm, mạng xã hội, đặt hàng trực tuyến."@vi ;
    rdfs:subClassOf persona:ky_nang_cong_nghe_va_cong_cu_so .

persona:su_luan_phien_nhom_bai_tap a owl:Class ;
    rdfs:label "Sự luân phiên nhóm bài tập"@vi ;
    rdfs:comment "Cách sắp xếp xen kẽ các nhóm bài tập khác nhau trong lịch để tránh tập quá tải một nhóm cơ và duy trì sự đa dạng.\\nVí dụ: ngày chẵn tập thân trên, ngày lẻ tập thân dưới, cuối tuần tập cardio."@vi ;
    rdfs:subClassOf persona:lich_trinh_tap_luyen .

persona:su_nghiep_la_dong_gop_cho_xa_hoi a owl:Class ;
    rdfs:label "Sự nghiệp là đóng góp cho xã hội"@vi ;
    rdfs:comment "Quan niệm coi công việc là phương tiện tạo ra giá trị cho cộng đồng — ý nghĩa của sự nghiệp nằm ở tác động tích cực để lại cho người khác và xã hội."@vi ;
    rdfs:subClassOf persona:y_nghia_ca_nhan_cua_su_nghiep .

persona:su_nghiep_la_nguon_danh_du_va_ban_sac a owl:Class ;
    rdfs:label "Sự nghiệp là nguồn danh dự và bản sắc"@vi ;
    rdfs:comment "Quan niệm coi công việc là phần cốt lõi tạo nên con người mình — nghề nghiệp gắn liền với danh dự, tự trọng và cách người khác nhìn nhận bản thân."@vi ;
    rdfs:subClassOf persona:y_nghia_ca_nhan_cua_su_nghiep .

persona:su_nghiep_la_phuong_tien_kiem_song a owl:Class ;
    rdfs:label "Sự nghiệp là phương tiện kiếm sống"@vi ;
    rdfs:comment "Quan niệm coi công việc chủ yếu là nguồn thu nhập để đảm bảo cuộc sống — không gắn bản sắc hay ý nghĩa sâu sắc với nghề nghiệp."@vi ;
    rdfs:subClassOf persona:y_nghia_ca_nhan_cua_su_nghiep .

persona:su_truong_thanh_chuyen_mon a owl:Class ;
    rdfs:label "Sự trưởng thành chuyên môn"@vi ;
    rdfs:comment "Mức độ chín chắn và kinh nghiệm được tích lũy theo thời gian giúp cá nhân xử lý tình huống nghề nghiệp một cách điềm tĩnh và hiệu quả hơn.\\nThể hiện qua việc ít bị dao động cảm xúc và đưa ra quyết định ổn định hơn theo năm tháng."@vi ;
    rdfs:subClassOf persona:tinh_nhat_quan_hanh_vi .

persona:su_tuong_tac_va_khuech_dai_nang_luc a owl:Class ;
    rdfs:label "Sự tương tác và khuếch đại năng lực"@vi ;
    rdfs:comment "Hiện tượng các năng lực trong bộ sưu tập củng cố và nhân lên hiệu quả của nhau khi kết hợp.\\nVí dụ thực tế từ dữ liệu: kỹ năng tổ chức sự kiện kết hợp với ngoại ngữ và công nghệ tạo ra giá trị lớn hơn tổng từng kỹ năng riêng lẻ."@vi ;
    rdfs:subClassOf persona:tap_hop_nang_luc .

persona:tac_dong a owl:ObjectProperty ;
    rdfs:label "tac_dong"@vi ;
    rdfs:comment "A làm thay đổi mức độ hoặc trạng thái của B; B vẫn tồn tại độc lập nhưng bị A tác động"@vi .

persona:tac_dong_nhan_thuc_nghe_thuat a owl:Class ;
    rdfs:label "Tác động nhận thức nghệ thuật"@vi ;
    rdfs:comment "Mức độ mà việc tiếp xúc với nghệ thuật thay đổi cách tư duy, mở rộng góc nhìn hoặc thách thức các quan điểm cũ của cá nhân.\\nThể hiện qua việc cá nhân đặt câu hỏi mới, nhìn nhận sự vật khác đi hoặc nhận ra các chiều kích mà trước đó chưa chú ý."@vi ;
    rdfs:subClassOf persona:cach_thuc_nghe_thuat_tac_dong .

persona:tan_suat_cap_nhat_thong_tin_the_thao a owl:Class ;
    rdfs:label "Tần suất cập nhật thông tin thể thao"@vi ;
    rdfs:comment "Số lần cá nhân chủ động tìm hiểu kết quả, lịch thi đấu và tin tức về đội hoặc câu lạc bộ yêu thích trong một đơn vị thời gian.\\nVí dụ thực tế: xem highlights sau mỗi trận, kiểm tra bảng xếp hạng hàng tuần hay chỉ hỏi kết quả khi có ai đề cập."@vi ;
    rdfs:subClassOf persona:muc_do_quan_tam_theo_doi .

persona:tan_suat_chu_dong_tham_gia a owl:Class ;
    rdfs:label "Tần suất chủ động tham gia"@vi ;
    rdfs:comment "Số lần trong tuần hoặc tháng mà cá nhân tự nguyện thực hiện hoạt động thể chất mà không cần ai nhắc nhở hay ép buộc."@vi ;
    rdfs:subClassOf persona:muc_do_hung_thu_van_dong .

persona:tan_suat_tap_trong_lich_trinh a owl:Class ;
    rdfs:label "Tần suất tập trong lịch trình"@vi ;
    rdfs:comment "Số buổi tập được lên kế hoạch trong một tuần hoặc chu kỳ nhất định.\\nVí dụ thực tế từ dữ liệu: tập 3 buổi/tuần xen kẽ ngày nghỉ, tập mỗi ngày với cường độ thay đổi."@vi ;
    rdfs:subClassOf persona:lich_trinh_tap_luyen .

persona:tan_suat_tiep_xuc_dinh_ky a owl:Class ;
    rdfs:label "Tần suất tiếp xúc định kỳ"@vi ;
    rdfs:comment "Mức độ tiếp xúc nghệ thuật diễn ra thường xuyên và đều đặn trong lịch sinh hoạt.\\nVí dụ thực tế: xem phim mỗi tuần, nghe nhạc mỗi ngày."@vi ;
    rdfs:subClassOf persona:tan_suat_tiep_xuc_nghe_thuat .

persona:tan_suat_tiep_xuc_hiem_khi a owl:Class ;
    rdfs:label "Tần suất tiếp xúc hiếm khi"@vi ;
    rdfs:comment "Mức độ tiếp xúc nghệ thuật rất thấp, gần như không chủ động tìm kiếm.\\nVí dụ thực tế: hiếm khi ghé triển lãm, chỉ tiếp xúc nghệ thuật khi được rủ hoặc tình cờ gặp."@vi ;
    rdfs:subClassOf persona:tan_suat_tiep_xuc_nghe_thuat .

persona:tan_suat_tiep_xuc_khong_thuong_xuyen a owl:Class ;
    rdfs:label "Tần suất tiếp xúc không thường xuyên"@vi ;
    rdfs:comment "Mức độ tiếp xúc nghệ thuật xảy ra theo dịp hoặc cảm hứng, không có lịch cố định.\\nVí dụ thực tế: thỉnh thoảng đi xem hòa nhạc khi có chương trình hay."@vi ;
    rdfs:subClassOf persona:tan_suat_tiep_xuc_nghe_thuat .

persona:tang_kich_thuoc_co_bap a owl:Class ;
    rdfs:label "Tăng kích thước cơ bắp"@vi ;
    rdfs:comment "Mục tiêu gia tăng thể tích và khối lượng cơ bắp nhìn thấy được, thường được thực hiện qua tập tạ cường độ trung bình đến cao với số lần nhiều.\\nVí dụ thực tế từ dữ liệu: tập tay để cánh tay to hơn, tập ngực để lồng ngực nở hơn."@vi ;
    rdfs:subClassOf persona:phat_trien_co_bap .

persona:tap_luyen_khang_luc a owl:Class ;
    rdfs:label "Tập luyện kháng lực"@vi ;
    rdfs:comment "Hình thức tập luyện sử dụng lực cản bên ngoài như tạ, dây kháng lực hay trọng lượng cơ thể để kích thích cơ bắp phát triển.\\nVí dụ thực tế từ dữ liệu: tập tạ đòn, tập với dây kháng lực, hít đất, kéo xà."@vi ;
    rdfs:subClassOf persona:phat_trien_co_bap .

persona:ten_mon_the_thao_cu_the a owl:Class ;
    rdfs:label "Tên môn thể thao cụ thể"@vi ;
    rdfs:comment "Hoạt động thể chất có tên gọi và quy tắc xác định mà cá nhân lựa chọn làm môn ưu tiên.\\nVí dụ thực tế từ dữ liệu: bóng đá, cầu lông, bơi lội, đi bộ, bóng bàn, yoga, đạp xe."@vi ;
    rdfs:subClassOf persona:mon_the_thao_yeu_thich .

persona:ten_to_chuc_the_thao_cu_the a owl:Class ;
    rdfs:label "Tên tổ chức thể thao cụ thể"@vi ;
    rdfs:comment "Danh xưng cụ thể của câu lạc bộ, đội tuyển hoặc tổ chức thể thao mà cá nhân dành sự ủng hộ.\\nVí dụ thực tế từ dữ liệu: CLB bóng đá khu phố Nghi Sơn, đội tuyển bóng bàn quận Bình Thạnh."@vi ;
    rdfs:subClassOf persona:to_chuc_the_thao_yeu_thich .

persona:tham_du_su_kien_the_thao_truc_tiep a owl:Class ;
    rdfs:label "Tham dự sự kiện thể thao trực tiếp"@vi ;
    rdfs:comment "Hành động đến xem thi đấu tại sân, trường hoặc địa điểm tổ chức thay vì xem qua màn hình.\\nVí dụ thực tế từ dữ liệu: ra sân cổ vũ đội địa phương dịp cuối tuần, tham dự giải đấu phong trào trong khu phố."@vi ;
    rdfs:subClassOf persona:su_ung_ho_tinh_than .

persona:tham_gia_cau_lac_bo_co_to_chuc a owl:Class ;
    rdfs:label "Tham gia câu lạc bộ có tổ chức"@vi ;
    rdfs:comment "Hình thức tham gia thể thao trong một tổ chức có cấu trúc, lịch tập cố định và người hướng dẫn.\\nVí dụ thực tế từ dữ liệu: đăng ký lớp bơi tại hồ bơi quận, tham gia câu lạc bộ cầu lông khu phố."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tham_gia_the_thao .

persona:tham_gia_cung_ban_be_khong_to_chuc a owl:Class ;
    rdfs:label "Tham gia cùng bạn bè không tổ chức"@vi ;
    rdfs:comment "Hình thức vận động có tính xã hội nhưng không có cấu trúc hay lịch trình cố định, dựa trên sự rủ rê tự phát.\\nVí dụ thực tế từ dữ liệu: rủ nhau đá bóng cuối tuần, cùng bạn đi bơi khi rảnh."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tham_gia_the_thao .

persona:tham_gia_hoat_dong_cong_dong_ban_dia a owl:Class ;
    rdfs:label "Tham gia hoạt động cộng đồng bản địa"@vi ;
    rdfs:comment "Dự lễ hội làng, tham gia sự kiện địa phương hoặc các sinh hoạt tập thể của người dân bản địa để trải nghiệm văn hóa từ bên trong."@vi ;
    rdfs:subClassOf persona:muc_do_hoa_nhap_van_hoa_ban_dia .

persona:tham_gia_to_chuc_su_kien_cong_dong a owl:Class ;
    rdfs:label "Tham gia tổ chức sự kiện cộng đồng"@vi ;
    rdfs:comment "Hành vi chủ động đóng góp vào việc chuẩn bị và tổ chức các hoạt động tập thể — lễ hội làng, đua thuyền, thả đèn hoa đăng — thay vì chỉ tham dự với tư cách khán giả."@vi ;
    rdfs:subClassOf persona:hanh_vi_tham_gia_cong_dong .

persona:thang_tien_vi_tri a owl:Class ;
    rdfs:label "Thăng tiến vị trí"@vi ;
    rdfs:comment "Quá trình di chuyển lên các cấp bậc cao hơn trong hệ thống phân cấp của tổ chức hoặc ngành nghề.\\nVí dụ thực tế từ dữ liệu: từ điều dưỡng viên lên trưởng bộ phận, từ thợ kỹ thuật lên kỹ sư trưởng."@vi ;
    rdfs:subClassOf persona:phat_trien_su_nghiep .

persona:theo_doi_va_co_vu a owl:Class ;
    rdfs:label "Theo dõi và cổ vũ"@vi ;
    rdfs:comment "Hình thức tương tác với thể thao qua việc xem, cổ vũ cho các vận động viên hay đội tuyển mà không trực tiếp thi đấu.\\nVí dụ thực tế từ dữ liệu: xem bóng đá trên tivi, đến sân cổ vũ đội địa phương."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tham_gia_the_thao .

persona:thi_dau_chinh_thuc a owl:Class ;
    rdfs:label "Thi đấu chính thức"@vi ;
    rdfs:comment "Hình thức tham gia thể thao trong các cuộc tranh tài có quy tắc, trọng tài và kết quả chính thức được ghi nhận.\\nVí dụ thực tế từ dữ liệu: tham gia giải bóng đá phong trào cấp quận, thi bơi lội trong hội thao công ty."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tham_gia_the_thao .

persona:thiet_bi_bep_hien_dai a owl:Class ;
    rdfs:label "Thiết bị bếp hiện đại"@vi ;
    rdfs:comment "Các thiết bị nấu ăn điện tử và công nghệ cao — lò nướng, nồi áp suất điện, máy xay sinh tố, lò vi sóng, bếp từ."@vi ;
    rdfs:subClassOf persona:thiet_bi_va_dung_cu_nau_an_su_dung .

persona:thoi_diem_an_uong_trong_ngay a owl:Class ;
    rdfs:label "Thời điểm ăn uống trong ngày"@vi ;
    rdfs:comment "Giờ giấc và sự phân bổ các bữa ăn trong ngày được lên kế hoạch để hỗ trợ quá trình tập luyện và phục hồi.\\nVí dụ thực tế từ dữ liệu: ăn nhẹ trước tập 1 tiếng, ăn protein ngay sau tập, tránh ăn khuya."@vi ;
    rdfs:subClassOf persona:thoi_quen_dinh_duong .

persona:thoi_luong_moi_buoi_tap a owl:Class ;
    rdfs:label "Thời lượng mỗi buổi tập"@vi ;
    rdfs:comment "Số phút hoặc giờ dành cho một buổi tập luyện từ khởi động đến giãn cơ.\\nVí dụ thực tế từ dữ liệu: 30 phút đi bộ buổi sáng, 90 phút đá bóng cuối tuần, 45 phút bơi lội chiều tối."@vi ;
    rdfs:subClassOf persona:lich_trinh_tap_luyen .

persona:thu_gian_qua_van_dong a owl:Class ;
    rdfs:label "Thư giãn qua vận động"@vi ;
    rdfs:comment "Trạng thái thả lỏng thể chất và tinh thần đạt được khi cơ thể chuyển động nhẹ nhàng sau giờ làm việc căng thẳng.\\nVí dụ thực tế từ dữ liệu: đi bộ buổi chiều để xả hơi, bơi lội để quên chuyện công việc."@vi ;
    rdfs:subClassOf persona:muc_dich_giai_tri_tinh_than .

persona:thu_tu_uu_tien_gia_tri a owl:Class ;
    rdfs:label "Thứ tự ưu tiên giá trị"@vi ;
    persona:tac_dong persona:muc_do_dau_tu_vao_so_thich ;
    rdfs:comment "Sự sắp xếp có thứ bậc giữa các giá trị sống khi chúng xung đột với nhau trong một tình huống cụ thể.\\nVí dụ thực tế: khi phải chọn giữa sự nghiệp và gia đình, cá nhân luôn ưu tiên điều nào trước — thể hiện giá trị nào được đặt cao hơn."@vi ;
    rdfs:subClassOf persona:gia_tri_cot_loi .

persona:thu_tu_uu_tien_nhiem_vu a owl:Class ;
    rdfs:label "Thứ tự ưu tiên nhiệm vụ"@vi ;
    rdfs:comment "Cách cá nhân xếp hạng và quyết định làm việc gì trước khi có nhiều nhiệm vụ cùng lúc.\\nVí dụ thực tế từ dữ liệu: ưu tiên ca bệnh nặng trước, giải quyết hàng sắp hết trước khi nhập hàng mới, hoàn thành hạng mục cốt lõi trước hạng mục phụ."@vi ;
    rdfs:subClassOf persona:thoi_quen_lam_viec .

persona:thu_tu_xep_hang_hoat_dong_the_chat a owl:Class ;
    rdfs:label "Thứ tự xếp hạng hoạt động thể chất"@vi ;
    rdfs:comment "Cách cá nhân sắp xếp ưu tiên giữa các loại hình vận động khi phải lựa chọn trong điều kiện thời gian và sức lực có hạn."@vi ;
    rdfs:subClassOf persona:su_uu_tien_van_dong .

persona:thuc_day a owl:ObjectProperty ;
    rdfs:label "thuc_day"@vi ;
    rdfs:comment "A kích hoạt hoặc tạo động lực cho B xuất hiện hoặc tăng lên; mang tính chủ động từ phía A"@vi .

persona:tich_luy_chuyen_mon_chinh a owl:Class ;
    rdfs:label "Tích lũy chuyên môn chính"@vi ;
    rdfs:comment "Quá trình xây dựng và làm sâu sắc thêm năng lực trong một ngành nghề cụ thể theo thời gian gắn bó.\\nPhản ánh ngành nghề không chỉ là nơi kiếm tiền mà còn là nơi cá nhân đầu tư phát triển năng lực lâu dài."@vi ;
    rdfs:subClassOf persona:nganh_nghe .

persona:tiep_can_cuoc_song_bi_dong a owl:Class ;
    rdfs:label "Tiếp cận cuộc sống bị động"@vi ;
    rdfs:comment "Xu hướng để hoàn cảnh và người khác định hướng — chờ cơ hội đến thay vì chủ động tạo ra, và có xu hướng đổ trách nhiệm kết quả cho yếu tố bên ngoài."@vi ;
    rdfs:subClassOf persona:muc_do_chu_dong_voi_bi_dong .

persona:tiep_can_cuoc_song_chu_dong a owl:Class ;
    rdfs:label "Tiếp cận cuộc sống chủ động"@vi ;
    rdfs:comment "Xu hướng tự tạo cơ hội, chủ động đưa ra quyết định và chịu trách nhiệm về kết quả — không chờ hoàn cảnh dẫn dắt."@vi ;
    rdfs:subClassOf persona:muc_do_chu_dong_voi_bi_dong .

persona:tiep_nhan_nghe_thuat_qua_loa a owl:Class ;
    rdfs:label "Tiếp nhận nghệ thuật qua loa"@vi ;
    rdfs:comment "Cách thưởng thức bề mặt, không chú ý đến chi tiết kỹ thuật hay thông điệp ẩn.\\nNghệ thuật chỉ là nền hoặc giải trí thoáng qua, không để lại dấu ấn nhận thức."@vi ;
    rdfs:subClassOf persona:muc_do_chu_tam_nghe_thuat .

persona:tieu_chi_danh_gia_thanh_cong_noi_bo a owl:Class ;
    rdfs:label "Tiêu chí đánh giá thành công nội bộ"@vi ;
    rdfs:comment "Thước đo mà tổ chức dùng để xác định ai đang làm tốt và điều gì được coi là thành tích đáng khen ngợi.\\nVí dụ thực tế từ dữ liệu: không để xảy ra sự cố y tế là thành công trong bệnh viện, doanh thu tăng là thành công với tiệm tạp hóa, \\ngiao công trình đúng hạn là thành công với đội xây dựng."@vi ;
    rdfs:subClassOf persona:van_hoa_doanh_nghiep .

persona:tieu_chuan_ca_nhan_ve_hinh_the a owl:Class ;
    rdfs:label "Tiêu chuẩn cá nhân về hình thể"@vi ;
    rdfs:comment "Hình mẫu vóc dáng lý tưởng mà cá nhân tự đặt ra làm mục tiêu hướng đến, xuất phát từ quan niệm thẩm mỹ riêng.\\nPhân biệt với tiêu chuẩn y tế ở chỗ được xác định bởi sở thích và văn hóa cá nhân hơn là chỉ số sức khỏe."@vi ;
    rdfs:subClassOf persona:hoat_dong_the_chat_giu_voc_dang .

persona:tieu_chuan_fine_dining_cao_cap a owl:Class ;
    rdfs:label "Tiêu chuẩn fine-dining cao cấp"@vi ;
    rdfs:comment "Ưu tiên trải nghiệm ẩm thực cao cấp với không gian sang trọng, dịch vụ chuyên nghiệp và thực đơn được chăm chút tỉ mỉ về kỹ thuật và thẩm mỹ."@vi ;
    rdfs:subClassOf persona:tieu_chuan_lua_chon_quan_an .

persona:tieu_chuan_quan_via_he_binh_dan a owl:Class ;
    rdfs:label "Tiêu chuẩn quán vỉa hè bình dân"@vi ;
    rdfs:comment "Ưu tiên chọn quán ăn đường phố, hàng chợ hoặc quán bình dân đúng chất địa phương — coi trọng vị thật hơn không gian sang trọng."@vi ;
    rdfs:subClassOf persona:tieu_chuan_lua_chon_quan_an .

persona:tieu_chuan_sach_se_tien_nghi a owl:Class ;
    rdfs:label "Tiêu chuẩn sạch sẽ tiện nghi"@vi ;
    rdfs:comment "Ưu tiên chọn quán ăn đảm bảo vệ sinh, không gian thoải mái có điều hòa — cân bằng giữa chất lượng món ăn và điều kiện ăn uống dễ chịu."@vi ;
    rdfs:subClassOf persona:tieu_chuan_lua_chon_quan_an .

persona:tim_kiem_niem_vui_qua_the_thao a owl:Class ;
    rdfs:label "Tìm kiếm niềm vui qua thể thao"@vi ;
    rdfs:comment "Động lực tham gia vận động thuần túy vì cảm giác thích thú và vui vẻ mà hoạt động đó mang lại.\\nVí dụ thực tế từ dữ liệu: chơi cầu lông cùng bạn bè vì vui, nhảy truyền thống vào sáng Chủ Nhật vì thích."@vi ;
    rdfs:subClassOf persona:muc_dich_giai_tri_tinh_than .

persona:tin_so_phan_kho_thay_doi a owl:Class ;
    rdfs:label "Tin số phận khó thay đổi"@vi ;
    rdfs:comment "Quan điểm rằng hoàn cảnh xuất phát điểm, số phận hoặc bản chất con người là bất biến hoặc rất khó thay đổi dù có cố gắng."@vi ;
    rdfs:subClassOf persona:niem_tin_ve_su_thay_doi .

persona:tin_vao_kha_nang_thay_doi a owl:Class ;
    rdfs:label "Tin vào khả năng thay đổi"@vi ;
    rdfs:comment "Quan điểm rằng con người và hoàn cảnh có thể cải thiện nếu có nỗ lực và chiến lược đúng đắn — không có gì là cố định vĩnh viễn."@vi ;
    rdfs:subClassOf persona:niem_tin_ve_su_thay_doi .

persona:tinh_chat_ca_nhan_hay_dong_doi a owl:Class ;
    rdfs:label "Tính chất cá nhân hay đồng đội"@vi ;
    rdfs:comment "Thiên hướng của cá nhân trong việc lựa chọn vận động một mình hay cùng tập thể."@vi ;
    rdfs:subClassOf persona:thien_huong_loai_hinh_van_dong .

persona:tinh_do_luong_va_kiem_dinh_duoc a owl:Class ;
    rdfs:label "Tính đo lường và kiểm định được"@vi ;
    rdfs:comment "Đặc điểm của kỹ năng kỹ thuật cho phép đánh giá mức độ thành thục một cách khách quan và có thể chứng minh.\\nVí dụ thực tế từ dữ liệu: chứng chỉ điều dưỡng, bằng kỹ sư cơ khí, kết quả kiểm tra tay nghề làm bánh."@vi ;
    rdfs:subClassOf persona:nang_luc_ky_thuat .

persona:tinh_khong_the_thieu a owl:Class ;
    rdfs:label "Tính không thể thiếu"@vi ;
    rdfs:comment "Mức độ mà một kỹ năng là điều kiện bắt buộc để công việc có thể được thực hiện hay không.\\nVí dụ thực tế từ dữ liệu: điều dưỡng bắt buộc phải biết đọc điện tâm đồ, thợ xây bắt buộc phải biết đọc bản vẽ kỹ thuật."@vi ;
    rdfs:subClassOf persona:vai_tro_quyet_dinh_trong_cong_viec .

persona:toc_do_hoan_thanh_cong_viec a owl:Class ;
    rdfs:label "Tốc độ hoàn thành công việc"@vi ;
    rdfs:comment "Thời gian thực tế cần để hoàn thành một nhiệm vụ so với mức kỳ vọng hoặc tiêu chuẩn ngành.\\nĐo lường khả năng làm việc nhanh mà không đánh đổi chất lượng."@vi ;
    rdfs:subClassOf persona:hieu_qua_thuc_hien_cong_viec .

persona:toc_do_xu_ly_cong_viec a owl:Class ;
    rdfs:label "Tốc độ xử lý công việc"@vi ;
    rdfs:comment "Thời gian cần thiết để cá nhân hoàn thành một thao tác hoặc nhiệm vụ nhất định ở mức chất lượng chấp nhận được.\\nVí dụ thực tế từ dữ liệu: phục vụ nhiều khách trong giờ cao điểm, xử lý nhanh ca bệnh cấp cứu, làm xong mẻ bánh kịp giờ chợ sáng."@vi ;
    rdfs:subClassOf persona:ky_nang_thuc_hanh_nghe_nghiep .

persona:trat_tu_va_logic_sap_xep_bai_tap a owl:Class ;
    rdfs:label "Trật tự và logic sắp xếp bài tập"@vi ;
    rdfs:comment "Nguyên tắc xếp thứ tự các bài tập để chúng bổ trợ và kế thừa nhau, tránh mâu thuẫn hoặc gây chấn thương.\\nVí dụ thực tế: khởi động trước khi tập nặng, tập cơ lớn trước cơ nhỏ, giãn cơ sau tập."@vi ;
    rdfs:subClassOf persona:he_thong_bai_tap .

persona:tri_thuc_ly_thuyet_chuyen_nganh a owl:Class ;
    rdfs:label "Tri thức lý thuyết chuyên ngành"@vi ;
    rdfs:comment "Hệ thống khái niệm, mô hình và lý luận nền tảng của một ngành được học qua đào tạo chính quy hoặc tự nghiên cứu.\\nVí dụ thực tế từ dữ liệu: kiến thức sinh lý và dược lý của điều dưỡng, lý thuyết cơ học và vật liệu của kỹ sư xây dựng."@vi ;
    rdfs:subClassOf persona:kien_thuc_chuyen_nganh .

persona:trinh_do_ban_chuyen a owl:Class ;
    rdfs:label "Trình độ bán chuyên"@vi ;
    rdfs:comment "Mức kỹ năng có nền tảng kỹ thuật rõ ràng, đã đầu tư thời gian học tập bài bản, tạo ra sản phẩm có chất lượng nhưng chưa hoạt động chuyên nghiệp toàn thời gian."@vi ;
    rdfs:subClassOf persona:muc_do_thuan_thuc_sang_tao .

persona:trinh_do_chuyen_nghiep a owl:Class ;
    rdfs:label "Trình độ chuyên nghiệp"@vi ;
    rdfs:comment "Mức kỹ năng đủ để biểu diễn, triển lãm hoặc xuất bản công khai và nhận thù lao.\\nHoạt động nghệ thuật gắn với danh tiếng hoặc thu nhập chính thức."@vi ;
    rdfs:subClassOf persona:muc_do_thuan_thuc_sang_tao .

persona:trinh_do_nghiep_du a owl:Class ;
    rdfs:label "Trình độ nghiệp dư"@vi ;
    rdfs:comment "Mức kỹ năng ban đầu, thực hành nghệ thuật để vui hoặc khám phá sở thích, chưa có nền tảng kỹ thuật hệ thống.\\nSản phẩm chủ yếu để tự thưởng thức hoặc chia sẻ trong vòng bạn bè."@vi ;
    rdfs:subClassOf persona:muc_do_thuan_thuc_sang_tao .

persona:trinh_tu_tu_duy_xu_ly a owl:Class ;
    rdfs:label "Trình tự tư duy xử lý"@vi ;
    rdfs:comment "Thứ tự các bước nhận thức mà cá nhân đi qua khi đối mặt với một vấn đề: nhận diện vấn đề, phân tích nguyên nhân, đánh giá lựa chọn, ra quyết định.\\nPhản ánh cách não bộ cá nhân xử lý thông tin trước khi hành động."@vi ;
    rdfs:subClassOf persona:phuong_phap_xu_ly_van_de .

persona:trung_thanh_am_thuc_viet a owl:Class ;
    rdfs:label "Trung thành ẩm thực Việt"@vi ;
    rdfs:comment "Thiên hướng gắn bó với ẩm thực Việt Nam và ít quan tâm đến ẩm thực nước ngoài — coi món Việt là tiêu chuẩn và cảm thấy thỏa mãn nhất với hương vị quen thuộc từ nhỏ."@vi ;
    rdfs:subClassOf persona:su_coi_mo_voi_am_thuc_quoc_te .

persona:trung_thanh_bat_ke_ket_qua a owl:Class ;
    rdfs:label "Trung thành bất kể kết quả"@vi ;
    rdfs:comment "Đặc tính duy trì sự ủng hộ liên tục với đội yêu thích kể cả khi đội thua liên tiếp hay đang ở giai đoạn khó khăn.\\nPhân biệt người hâm mộ trung thành với người chỉ ủng hộ khi đội thắng."@vi ;
    rdfs:subClassOf persona:su_ung_ho_tinh_than .

persona:truyen_day_ky_nang_van_hoa_cho_the_he_sau a owl:Class ;
    rdfs:label "Truyền dạy kỹ năng văn hóa cho thế hệ sau"@vi ;
    rdfs:comment "Hành vi chủ động chia sẻ và truyền dạy các kỹ năng, nghề truyền thống hoặc giá trị văn hóa cho thế hệ trẻ hơn — dạy làm bánh, dạy múa quan họ, dạy làm đèn hoa đăng."@vi ;
    rdfs:subClassOf persona:hanh_vi_tham_gia_cong_dong .

persona:tu_duy_phan_tich_trong_cong_viec a owl:Class ;
    rdfs:label "Tư duy phân tích trong công việc"@vi ;
    rdfs:comment "Khuynh hướng tách vấn đề ra thành các thành phần nhỏ, tìm nguyên nhân gốc rễ và đánh giá logic trước khi hành động.\\nThường thấy ở những người được đào tạo bài bản hoặc có kinh nghiệm xử lý nhiều tình huống phức tạp."@vi ;
    rdfs:subClassOf persona:phuong_phap_xu_ly_van_de .

persona:tu_hao_ban_sac_van_hoa_cao a owl:Class ;
    rdfs:label "Tự hào bản sắc văn hóa cao"@vi ;
    rdfs:comment "Cảm giác gắn kết mạnh mẽ và tự hào sâu sắc với văn hóa, vùng miền và truyền thống gốc — chủ động gìn giữ, truyền dạy và quảng bá bản sắc đó cho thế hệ sau."@vi ;
    rdfs:subClassOf persona:muc_do_tu_hao_ban_sac_van_hoa .

persona:tu_hao_ban_sac_van_hoa_vua_phai a owl:Class ;
    rdfs:label "Tự hào bản sắc văn hóa vừa phải"@vi ;
    rdfs:comment "Cảm giác gắn bó với văn hóa gốc ở mức độ vừa phải — trân trọng nhưng không đặt bản sắc văn hóa làm trung tâm của mọi lựa chọn sống."@vi ;
    rdfs:subClassOf persona:muc_do_tu_hao_ban_sac_van_hoa .

persona:tu_may_mo_thu_nghiem a owl:Class ;
    rdfs:label "Tự mày mò thử nghiệm"@vi ;
    rdfs:comment "Tích lũy kinh nghiệm bằng cách tự khám phá, thử sai và rút ra bài học mà không có người hướng dẫn trực tiếp — phụ thuộc vào sự kiên trì và trực giác cá nhân."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tich_luy_kinh_nghiem .

persona:tu_nhan_co_su_menh_rieng a owl:Class ;
    rdfs:label "Tự nhận có sứ mệnh riêng"@vi ;
    rdfs:comment "Cảm nhận bản thân có mục tiêu hoặc vai trò độc đáo cần hoàn thành — không chỉ là một phần của đám đông mà có đóng góp riêng biệt và không thể thay thế."@vi ;
    rdfs:subClassOf persona:vi_tri_ca_nhan_trong_the_gioi .

persona:tu_nhan_la_mot_phan_cong_dong a owl:Class ;
    rdfs:label "Tự nhận là một phần cộng đồng"@vi ;
    rdfs:comment "Cảm nhận bản thân là mắt xích trong một tập thể — gia đình, làng xóm, xã hội — và ý nghĩa của mình gắn liền với sự đóng góp cho cộng đồng đó."@vi ;
    rdfs:subClassOf persona:vi_tri_ca_nhan_trong_the_gioi .

persona:tu_tap_ca_nhan a owl:Class ;
    rdfs:label "Tự tập cá nhân"@vi ;
    rdfs:comment "Hình thức vận động mà cá nhân tự thực hiện một mình không có người hướng dẫn hay cùng tập.\\nVí dụ thực tế từ dữ liệu: tự đi bộ buổi sáng, tự chạy bộ trong công viên, tự tập bài yoga ở nhà."@vi ;
    rdfs:subClassOf persona:hinh_thuc_tham_gia_the_thao .

persona:tu_tuc_tu_dat_tung_hang_muc a owl:Class ;
    rdfs:label "Tự túc tự đặt từng hạng mục"@vi ;
    rdfs:comment "Tự lên kế hoạch và đặt riêng lẻ vé, phòng, phương tiện mà không qua công ty lữ hành — phản ánh nhu cầu kiểm soát và chủ động cao."@vi ;
    rdfs:subClassOf persona:hinh_thuc_to_chuc_hanh_trinh .

persona:tuong_quan a owl:ObjectProperty ;
    rdfs:label "tuong_quan"@vi ;
    rdfs:comment "A và B thường xuất hiện cùng nhau hoặc thay đổi cùng chiều; không xác định được chiều nhân quả"@vi .

persona:ty_le_co_the_mong_muon a owl:Class ;
    rdfs:label "Tỷ lệ cơ thể mong muốn"@vi ;
    rdfs:comment "Hình thể lý tưởng mà cá nhân hướng đến thể hiện qua tỷ lệ giữa các phần cơ thể theo tiêu chuẩn thẩm mỹ riêng.\\nVí dụ thực tế từ dữ liệu: muốn thon vòng eo, muốn cánh tay săn chắc, muốn bụng phẳng."@vi ;
    rdfs:subClassOf persona:muc_dich_giu_voc_dang .

persona:ty_le_co_xuong a owl:Class ;
    rdfs:label "Tỷ lệ cơ xương"@vi ;
    rdfs:comment "Phần trăm khối lượng cơ và xương so với tổng khối lượng cơ thể, phản ánh mức độ phát triển cơ bắp và mật độ xương.\\nChỉ số quan trọng với người tập tạ muốn đánh giá hiệu quả tăng cơ thực sự."@vi ;
    rdfs:subClassOf persona:chi_so_hinh_the .

persona:ty_le_mo_co_the a owl:Class ;
    rdfs:label "Tỷ lệ mỡ cơ thể"@vi ;
    rdfs:comment "Phần trăm khối lượng mỡ so với tổng trọng lượng cơ thể, là chỉ số phản ánh thành phần cơ thể chính xác hơn cân nặng đơn thuần.\\nVí dụ thực tế: vận động viên nặng 70kg có thể chỉ có 10% mỡ, trong khi người ít tập cùng cân nặng có thể có 25% mỡ."@vi ;
    rdfs:subClassOf persona:chi_so_hinh_the .

persona:ty_le_phan_bo_nguon_luc a owl:Class ;
    rdfs:label "Tỷ lệ phân bổ nguồn lực"@vi ;
    rdfs:comment "Phần trăm thời gian, công sức và tiền bạc mà cá nhân dành cho nghề nghiệp chính so với các hoạt động khác trong cuộc sống.\\nVí dụ thực tế từ dữ liệu: nông dân dành gần như toàn bộ ngày làm đồng, công nhân làm ca cố định 8 tiếng rồi về."@vi ;
    rdfs:subClassOf persona:muc_do_dau_tu_thoi_gian_va_nguon_luc .

persona:uu_tien_diem_den_do_thi a owl:Class ;
    rdfs:label "Ưu tiên điểm đến đô thị"@vi ;
    rdfs:comment "Xu hướng chọn thành phố sầm uất với bảo tàng, kiến trúc, ẩm thực đường phố và đời sống văn hóa đa dạng.\\nVí dụ thực tế: thích Hà Nội cổ kính, Sài Gòn năng động, Tokyo hiện đại hơn các vùng nông thôn yên tĩnh."@vi ;
    rdfs:subClassOf persona:so_thich_diem_den .

persona:uu_tien_diem_den_lich_su_van_hoa a owl:Class ;
    rdfs:label "Ưu tiên điểm đến lịch sử văn hóa"@vi ;
    rdfs:comment "Xu hướng đặc biệt quan tâm đến các địa điểm có giá trị di sản, lịch sử hoặc bản sắc văn hóa đặc trưng.\\nVí dụ thực tế: phố cổ Hội An, thánh địa Mỹ Sơn, các làng nghề truyền thống."@vi ;
    rdfs:subClassOf persona:so_thich_diem_den .

persona:uu_tien_diem_den_thien_nhien a owl:Class ;
    rdfs:label "Ưu tiên điểm đến thiên nhiên"@vi ;
    rdfs:comment "Xu hướng chọn địa điểm gắn với môi trường tự nhiên — biển, núi, rừng, hồ — thay cho đô thị hay khu du lịch nhân tạo."@vi ;
    rdfs:subClassOf persona:so_thich_diem_den .

persona:uu_tien_hon a owl:ObjectProperty ;
    rdfs:label "uu_tien_hon"@vi ;
    rdfs:comment "Khi A và B xung đột trong quá trình tóm tắt, A được ưu tiên hơn B; dùng để biểu diễn quan hệ HARD > SOFT"@vi .

persona:uu_tien_vi_cay a owl:Class ;
    rdfs:label "Ưu tiên vị cay"@vi ;
    rdfs:comment "Thiên hướng tìm kiếm và cảm thấy thỏa mãn với độ cay nồng trong món ăn — từ cay nhẹ đến cay mạnh kích thích."@vi ;
    rdfs:subClassOf persona:vi_uu_tien_ca_nhan .

persona:uu_tien_vi_ngot a owl:Class ;
    rdfs:label "Ưu tiên vị ngọt"@vi ;
    rdfs:comment "Thiên hướng tìm kiếm và cảm thấy thỏa mãn với hương vị ngọt trong bữa ăn — từ ngọt thanh tự nhiên đến ngọt đậm từ đường hoặc nước cốt."@vi ;
    rdfs:subClassOf persona:vi_uu_tien_ca_nhan .

persona:uu_tien_vi_thanh_nhat a owl:Class ;
    rdfs:label "Ưu tiên vị thanh nhạt"@vi ;
    rdfs:comment "Thiên hướng ưa hương vị nhẹ nhàng, không đậm đà — thích cảm nhận vị tự nhiên của nguyên liệu hơn là gia vị nổi bật."@vi ;
    rdfs:subClassOf persona:vi_uu_tien_ca_nhan .

persona:uu_tien_vi_umami_dam_da a owl:Class ;
    rdfs:label "Ưu tiên vị umami đậm đà"@vi ;
    rdfs:comment "Thiên hướng tìm kiếm vị savory sâu, béo ngậy hoặc đậm đà từ nước hầm xương, mắm, tương, pho mát hoặc nấm."@vi ;
    rdfs:subClassOf persona:vi_uu_tien_ca_nhan .

persona:vai_tro_chu_dong_sang_tao a owl:Class ;
    rdfs:label "Vai trò chủ động sáng tạo"@vi ;
    rdfs:comment "Vị trí trực tiếp tạo ra hoặc biểu diễn tác phẩm nghệ thuật.\\nVí dụ thực tế: họa sĩ vẽ tranh, nhạc công chơi đàn, diễn viên biểu diễn, nhà văn viết truyện."@vi ;
    rdfs:subClassOf persona:vai_tro_tiep_nhan_nghe_thuat .

persona:vai_tro_thu_dong_khan_gia a owl:Class ;
    rdfs:label "Vai trò thụ động khán giả"@vi ;
    rdfs:comment "Vị trí tiếp nhận nghệ thuật một chiều: xem, nghe, đọc mà không tham gia vào quá trình sản xuất.\\nVí dụ thực tế: khán giả xem phim, người nghe nhạc, độc giả đọc sách."@vi ;
    rdfs:subClassOf persona:vai_tro_tiep_nhan_nghe_thuat .

persona:vi_giac_nhay_cam_cao a owl:Class ;
    rdfs:label "Vị giác nhạy cảm cao"@vi ;
    rdfs:comment "Hệ thống cảm giác phát hiện và phản ứng mạnh với các kích thích vị giác tinh tế.\\nCá nhân dễ nhận ra sự khác biệt nhỏ giữa các vị, dễ bị ảnh hưởng bởi hương vị lạ hoặc quá đậm."@vi ;
    rdfs:subClassOf persona:do_nhay_cam_vi_giac .

persona:vi_tri_nghe_nghiep a owl:Class ;
    rdfs:label "Vị trí nghề nghiệp"@vi ;
    rdfs:comment "Chức danh, cấp bậc hoặc vai trò chính thức mà cá nhân đang đảm nhận trong tổ chức hoặc ngành nghề.\\nVí dụ thực tế từ dữ liệu: điều dưỡng viên, kỹ sư cơ khí, chủ tiệm tạp hóa, quản lý dự án cộng đồng."@vi ;
    rdfs:subClassOf persona:phat_trien_su_nghiep .

persona:vong_eo a owl:Class ;
    rdfs:label "Vòng eo"@vi ;
    rdfs:comment "Chu vi đo tại phần eo nhỏ nhất của cơ thể, phản ánh lượng mỡ nội tạng và là chỉ số thẩm mỹ được nhiều người theo dõi.\\nVí dụ thực tế từ dữ liệu: mục tiêu giữ vòng eo dưới 70cm, đo vòng eo hàng tháng để theo dõi tiến độ."@vi ;
    rdfs:subClassOf persona:chi_so_hinh_the .

persona:xu_huong_bi_quan a owl:Class ;
    rdfs:label "Xu hướng bi quan"@vi ;
    rdfs:comment "Thiên hướng coi trọng rủi ro và chuẩn bị tinh thần cho tình huống xấu nhất — có xu hướng nhìn nhận sự kiện theo chiều hướng tiêu cực hoặc đề phòng."@vi ;
    rdfs:subClassOf persona:xu_huong_lac_quan_voi_bi_quan .

persona:xu_huong_lac_quan a owl:Class ;
    rdfs:label "Xu hướng lạc quan"@vi ;
    rdfs:comment "Thiên hướng mặc định kỳ vọng kết quả tốt và nhìn nhận sự kiện theo hướng tích cực — tập trung vào cơ hội hơn là rủi ro."@vi ;
    rdfs:subClassOf persona:xu_huong_lac_quan_voi_bi_quan .

persona:xuat_than_gia_dinh_lao_dong a owl:Class ;
    rdfs:label "Xuất thân gia đình lao động"@vi ;
    rdfs:comment "Gia đình gốc làm các nghề lao động chân tay hoặc dịch vụ phổ thông — công nhân, nông dân, thợ thủ công.\\nTác động đến định hướng nghề nghiệp, kỳ vọng học vấn và thái độ với công việc tay chân của cá nhân."@vi ;
    rdfs:subClassOf persona:moi_truong_kinh_te_xa_hoi_xuat_than .

persona:xuat_than_gia_dinh_tieu_thuong a owl:Class ;
    rdfs:label "Xuất thân gia đình tiểu thương"@vi ;
    rdfs:comment "Gia đình gốc hoạt động buôn bán nhỏ lẻ — tiệm tạp hóa, hàng chợ, dịch vụ gia đình.\\nThường hình thành sớm tư duy kinh doanh, quản lý tài chính và ý thức phục vụ khách hàng từ nhỏ."@vi ;
    rdfs:subClassOf persona:moi_truong_kinh_te_xa_hoi_xuat_than .

persona:xuat_than_gia_dinh_tri_thuc a owl:Class ;
    rdfs:label "Xuất thân gia đình tri thức"@vi ;
    rdfs:comment "Gia đình gốc có truyền thống học vấn cao — giáo viên, bác sĩ, kỹ sư, công chức.\\nThường tạo ra môi trường coi trọng bằng cấp, đọc sách và định hướng con cái vào các ngành nghề chuyên môn."@vi ;
    rdfs:subClassOf persona:moi_truong_kinh_te_xa_hoi_xuat_than .

persona:zone a owl:Class ;
    rdfs:label "zone"@vi ;
    rdfs:comment "Khu vực cư trú: Đô Thị, Nông Thôn."@vi .

persona:cach_bieu_dat_ngon_ngu_va_giao_tiep_van_hoa a owl:Class ;
    rdfs:label "Cách biểu đạt ngôn ngữ và giao tiếp văn hóa"@vi ;
    rdfs:comment "Phong cách ngôn ngữ, cách xưng hô, thành ngữ địa phương và cách diễn đạt đặc trưng của vùng miền mà cá nhân sử dụng trong giao tiếp hàng ngày.\\nVí dụ thực tế: dùng từ địa phương Hải Phòng, cách gọi tên thân mật theo kiểu Sài Gòn, văn hóa kể chuyện vòng vèo của người Bắc."@vi ;
    rdfs:subClassOf persona:hanh_vi_ca_nhan_van_hoa .

persona:di_san_nghe_thuat_va_am_nhac_truyen_thong a owl:Class ;
    rdfs:label "Di sản nghệ thuật và âm nhạc truyền thống"@vi ;
    persona:cung_co persona:muc_do_quan_tam_am_thuc_truyen_thong ;
    persona:dinh_hinh persona:loai_hinh_nghe_thuat_thuc_hanh ;
    rdfs:comment "Các loại hình nghệ thuật và âm nhạc dân gian của vùng miền mà cá nhân được tiếp xúc từ thời thơ ấu và gắn với bản sắc văn hóa gốc.\\nVí dụ thực tế từ dữ liệu: hát chèo, cải lương, hát quan họ, hát xẩm, múa quan họ tại sân đình."@vi ;
    rdfs:subClassOf persona:nguon_goc_hoac_nen_tang_van_hoa .

persona:do_nhay_cam_vi_giac a owl:Class ;
    rdfs:label "Độ nhạy cảm vị giác"@vi ;
    rdfs:comment "Mức độ mà hệ thống cảm giác của một cá nhân phát hiện và phản ứng với các kích thích vị giác.\\nNgười nhạy cảm cao dễ nhận ra sự khác biệt tinh tế giữa các vị, trong khi người ít nhạy cảm hơn chấp nhận đa dạng hương vị mà không có phản ứng mạnh."@vi ;
    rdfs:subClassOf persona:khau_vi_ca_nhan .

persona:hinh_anh_phong_cach_song_dac_trung a owl:Class ;
    rdfs:label "Hình ảnh phong cách sống đặc trưng"@vi ;
    persona:dinh_hinh persona:phong_cach_dich_chuyen ;
    rdfs:comment "Chi tiết sinh động, mang tính hình ảnh cao thể hiện nét đặc trưng trong lối sống của cá nhân.\\nVí dụ thực tế từ dữ liệu: 'mỗi sáng Chủ Nhật cùng nhóm khiêu vũ truyền thống tại công viên', 'ngồi chèo xuồng kênh rạch Cần Thơ vào chiều tà', 'ngồi uống nước đá chanh vỉa hè nghe cải lương'."@vi ;
    rdfs:subClassOf persona:doan_van_ban_tu_su_phong_cach_song .

persona:hoat_dong_giai_tri_khi_du_lich a owl:Class ;
    rdfs:label "Hoạt động giải trí khi du lịch"@vi ;
    persona:tuong_quan persona:hanh_vi_chia_se_am_thuc ;
    rdfs:comment "Các việc làm mang tính thư giãn và vui chơi được thực hiện trong thời gian đi du lịch.\\nVí dụ thực tế: tắm biển, leo núi, tham gia lễ hội địa phương, mua sắm tại chợ truyền thống."@vi ;
    rdfs:subClassOf persona:hoat_dong_hanh_trinh_hoac_lu_hanh .

persona:ket_qua_do_luong_duoc_tu_kinh_nghiem a owl:Class ;
    rdfs:label "Kết quả đo lường được từ kinh nghiệm"@vi ;
    persona:cung_co persona:dong_luc_phat_trien_su_nghiep ;
    persona:tuong_quan persona:hieu_qua_thuc_hien_cong_viec ;
    rdfs:comment "Các thành phẩm, năng lực hoặc thành tích cụ thể có thể quan sát được, là bằng chứng của quá trình tích lũy kinh nghiệm.\\nVí dụ thực tế từ dữ liệu: nấu phở chuẩn vị Hà Nội, làm được bánh cuốn, quản lý được hàng tồn kho, sửa chữa được hệ thống điện nước cơ bản."@vi ;
    rdfs:subClassOf persona:kinh_nghiem_thuc_te .

persona:ky_nang_giai_quyet_van_de_thuc_te a owl:Class ;
    rdfs:label "Kỹ năng giải quyết vấn đề thực tế"@vi ;
    persona:cung_co persona:phuong_phap_xu_ly_van_de ;
    persona:tuong_quan persona:muc_do_linh_hoat_ke_hoach ;
    rdfs:comment "Khả năng nhận diện và xử lý các tình huống khó khăn cụ thể bằng kinh nghiệm tích lũy hoặc tư duy thực dụng, không nhất thiết dựa trên lý thuyết học thuật.\\nVí dụ thực tế từ dữ liệu: tự mài dao, sửa xe đạp, lắp ráp thiết bị gia đình, sửa chữa điện nước cơ bản."@vi ;
    rdfs:subClassOf persona:ky_nang_ca_nhan .

persona:ky_nang_ky_thuat_chuyen_nganh a owl:Class ;
    rdfs:label "Kỹ năng kỹ thuật chuyên ngành"@vi ;
    persona:cung_co persona:nang_luc_ky_thuat ;
    rdfs:comment "Các thao tác, quy trình và năng lực kỹ thuật đặc thù của một ngành nghề cụ thể mà cá nhân đã thành thục.\\nVí dụ thực tế từ dữ liệu: đọc điện tâm đồ, tiêm bắp, đo huyết áp, thiết kế hệ thống tưới tiêu, sử dụng phần mềm thiết kế 3D, bảo trì máy móc nông nghiệp."@vi ;
    rdfs:subClassOf persona:ky_nang_chuyen_mon_cot_loi .

persona:linh_vuc_kinh_nghiem_tich_luy a owl:Class ;
    rdfs:label "Lĩnh vực kinh nghiệm tích lũy"@vi ;
    persona:dinh_hinh persona:dinh_huong_phat_trien_ban_than ;
    rdfs:comment "Các mảng công việc hoặc hoạt động cụ thể mà cá nhân đã dành thời gian đáng kể để thực hành và tích lũy bài học.\\nVí dụ thực tế từ dữ liệu: chăm sóc bệnh nhân nhiều năm, quản lý tiệm tạp hóa từ nhỏ, nấu ăn truyền thống từ gia đình."@vi ;
    rdfs:subClassOf persona:kinh_nghiem_thuc_te .

persona:moi_quan_he_xa_hoi_nghe_nghiep a owl:Class ;
    rdfs:label "Mối quan hệ xã hội nghề nghiệp"@vi ;
    persona:thuc_day persona:hanh_vi_chia_se_am_thuc,
        persona:muc_dich_ket_noi_xa_hoi,
        persona:muc_tieu_chuyen_di ;
    persona:tuong_quan persona:dong_luc_ket_noi_cong_dong_sang_tao,
        persona:hanh_vi_tham_gia_cong_dong ;
    rdfs:comment "Mạng lưới các kết nối giữa cá nhân với đồng nghiệp, cấp trên, cấp dưới, đối tác và khách hàng trong bối cảnh công việc. \\nBao gồm cả chất lượng tin tưởng, mức độ hợp tác và động lực quyền lực trong các mối quan hệ đó."@vi ;
    rdfs:subClassOf persona:moi_truong_lam_viec .

persona:muc_do_cam_ket_nghe_nghiep a owl:Class ;
    rdfs:label "Mức độ cam kết nghề nghiệp"@vi ;
    rdfs:comment "Sức mạnh của sự gắn bó và quyết tâm của cá nhân trong việc duy trì và phát triển con đường nghề nghiệp đã chọn dù gặp khó khăn.\\nVí dụ thực tế từ dữ liệu: vẫn dạy nghề truyền thống dù đã nghỉ hưu, tiếp tục học thêm chứng chỉ dù đang đi làm."@vi ;
    rdfs:subClassOf persona:muc_do_dau_tu_thoi_gian_va_nguon_luc .

persona:muc_do_quan_tam_am_thuc_truyen_thong a owl:Class ;
    rdfs:label "Mức độ quan tâm ẩm thực truyền thống"@vi ;
    rdfs:comment "Sự chú trọng và trân trọng của cá nhân đối với các món ăn mang giá trị văn hóa, lịch sử của vùng miền hoặc quốc gia.\\nVí dụ thực tế: đặc biệt tìm phở đúng vị Hà Nội, coi trọng công thức gia truyền hơn công thức hiện đại."@vi ;
    rdfs:subClassOf persona:gu_trai_nghiem_van_hoa_am_thuc .

persona:muc_tieu_the_thao_trong_ke_hoach a owl:Class ;
    rdfs:label "Mục tiêu thể thao trong kế hoạch"@vi ;
    persona:tuong_quan persona:moc_thoi_gian_muc_tieu ;
    rdfs:comment "Đích đến cụ thể và có thể đo lường mà cá nhân muốn đạt được sau một giai đoạn tập luyện.\\nVí dụ thực tế từ dữ liệu: chạy được 5km liên tục sau 2 tháng, giảm 5kg trong 3 tháng, bơi đúng kỹ thuật sải tay."@vi ;
    rdfs:subClassOf persona:ke_hoach_tap_luyen .

persona:nang_luc_can_phat_trien a owl:Class ;
    rdfs:label "Năng lực cần phát triển"@vi ;
    persona:tuong_quan persona:tap_hop_nang_luc ;
    rdfs:comment "Kỹ năng hoặc kiến thức cụ thể mà cá nhân nhận ra còn thiếu và đang có kế hoạch bổ sung.\\nVí dụ thực tế từ dữ liệu: muốn học thêm để phát triển bản thân dù không có học vấn, cần thêm kỹ năng quản lý để mở rộng quy mô kinh doanh, học phần mềm mới trong nghề kỹ thuật."@vi ;
    rdfs:subClassOf persona:dinh_huong_phat_trien_ban_than .

persona:nguyen_tac_song_nen_tang a owl:Class ;
    rdfs:label "Nguyên tắc sống nền tảng"@vi ;
    persona:dinh_hinh persona:muc_tieu_vi_tri_nghe_nghiep ;
    rdfs:comment "Các quy tắc hành xử bất di bất dịch mà cá nhân tự đặt ra và luôn tuân theo bất kể hoàn cảnh thay đổi.\\nVí dụ thực tế: không bao giờ nói dối, luôn đặt gia đình lên trên sự nghiệp, sống tự lập không nhờ vả người khác."@vi ;
    rdfs:subClassOf persona:gia_tri_cot_loi .

persona:nhom_thuc_pham_uu_tien a owl:Class ;
    rdfs:label "Nhóm thực phẩm ưu tiên"@vi ;
    rdfs:comment "Các loại nguyên liệu hoặc nhóm thực phẩm mà cá nhân chủ động lựa chọn tiêu thụ thường xuyên.\\nVí dụ thực tế: ưu tiên rau xanh và cá, thường chọn thịt đỏ, hoặc đặc biệt thích các chế phẩm từ sữa."@vi ;
    rdfs:subClassOf persona:so_thich_an_uong_ca_nhan .

persona:phong_tuc_tap_quan_gia_dinh a owl:Class ;
    rdfs:label "Phong tục tập quán gia đình"@vi ;
    persona:dinh_hinh persona:che_do_an_uong_ca_nhan ;
    rdfs:comment "Các thói quen, nghi lễ và quy tắc ứng xử được thực hành lặp đi lặp lại trong phạm vi gia đình và truyền từ thế hệ này sang thế hệ khác.\\nVí dụ thực tế từ dữ liệu: thắp nhang dịp Tết, cả nhà đến rạp hát xem chèo mỗi sáng Chủ Nhật, mẹ dạy nấu ăn từ nhỏ."@vi ;
    rdfs:subClassOf persona:nguon_goc_hoac_nen_tang_van_hoa .

persona:phuong_tien_ky_thuat_so a owl:Class ;
    rdfs:label "Phương tiện kỹ thuật số"@vi ;
    rdfs:comment "Nền tảng và phần mềm kỹ thuật số được dùng để sáng tác, chỉnh sửa hoặc phân phối tác phẩm.\\nVí dụ: phần mềm chỉnh ảnh, DAW thu âm, công cụ vẽ kỹ thuật số, nền tảng xuất bản trực tuyến."@vi ;
    rdfs:subClassOf persona:phuong_tien_bieu_dat_nghe_thuat .

persona:thoi_quen_sinh_hoat_hang_ngay a owl:Class ;
    rdfs:label "Thói quen sinh hoạt hàng ngày"@vi ;
    rdfs:comment "Các hành động lặp đi lặp lại trong cuộc sống thường nhật phản ánh rõ nét nền tảng văn hóa của cá nhân.\\nVí dụ thực tế từ dữ liệu: uống trà ấm mỗi sáng xem người qua lại, dùng phin ủ trà, đi chợ nổi mua đồ ăn sáng sớm, nấu cháo nồi đất cuối tuần."@vi ;
    rdfs:subClassOf persona:hanh_vi_ca_nhan_van_hoa .

persona:boi_canh_giai_tri a owl:Class ;
    rdfs:label "Bối cảnh giải trí"@vi ;
    persona:dinh_hinh persona:boi_canh_tham_gia_the_thao ;
    rdfs:comment "Hoàn cảnh và môi trường xung quanh khi cá nhân thực hiện hoạt động giải trí: một mình hay cùng người khác, \\ntại nhà hay ngoài không gian công cộng, định kỳ hay tùy hứng.\\nVí dụ thực tế từ dữ liệu: kể chuyện cho con cháu đêm trăng tròn, đốt lửa quây quanh bạn bè, cùng cháu nội chơi cờ vua, \\nđến công viên với nhóm khiêu vũ cuối tuần."@vi ;
    rdfs:subClassOf persona:hoat_dong_giai_tri_thoi_gian_ranh .

persona:cau_truc_gia_dinh a owl:Class ;
    rdfs:label "Cấu trúc gia đình"@vi ;
    rdfs:comment "Hình thức tổ chức của đơn vị gia đình mà cá nhân lớn lên trong đó, bao gồm số thế hệ cùng chung sống và vai trò của từng thành viên.\\nVí dụ thực tế từ dữ liệu: gia đình 3 thế hệ, gia đình hạt nhân 2 người, gia đình mà tầng 1 là tiệm tạp hóa mẹ điều hành."@vi ;
    rdfs:subClassOf persona:boi_canh_xa_hoi_truyen_thong .

persona:dam_me_ca_nhan a owl:Class ;
    rdfs:label "Đam mê cá nhân"@vi ;
    persona:thuc_day persona:dong_luc_sang_tao_nghe_thuat,
        persona:khat_vong_dong_gop_xa_hoi,
        persona:muc_do_hung_thu_van_dong,
        persona:muc_tieu_chuyen_di ;
    rdfs:comment "Mức độ quan tâm và yêu thích sâu sắc, mạnh mẽ ở mức độ cao đối với một hoạt động hoặc lĩnh vực cụ thể.\\nThúc đẩy cá nhân dành nhiều thời gian, công sức và tâm huyết để theo đuổi, tìm tòi và phát triển lâu dài."@vi ;
    rdfs:subClassOf persona:hobbies_and_interests .

persona:dinh_huong_thuc_te_voi_ly_tuong a owl:Class ;
    rdfs:label "Định hướng thực tế với lý tưởng"@vi ;
    persona:tac_dong persona:muc_tieu_tai_chinh_ca_nhan,
        persona:muc_tieu_the_thao_trong_ke_hoach,
        persona:phuong_phap_xu_ly_van_de ;
    rdfs:comment "Mức độ mà cá nhân dựa vào thực tế hiện tại và những gì khả thi, thay vì theo đuổi một hình mẫu lý tưởng hoàn hảo.\\nNgười thiên thực tế ưu tiên giải pháp khả thi; người thiên lý tưởng không thỏa hiệp với những gì kém hoàn hảo."@vi ;
    rdfs:subClassOf persona:cach_thuc_tiep_can_cuoc_song .

persona:doan_van_ban_tu_su_nang_luc a owl:Class ;
    rdfs:label "Đoạn văn bản tự sự năng lực"@vi ;
    rdfs:comment "Hình thức trình bày thông tin năng lực dưới dạng một câu chuyện hoặc một đoạn văn liền mạch, có ngữ cảnh.\\nThay vì liệt kê danh sách đầu dòng, cách viết này giúp thể hiện rõ nét tư duy và phong cách cá nhân."@vi ;
    rdfs:subClassOf persona:skills_and_expertise .

persona:doan_van_ban_tu_su_phong_cach_song a owl:Class ;
    rdfs:label "Đoạn văn bản tự sự phong cách sống"@vi ;
    rdfs:comment "Hình thức kết nối các thói quen, sở thích thành một câu chuyện kể liền mạch và có văn cảnh.\\nGiúp gián tiếp phác họa nên gu thẩm mỹ, thế giới quan và cá tính độc bản của người viết."@vi ;
    rdfs:subClassOf persona:hobbies_and_interests .

persona:dong_luc_ket_noi_cong_dong_sang_tao a owl:Class ;
    rdfs:label "Động lực kết nối cộng đồng sáng tạo"@vi ;
    rdfs:comment "Mong muốn tham gia vào cộng đồng người cùng đam mê, tìm kiếm sự đồng điệu và chia sẻ trải nghiệm sáng tạo với người khác."@vi ;
    rdfs:subClassOf persona:dong_luc_sang_tao_nghe_thuat .

persona:he_thong_niem_tin_ca_nhan a owl:Class ;
    rdfs:label "Hệ thống niềm tin cá nhân"@vi ;
    rdfs:comment "Tập hợp các xác tín mà một cá nhân xem là đúng đắn về bản thân, con người và thế giới — dù có hay không có bằng chứng kiểm chứng.\\nĐóng vai trò là bộ lọc diễn giải mọi sự kiện và định hướng hành vi thường ngày."@vi ;
    rdfs:subClassOf persona:ban_sac_ca_nhan .

persona:hoat_dong_giai_tri_cu_the a owl:Class ;
    rdfs:label "Hoạt động giải trí cụ thể"@vi ;
    persona:dinh_hinh persona:tan_suat_tiep_xuc_nghe_thuat ;
    persona:tuong_quan persona:hoat_dong_giai_tri_khi_du_lich ;
    rdfs:comment "Danh sách các việc làm thực tế mà cá nhân thực hiện trong thời gian rảnh để thư giãn và tái tạo năng lượng.\\nVí dụ thực tế từ dữ liệu: chơi cờ tướng, uống nước đá chanh vỉa hè, đọc thơ, nghe cải lương, chèo xuồng kênh rạch chiều tà, làm bánh cống cuối tuần, nướng bánh."@vi ;
    rdfs:subClassOf persona:hoat_dong_giai_tri_thoi_gian_ranh .

persona:hoat_dong_luu_tru_va_di_chuyen a owl:Class ;
    rdfs:label "Hoạt động lưu trú và di chuyển"@vi ;
    rdfs:comment "Các hành động liên quan đến việc sắp xếp nơi ở và phương tiện trong suốt hành trình.\\nBao gồm đặt phòng, check-in, di chuyển giữa các địa điểm và quản lý hành lý."@vi ;
    rdfs:subClassOf persona:hoat_dong_hanh_trinh_hoac_lu_hanh .

persona:ky_nang_giao_tiep_va_ung_xu a owl:Class ;
    rdfs:label "Kỹ năng giao tiếp và ứng xử"@vi ;
    persona:dinh_hinh persona:cach_bieu_dat_ngon_ngu_va_giao_tiep_van_hoa,
        persona:phong_cach_giao_tiep_nghe_nghiep ;
    rdfs:comment "Khả năng truyền đạt thông tin, lắng nghe và tương tác hiệu quả với người khác trong các tình huống xã hội khác nhau.\\nVí dụ thực tế từ dữ liệu: kỹ năng giao tiếp cơ bản khi bán hàng tạp hóa, thuyết trình trực tiếp, phối hợp điều trị với bác sĩ."@vi ;
    rdfs:subClassOf persona:ky_nang_ca_nhan .

persona:muc_do_quan_tam_theo_doi a owl:Class ;
    rdfs:label "Mức độ quan tâm theo dõi"@vi ;
    rdfs:comment "Tần suất và chiều sâu mà một cá nhân chủ động cập nhật thông tin, xem trực tiếp hoặc \\nphân tích kết quả thi đấu của một đội hoặc câu lạc bộ. \\nTừ mức thỉnh thoảng xem qua đến mức theo dõi sát sao từng trận đấu."@vi ;
    rdfs:subClassOf persona:cau_lac_bo_hoac_doi_tuyen_the_thao_yeu_thich .

persona:muc_do_tiep_nhan_van_hoa_ben_ngoai a owl:Class ;
    rdfs:label "Mức độ tiếp nhận văn hóa bên ngoài"@vi ;
    persona:thuc_day persona:muc_do_kham_pha_tu_phat,
        persona:su_coi_mo_voi_am_thuc_quoc_te ;
    rdfs:comment "Sự sẵn sàng của cá nhân trong việc tiếp thu, đánh giá và tích hợp các yếu tố từ văn hóa khác vùng miền hoặc quốc tế vào lối sống của mình.\\nVí dụ thực tế: dùng lò vi sóng nhưng vẫn thích nấu nồi đất, thích ẩm thực Việt nhưng cũng tò mò thử đồ ăn mới."@vi ;
    rdfs:subClassOf persona:nhan_thuc_ca_nhan_van_hoa .

persona:muc_tieu_kinh_doanh_hoac_su_nghiep_cu_the a owl:Class ;
    rdfs:label "Mục tiêu kinh doanh hoặc sự nghiệp cụ thể"@vi ;
    persona:dinh_hinh persona:pham_vi_chuyen_mon_hoa ;
    rdfs:comment "Đích đến rõ ràng và có thể đo lường được trong lĩnh vực nghề nghiệp hoặc kinh doanh mà cá nhân đang hướng tới.\\nVí dụ thực tế từ dữ liệu: mở siêu thị mini nhận hàng nhập khẩu, mở xưởng sửa chữa thiết bị nông nghiệp, mở rộng quy mô công việc phục vụ, duy trì cửa hàng tạp hóa gia đình."@vi ;
    rdfs:subClassOf persona:muc_tieu_cong_viec_dai_han .

persona:pham_vi_loai_hinh_nghe_thuat_tiep_can a owl:Class ;
    rdfs:label "Phạm vi loại hình nghệ thuật tiếp cận"@vi ;
    rdfs:comment "Độ rộng của các hình thức nghệ thuật mà một cá nhân có kinh nghiệm tương tác. Người có phạm vi hẹp chỉ gắn với một \\nthể loại (ví dụ: chỉ nghe nhạc dân ca), trong khi người có phạm vi rộng trải nghiệm đa dạng từ điện ảnh, âm nhạc đến hội họa và sân khấu."@vi ;
    rdfs:subClassOf persona:muc_do_gan_ket_nghe_thuat .

persona:su_nghiep_ca_nhan a owl:Class ;
    rdfs:label "Sự nghiệp cá nhân"@vi ;
    rdfs:comment "Toàn bộ chuỗi hành trình làm việc, tích lũy kinh nghiệm và thăng tiến chuyên môn của một người trong suốt thời gian lao động.\\nKhông chỉ là phương tiện tạo ra thu nhập mà còn là nền tảng để tự khẳng định giá trị bản thân với xã hội."@vi ;
    rdfs:subClassOf persona:career_goals_and_ambitions .

persona:su_uu_tien_van_dong a owl:Class ;
    rdfs:label "Sự ưu tiên vận động"@vi ;
    rdfs:comment "Thứ tự xếp hạng các loại hình hoạt động thể chất mà một cá nhân chủ động lựa chọn thực hiện \\ntrước khi xem xét các lựa chọn khác. \\nPhản ánh giá trị cá nhân gắn với sức khỏe, thẩm mỹ hay tính cạnh tranh."@vi ;
    rdfs:subClassOf persona:xu_huong_va_so_thich_van_dong .

persona:thai_do_doi_voi_kho_khan_va_mat_mat a owl:Class ;
    rdfs:label "Thái độ đối với khó khăn và mất mát"@vi ;
    rdfs:comment "Cách cá nhân diễn giải và phản ứng về mặt tinh thần trước nghịch cảnh, thất bại hoặc mất mát trong cuộc sống.\\nPhân biệt giữa người nhìn khó khăn như cơ hội trưởng thành và người xem đó là bất công hoặc nguyên nhân bỏ cuộc."@vi ;
    rdfs:subClassOf persona:nhan_sinh_quan .

persona:thiet_bi_va_dung_cu_nau_an_su_dung a owl:Class ;
    rdfs:label "Thiết bị và dụng cụ nấu ăn sử dụng"@vi ;
    rdfs:comment "Các công cụ và thiết bị bếp núc mà cá nhân quen dùng và có khả năng vận hành thành thục.\\nVí dụ thực tế từ dữ liệu: nồi đất truyền thống, bếp gas thông thường, hoặc thiết bị hiện đại như lò nướng, nồi áp suất điện."@vi ;
    rdfs:subClassOf persona:nang_luc_nau_nuong .

persona:to_chuc_the_thao_yeu_thich a owl:Class ;
    rdfs:label "Tổ chức thể thao yêu thích"@vi ;
    rdfs:comment "Câu lạc bộ, đội tuyển hoặc tổ chức thể thao cụ thể mà cá nhân dành sự quan tâm và ủng hộ tinh thần bền vững. \\nBao gồm câu lạc bộ địa phương, đội tuyển tỉnh/thành hoặc đội tuyển quốc gia."@vi ;
    rdfs:subClassOf persona:cau_lac_bo_hoac_doi_tuyen_the_thao_yeu_thich .

persona:tu_nhan_thuc_ban_than a owl:Class ;
    rdfs:label "Tự nhận thức bản thân"@vi ;
    rdfs:comment "Khả năng cá nhân nhìn nhận, hiểu rõ và mô tả chính xác các điểm mạnh, điểm yếu, cảm xúc và động lực của bản thân.\\nLà nền tảng để cá nhân đưa ra quyết định phù hợp với giá trị thực của mình."@vi ;
    rdfs:subClassOf persona:ban_sac_ca_nhan .

persona:vai_tro_tiep_nhan_nghe_thuat a owl:Class ;
    rdfs:label "Vai trò tiếp nhận nghệ thuật"@vi ;
    rdfs:comment "Vị trí mà cá nhân đảm nhận trong quá trình tương tác với nghệ thuật: thưởng thức thụ động (khán giả, độc giả, người nghe) \\nhoặc tham gia chủ động sáng tạo (diễn viên, họa sĩ, nhạc công). Xác định mức độ đầu tư thực sự của cá nhân vào thế giới nghệ thuật."@vi ;
    rdfs:subClassOf persona:muc_do_gan_ket_nghe_thuat .

persona:anh_huong_nghe_thuat_den_the_gioi_quan a owl:Class ;
    rdfs:label "Ảnh hưởng nghệ thuật đến thế giới quan"@vi ;
    persona:cung_co persona:the_gioi_quan ;
    persona:dinh_hinh persona:nhan_thuc_ca_nhan_van_hoa ;
    rdfs:comment "Mức độ mà các trải nghiệm nghệ thuật tích lũy theo thời gian định hình nên hệ thống giá trị, niềm tin và cách nhìn nhận cuộc sống của một cá nhân.\\nVí dụ thực tế: đọc nhiều văn học khiến người ta đồng cảm hơn với người khác, tiếp xúc với nghệ thuật phản kháng hình thành ý thức xã hội."@vi ;
    rdfs:subClassOf persona:cach_thuc_nghe_thuat_tac_dong .

persona:cach_thuc_nghe_thuat_tac_dong a owl:Class ;
    rdfs:label "Cách thức nghệ thuật tác động"@vi ;
    rdfs:comment "Cơ chế mà các tác phẩm hoặc hoạt động nghệ thuật khơi gợi cảm xúc, thay đổi nhận thức hoặc thúc đẩy tư duy.\\nGóp phần hình thành nên thế giới quan và tâm lý cá nhân."@vi ;
    rdfs:subClassOf persona:arts_persona .

persona:cau_lac_bo_hoac_doi_tuyen_the_thao_yeu_thich a owl:Class ;
    rdfs:label "Câu lạc bộ hoặc đội tuyển thể thao yêu thích"@vi ;
    rdfs:comment "Tổ chức, câu lạc bộ hoặc đội thể thao chuyên nghiệp/bán chuyên mà một cá nhân đặc biệt quan tâm, \\ntheo dõi sát sao và dành sự ủng hộ tinh thần lâu dài."@vi ;
    rdfs:subClassOf persona:sports_persona .

persona:co_che_khoi_goi_cam_xuc a owl:Class ;
    rdfs:label "Cơ chế khơi gợi cảm xúc"@vi ;
    persona:tuong_quan persona:muc_dich_giai_tri_tinh_than ;
    rdfs:comment "Cách thức cụ thể mà một tác phẩm hoặc trải nghiệm nghệ thuật kích hoạt và dẫn dắt phản ứng cảm xúc của người tiếp nhận.\\nVí dụ: giai điệu buồn gợi nỗi nhớ, màu sắc tương phản tạo căng thẳng thị giác, lời thoại chạm đến ký ức cá nhân."@vi ;
    rdfs:subClassOf persona:cach_thuc_nghe_thuat_tac_dong .

persona:giong_dieu_va_phong_cach_viet_tu_su a owl:Class ;
    rdfs:label "Giọng điệu và phong cách viết tự sự"@vi ;
    rdfs:comment "Cách thức ngôn ngữ được sử dụng trong đoạn văn tự sự: trang trọng hay thân mật, khiêm tốn hay tự tin, ngắn gọn súc tích hay chi tiết phong phú.\\nPhản ánh cá tính và bối cảnh văn hóa của người được mô tả."@vi ;
    rdfs:subClassOf persona:doan_van_ban_tu_su_nang_luc .

persona:hanh_vi_ca_nhan_van_hoa a owl:Class ;
    rdfs:label "Hành vi cá nhân văn hóa"@vi ;
    persona:tuong_quan persona:phuong_tien_bieu_dat_nghe_thuat ;
    rdfs:comment "Các hành động, cách ứng xử, giao tiếp và biểu đạt ra bên ngoài của một cá nhân trong đời sống thường nhật.\\nChịu sự điều chỉnh ngầm hoặc rõ ràng bởi các quy tắc ứng xử và khuôn mẫu văn hóa mà họ đã tiếp thu."@vi ;
    rdfs:subClassOf persona:cultural_background .

persona:hoat_dong_giai_tri_thoi_gian_ranh a owl:Class ;
    rdfs:label "Hoạt động giải trí thời gian rảnh"@vi ;
    rdfs:comment "Những việc làm cụ thể được thực hiện trong quỹ thời gian ngoài giờ làm việc hoặc học tập.\\nNhằm mục đích tái tạo năng lượng thể chất, giải tỏa căng thẳng tinh thần và cân bằng cuộc sống."@vi ;
    rdfs:subClassOf persona:hobbies_and_interests .

persona:hoat_dong_the_chat_giu_voc_dang a owl:Class ;
    rdfs:label "Hoạt động thể chất giữ vóc dáng"@vi ;
    rdfs:comment "Các bài tập và vận động cơ thể được thực hiện đều đặn với mục tiêu chính là duy trì \\nhoặc cải thiện hình thể theo tiêu chuẩn cá nhân. \\nKhác với tập luyện thể thao ở chỗ ưu tiên kết quả hình thể hơn hiệu suất thi đấu."@vi ;
    rdfs:subClassOf persona:che_do_giu_gin_voc_dang .

persona:ke_hoach_tap_luyen a owl:Class ;
    rdfs:label "Kế hoạch tập luyện"@vi ;
    rdfs:comment "Chiến lược tổng thể xác định mục tiêu, phương pháp và lộ trình phát triển thể chất trong một giai đoạn nhất định. \\nLà cầu nối giữa mục tiêu thể thao của cá nhân và các hành động cụ thể hàng ngày."@vi ;
    rdfs:subClassOf persona:phuong_phap_tap_luyen .

persona:khat_vong_dong_gop_xa_hoi a owl:Class ;
    rdfs:label "Khát vọng đóng góp xã hội"@vi ;
    rdfs:comment "Mong muốn của cá nhân tạo ra giá trị hoặc tác động tích cực vượt ra ngoài lợi ích cá nhân, hướng đến cộng đồng hoặc xã hội rộng lớn hơn.\\nVí dụ thực tế từ dữ liệu: truyền dạy nem cua bể đúng chuẩn cho lớp trẻ, đào tạo kỹ sư trẻ, xây dựng dự án xã hội hỗ trợ cộng đồng, đóng góp từ thiện."@vi ;
    rdfs:subClassOf persona:khat_vong_nghe_nghiep .

persona:kiem_soat_can_nang a owl:Class ;
    rdfs:label "Kiểm soát cân nặng"@vi ;
    rdfs:comment "Quá trình chủ động điều tiết khối lượng cơ thể thông qua cân bằng giữa năng lượng nạp vào \\nvà năng lượng tiêu hao qua vận động. \\nBao gồm mục tiêu giảm cân, tăng cân hoặc duy trì cân nặng ở ngưỡng mong muốn."@vi ;
    rdfs:subClassOf persona:che_do_giu_gin_voc_dang .

persona:kinh_nghiem_thuc_te a owl:Class ;
    rdfs:label "Kinh nghiệm thực tế"@vi ;
    persona:cung_co persona:muc_do_thuan_thuc_sang_tao,
        persona:the_gioi_quan ;
    persona:dinh_hinh persona:muc_tieu_kinh_doanh_hoac_su_nghiep_cu_the ;
    persona:tac_dong persona:ky_nang_thuc_hanh_nghe_nghiep ;
    rdfs:comment "Toàn bộ những bài học, sự am hiểu và tri thức có được thông qua quá trình trực tiếp tham gia làm việc, cọ xát và xử lý các bài toán trong đời thực.\\nĐược đo lường bằng kết quả công việc và các dự án đã hoàn thành."@vi ;
    rdfs:subClassOf persona:skills_and_expertise .

persona:ky_nang_ca_nhan a owl:Class ;
    rdfs:label "Kỹ năng cá nhân"@vi ;
    rdfs:comment "Các năng lực thuộc về tính cách, khả năng tương tác xã hội và quản lý bản thân của một người.\\nVí dụ như kỹ năng giao tiếp, giải quyết vấn đề, làm việc nhóm, quản lý thời gian hoặc khả năng thích ứng."@vi ;
    rdfs:subClassOf persona:skills_and_expertise .

persona:ky_nang_thu_cong_va_nghe_truyen_thong a owl:Class ;
    rdfs:label "Kỹ năng thủ công và nghề truyền thống"@vi ;
    persona:cung_co persona:di_san_nghe_thuat_va_am_nhac_truyen_thong ;
    persona:dinh_hinh persona:loai_hinh_nghe_thuat_thuc_hanh,
        persona:loai_hinh_so_thich ;
    rdfs:comment "Các năng lực làm việc bằng tay, chế tác thủ công hoặc thực hành nghề truyền thống được tích lũy qua học hỏi trực tiếp và luyện tập lâu năm.\\nVí dụ thực tế từ dữ liệu: làm bánh đa cua, may vá thạo, làm đèn hoa đăng, nắn bột làm bánh, làm bánh cuốn, nấu phở chuẩn vị Hà Nội."@vi ;
    rdfs:subClassOf persona:ky_nang_chuyen_mon_cot_loi .

persona:ky_thuat_van_dong a owl:Class ;
    rdfs:label "Kỹ thuật vận động"@vi ;
    rdfs:comment "Cách thức thực hiện chính xác một động tác hoặc chuỗi động tác theo đúng cơ học cơ thể \\nvà yêu cầu của môn thể thao. \\nKỹ thuật đúng giúp tối đa hóa hiệu suất và giảm thiểu nguy cơ chấn thương."@vi ;
    rdfs:subClassOf persona:phuong_phap_tap_luyen .

persona:loai_hinh_nghe_thuat_thuc_hanh a owl:Class ;
    rdfs:label "Loại hình nghệ thuật thực hành"@vi ;
    rdfs:comment "Hình thức nghệ thuật cụ thể mà một cá nhân trực tiếp thực hành hoặc sáng tác.\\nVí dụ thực tế: vẽ tranh, chơi đàn, viết văn, chụp ảnh, múa, ca hát, làm gốm."@vi ;
    rdfs:subClassOf persona:hinh_thuc_bieu_dat_sang_tao .

persona:moc_thoi_gian_muc_tieu a owl:Class ;
    rdfs:label "Mốc thời gian mục tiêu"@vi ;
    rdfs:comment "Khung thời gian cụ thể mà cá nhân gắn với các mục tiêu nghề nghiệp để tạo áp lực thực hiện.\\nVí dụ thực tế từ dữ liệu: trong 3 năm tới học chứng chỉ tim mạch, đến năm 30 tuổi trở thành trưởng bộ phận, trong 5 năm tới thăng tiến lên kỹ sư trưởng."@vi ;
    rdfs:subClassOf persona:muc_tieu_cong_viec_dai_han .

persona:moi_truong_kinh_te_xa_hoi_xuat_than a owl:Class ;
    rdfs:label "Môi trường kinh tế xã hội xuất thân"@vi ;
    persona:dinh_hinh persona:khat_vong_nghe_nghiep,
        persona:ky_nang_thu_cong_va_nghe_truyen_thong ;
    persona:tac_dong persona:linh_vuc_lam_viec_chinh,
        persona:nhan_sinh_quan ;
    rdfs:comment "Điều kiện tài chính và vị trí xã hội của gia đình gốc, tác động trực tiếp đến cơ hội tiếp cận giáo dục, nghề nghiệp và phong cách sống của cá nhân.\\nVí dụ thực tế từ dữ liệu: gia đình có tiệm tạp hóa nhỏ, sống trong căn nhà cấp bốn cuối ngõ, xuất thân từ gia đình có truyền thống học vấn."@vi ;
    rdfs:subClassOf persona:boi_canh_xa_hoi_truyen_thong .

persona:mon_the_thao_yeu_thich a owl:Class ;
    rdfs:label "Môn thể thao yêu thích"@vi ;
    persona:tuong_quan persona:loai_hinh_so_thich ;
    rdfs:comment "Hoạt động thể chất có quy tắc và hình thức cụ thể mà cá nhân chủ động lựa chọn để tập luyện hoặc thi đấu thường xuyên. \\nVí dụ thực tế: bóng đá, cầu lông, bơi lội, đi bộ, bóng bàn, yoga."@vi ;
    rdfs:subClassOf persona:xu_huong_va_so_thich_van_dong .

persona:muc_dich_giu_voc_dang a owl:Class ;
    rdfs:label "Mục đích giữ vóc dáng"@vi ;
    rdfs:comment "Động lực vận động gắn với mong muốn kiểm soát ngoại hình, cân nặng và tỷ lệ cơ thể theo tiêu chuẩn thẩm mỹ cá nhân. \\nKhác với mục đích sức khỏe ở chỗ ưu tiên yếu tố hình thể hơn chỉ số sinh lý."@vi ;
    rdfs:subClassOf persona:muc_dich_van_dong .

persona:muc_dich_thi_dau_canh_tranh a owl:Class ;
    rdfs:label "Mục đích thi đấu cạnh tranh"@vi ;
    persona:dinh_hinh persona:xu_huong_lac_quan_voi_bi_quan ;
    rdfs:comment "Động lực tham gia thể thao hướng đến việc đo sức, tranh tài và đạt thành tích trong các trận đấu có tổ chức. \\nVí dụ thực tế: tham gia trận cầu tại câu lạc bộ địa phương vào cuối tuần."@vi ;
    rdfs:subClassOf persona:muc_dich_van_dong .

persona:muc_do_chap_nhan_vi_la a owl:Class ;
    rdfs:label "Mức độ chấp nhận vị lạ"@vi ;
    rdfs:comment "Sự sẵn sàng của cá nhân trong việc thử nghiệm và chấp nhận các hương vị xa lạ, khác biệt so với thói quen ăn uống thông thường.\\nPhân biệt giữa người ăn uống bảo thủ (chỉ ăn món quen) và người cởi mở (háo hức thử món mới)."@vi ;
    rdfs:subClassOf persona:khau_vi_ca_nhan .

persona:muc_do_chu_dong_voi_bi_dong a owl:Class ;
    rdfs:label "Mức độ chủ động với bị động"@vi ;
    persona:dinh_hinh persona:hinh_thuc_tich_luy_kinh_nghiem ;
    persona:tuong_quan persona:dong_luc_phat_trien_su_nghiep,
        persona:tinh_nhat_quan_hanh_vi,
        persona:tinh_trang_tham_gia_the_thao ;
    rdfs:comment "Xu hướng hành động của cá nhân trong việc kiểm soát và định hướng cuộc sống của mình.\\nNgười chủ động tự tạo cơ hội và chịu trách nhiệm kết quả; người bị động chờ hoàn cảnh dẫn dắt và đổ trách nhiệm cho bên ngoài."@vi ;
    rdfs:subClassOf persona:cach_thuc_tiep_can_cuoc_song .

persona:muc_do_chu_tam_nghe_thuat a owl:Class ;
    rdfs:label "Mức độ chú tâm nghệ thuật"@vi ;
    rdfs:comment "Chất lượng sự tập trung và cảm nhận sâu mà cá nhân dành cho một tác phẩm hoặc trải nghiệm nghệ thuật cụ thể. \\nPhân biệt giữa người thưởng thức qua loa và người cảm thụ có chiều sâu, chú ý đến chi tiết nghệ thuật, kỹ thuật và thông điệp."@vi ;
    rdfs:subClassOf persona:muc_do_gan_ket_nghe_thuat .

persona:muc_do_linh_hoat_ke_hoach a owl:Class ;
    rdfs:label "Mức độ linh hoạt kế hoạch"@vi ;
    rdfs:comment "Khả năng và xu hướng của cá nhân trong việc điều chỉnh lịch trình khi gặp thay đổi hoặc cơ hội mới trong chuyến đi.\\nTừ người cần kế hoạch cứng nhắc chi tiết đến người sẵn sàng thay đổi hoàn toàn theo cảm hứng."@vi ;
    rdfs:subClassOf persona:phong_cach_dich_chuyen .

persona:muc_do_tu_hao_ban_sac_van_hoa a owl:Class ;
    rdfs:label "Mức độ tự hào bản sắc văn hóa"@vi ;
    persona:cung_co persona:ban_sac_ca_nhan,
        persona:muc_do_hoa_nhap_van_hoa_ban_dia ;
    rdfs:comment "Cường độ cảm giác tự hào và gắn kết của cá nhân với nền văn hóa, vùng miền và truyền thống gốc của mình.\\nVí dụ thực tế từ dữ liệu: tự hào truyền dạy bánh đa cua đúng chuẩn Hải Phòng, duy trì giữ hội hoa phượng đỏ dù đã nghỉ hưu."@vi ;
    rdfs:subClassOf persona:nhan_thuc_ca_nhan_van_hoa .

persona:muc_tieu_cong_viec_dai_han a owl:Class ;
    rdfs:label "Mục tiêu công việc dài hạn"@vi ;
    rdfs:comment "Những đích đến, cột mốc thành tựu hoặc vai trò cụ thể mà cá nhân kỳ vọng sẽ chinh phục trong tương lai xa (thường từ 3 đến 5 năm trở lên).\\nĐóng vai trò như kim chỉ nam định hình các kế hoạch hành động và quyết định ở hiện tại."@vi ;
    rdfs:subClassOf persona:career_goals_and_ambitions .

persona:muc_tieu_vi_tri_nghe_nghiep a owl:Class ;
    rdfs:label "Mục tiêu vị trí nghề nghiệp"@vi ;
    persona:thuc_day persona:phat_trien_su_nghiep ;
    rdfs:comment "Chức danh, vai trò hoặc vị trí cụ thể mà cá nhân hướng đến trong lộ trình thăng tiến.\\nVí dụ thực tế từ dữ liệu: trở thành trưởng bộ phận điều dưỡng năm 30 tuổi, thăng lên kỹ sư trưởng trong 5 năm, được phong nghệ nhân ẩm thực truyền thống."@vi ;
    rdfs:subClassOf persona:khat_vong_nghe_nghiep .

persona:nganh_nghe a owl:Class ;
    rdfs:label "Ngành nghề"@vi ;
    persona:dinh_hinh persona:muc_tieu_kinh_doanh_hoac_su_nghiep_cu_the ;
    rdfs:comment "Lĩnh vực kinh tế - xã hội được phân loại theo chức năng sản xuất hoặc dịch vụ mà một cá nhân lựa chọn làm phương tiện mưu sinh \\nvà tích lũy chuyên môn chính. Ví dụ: công nghệ thông tin, y tế, giáo dục,..."@vi ;
    rdfs:subClassOf persona:linh_vuc_lam_viec_chinh .

persona:nhan_thuc_ve_tu_nhien_va_xa_hoi a owl:Class ;
    rdfs:label "Nhận thức về tự nhiên và xã hội"@vi ;
    rdfs:comment "Cách cá nhân hiểu và diễn giải các quy luật vận hành của thế giới tự nhiên và cấu trúc xã hội xung quanh.\\nVí dụ: tin vào nhân quả, coi xã hội là hệ thống công bằng hay bất công, nhìn tự nhiên như nguồn nuôi dưỡng hay môi trường cần chinh phục."@vi ;
    rdfs:subClassOf persona:the_gioi_quan .

persona:nhip_do_hanh_trinh a owl:Class ;
    rdfs:label "Nhịp độ hành trình"@vi ;
    rdfs:comment "Tốc độ và mật độ hoạt động trong một chuyến đi.\\nPhân biệt giữa người thích lịch trình dày đặc (tham quan nhiều điểm, tối ưu thời gian) và người ưa nhịp thong thả (ở lâu một nơi, thấm sâu hơn)."@vi ;
    rdfs:subClassOf persona:phong_cach_dich_chuyen .

persona:niem_tin_ve_su_thay_doi a owl:Class ;
    rdfs:label "Niềm tin về sự thay đổi"@vi ;
    rdfs:comment "Quan điểm của cá nhân về khả năng và giới hạn của sự thay đổi trong cuộc sống con người và xã hội.\\nPhân biệt giữa người tin rằng mọi thứ có thể cải thiện nếu cố gắng và người cho rằng số phận hoặc hoàn cảnh là bất biến."@vi ;
    rdfs:subClassOf persona:the_gioi_quan .

persona:phat_trien_co_bap a owl:Class ;
    rdfs:label "Phát triển cơ bắp"@vi ;
    rdfs:comment "Quá trình tăng trưởng kích thước và sức mạnh các nhóm cơ thông qua tập luyện kháng lực \\nkết hợp với chế độ dinh dưỡng phù hợp. \\nĐòi hỏi cân bằng giữa kích thích cơ học từ bài tập và phục hồi sinh học sau tập."@vi ;
    rdfs:subClassOf persona:che_do_giu_gin_voc_dang .

persona:phuong_thuc_ra_quyet_dinh_ca_nhan a owl:Class ;
    rdfs:label "Phương thức ra quyết định cá nhân"@vi ;
    persona:dinh_hinh persona:moc_thoi_gian_muc_tieu ;
    rdfs:comment "Cách thức một cá nhân đưa ra lựa chọn trước các tình huống trong cuộc sống.\\nPhân biệt giữa người ra quyết định dựa trên cảm xúc và trực giác, người phân tích dữ liệu và cân nhắc lý trí, hay người cần tham khảo ý kiến người khác trước khi quyết định."@vi ;
    rdfs:subClassOf persona:cach_thuc_tiep_can_cuoc_song .

persona:so_thich_ca_nhan a owl:Class ;
    rdfs:label "Sở thích cá nhân"@vi ;
    rdfs:comment "Các hoạt động, đề tài hoặc lĩnh vực mà một người tự nguyện tìm đến nhằm mục đích thư giãn, tìm kiếm niềm vui hoặc thỏa mãn sự tò mò.\\nKhông bị ràng buộc bởi trách nhiệm hay áp lực công việc."@vi ;
    rdfs:subClassOf persona:hobbies_and_interests .

persona:so_thich_loai_hinh_luu_tru a owl:Class ;
    rdfs:label "Sở thích loại hình lưu trú"@vi ;
    rdfs:comment "Tiêu chuẩn và thiên hướng lựa chọn nơi ở khi đi du lịch.\\nVí dụ thực tế: ưa khách sạn tiện nghi, thích homestay gần gũi địa phương, chọn hostel để tiết kiệm và gặp gỡ khách du lịch khác."@vi ;
    rdfs:subClassOf persona:so_thich_dac_trung_du_lich .

persona:so_thich_phuong_tien_di_chuyen a owl:Class ;
    rdfs:label "Sở thích phương tiện di chuyển"@vi ;
    rdfs:comment "Loại phương tiện mà cá nhân ưu tiên sử dụng để di chuyển giữa các điểm đến trong chuyến đi.\\nVí dụ thực tế: thuê xe máy khám phá tự do, đi tàu hỏa để ngắm cảnh, chọn máy bay để tiết kiệm thời gian."@vi ;
    rdfs:subClassOf persona:so_thich_dac_trung_du_lich .

persona:su_phan_biet_ban_than_trong_xa_hoi a owl:Class ;
    rdfs:label "Sự phân biệt bản thân trong xã hội"@vi ;
    rdfs:comment "Cách thức cá nhân xác định mình khác biệt hoặc thuộc về một nhóm nhất định trong cộng đồng xã hội.\\nThể hiện qua các lựa chọn về phong cách sống, ngôn ngữ, ngoại hình và mối quan hệ xã hội được chủ động chọn lọc."@vi ;
    rdfs:subClassOf persona:ban_sac_ca_nhan .

persona:su_ung_ho_tinh_than a owl:Class ;
    rdfs:label "Sự ủng hộ tinh thần"@vi ;
    rdfs:comment "Trạng thái gắn bó cảm xúc và lòng trung thành bền vững mà một cá nhân dành cho một đội thể thao qua thời gian. \\nThể hiện qua việc cổ vũ, tham dự sự kiện và duy trì ủng hộ bất kể kết quả thắng thua."@vi ;
    rdfs:subClassOf persona:cau_lac_bo_hoac_doi_tuyen_the_thao_yeu_thich .

persona:tac_vu_dac_thu_cong_viec a owl:Class ;
    rdfs:label "Tác vụ đặc thù công việc"@vi ;
    persona:dinh_hinh persona:linh_vuc_kinh_nghiem_tich_luy ;
    rdfs:comment "Các nhiệm vụ, hoạt động hoặc quy trình mang tính nghiệp vụ đặc trưng, chỉ xuất hiện hoặc đòi hỏi năng lực riêng biệt trong một vị trí hoặc ngành nghề cụ thể. \\nPhân biệt rõ ràng với các nhiệm vụ hành chính hoặc hỗ trợ chung."@vi ;
    rdfs:subClassOf persona:he_thong_ky_nang_chuyen_mon_cot_loi .

persona:thien_huong_loai_hinh_van_dong a owl:Class ;
    rdfs:label "Thiên hướng loại hình vận động"@vi ;
    rdfs:comment "Xu thế tự nhiên của cá nhân khi lựa chọn giữa các nhóm hoạt động thể chất khác nhau về cường độ và tính chất. \\nVí dụ: ưa vận động nhẹ nhàng (đi bộ, yoga) hay cường độ cao (bóng đá, bơi lội), \\nthể thao cá nhân hay đồng đội, trong nhà hay ngoài trời."@vi ;
    rdfs:subClassOf persona:xu_huong_va_so_thich_van_dong .

persona:thoi_quen_dinh_duong a owl:Class ;
    rdfs:label "Thói quen dinh dưỡng"@vi ;
    persona:dinh_hinh persona:che_do_an_uong_ca_nhan ;
    persona:tac_dong persona:cai_thien_the_luc ;
    rdfs:comment "Các hành vi ăn uống lặp đi lặp lại của một cá nhân liên quan đến loại thực phẩm tiêu thụ, \\nthời điểm ăn và khẩu phần. \\nCó ảnh hưởng trực tiếp đến hiệu suất thể chất và thành phần cơ thể."@vi ;
    rdfs:subClassOf persona:che_do_giu_gin_voc_dang .

persona:trinh_do_ky_thuat_nau_an a owl:Class ;
    rdfs:label "Trình độ kỹ thuật nấu ăn"@vi ;
    rdfs:comment "Mức độ thành thạo của cá nhân trong việc thực hiện các kỹ thuật chế biến thực phẩm.\\nTừ mức cơ bản (luộc, chiên đơn giản) đến trung cấp (kho, hầm, làm bánh) và nâng cao (kỹ thuật Âu, phân tử ẩm thực, tạo hình tinh xảo)."@vi ;
    rdfs:subClassOf persona:nang_luc_nau_nuong .

persona:vai_tro_quyet_dinh_trong_cong_viec a owl:Class ;
    rdfs:label "Vai trò quyết định trong công việc"@vi ;
    rdfs:comment "Mức độ ảnh hưởng và tính không thể thiếu của một năng lực hoặc kỹ năng cụ thể đối với kết quả đầu ra của công việc. \\nMột kỹ năng được xem là có vai trò quyết định khi thiếu nó sẽ khiến tác vụ không thể hoàn thành hoặc chất lượng giảm sút đáng kể."@vi ;
    rdfs:subClassOf persona:he_thong_ky_nang_chuyen_mon_cot_loi .

persona:vi_tri_ca_nhan_trong_the_gioi a owl:Class ;
    rdfs:label "Vị trí cá nhân trong thế giới"@vi ;
    rdfs:comment "Cảm nhận của cá nhân về vai trò và ý nghĩa của bản thân trong bức tranh lớn hơn của xã hội và vũ trụ.\\nVí dụ thực tế: cảm thấy mình là một phần nhỏ trong cộng đồng, hoặc tin rằng mình có sứ mệnh riêng cần hoàn thành."@vi ;
    rdfs:subClassOf persona:the_gioi_quan .

persona:xu_huong_lac_quan_voi_bi_quan a owl:Class ;
    rdfs:label "Xu hướng lạc quan với bi quan"@vi ;
    persona:tuong_quan persona:muc_do_kien_tri_dam_me ;
    rdfs:comment "Thiên hướng tự nhiên của cá nhân trong việc diễn giải các sự kiện theo hướng tích cực hay tiêu cực.\\nNgười lạc quan mặc định kỳ vọng kết quả tốt; người bi quan coi trọng rủi ro và chuẩn bị cho tình huống xấu nhất."@vi ;
    rdfs:subClassOf persona:cach_thuc_tiep_can_cuoc_song .

persona:xu_huong_trai_nghiem_du_lich a owl:Class ;
    rdfs:label "Xu hướng trải nghiệm du lịch"@vi ;
    rdfs:comment "Cách thức một cá nhân tương tác, cảm nhận và khám phá các giá trị tại điểm đến.\\nVí dụ như xu hướng du lịch nghỉ dưỡng, du lịch khám phá mạo hiểm, hay du lịch tìm hiểu văn hóa - lịch sử."@vi ;
    rdfs:subClassOf persona:travel_persona .

persona:y_nghia_ca_nhan_cua_su_nghiep a owl:Class ;
    rdfs:label "Ý nghĩa cá nhân của sự nghiệp"@vi ;
    persona:tuong_quan persona:ban_sac_ca_nhan ;
    rdfs:comment "Vai trò mà công việc đảm nhận trong nhận thức của cá nhân về bản thân và cuộc sống: chỉ là phương tiện kiếm sống hay \\ncòn là nguồn gốc của danh dự, bản sắc hoặc đóng góp xã hội.Ví dụ thực tế từ dữ liệu: coi nghề nấu ăn là \\ncách giữ gìn văn hóa truyền thống, xem nghề điều dưỡng là ơn gọi cần học suốt đời, xem tiệm tạp hóa là tài sản gia đình cần gìn giữ."@vi ;
    rdfs:subClassOf persona:su_nghiep_ca_nhan .

persona:arts_persona a owl:Class ;
    rdfs:label "arts_persona"@vi ;
    rdfs:comment "Hình mẫu nghệ thuật xác định mức độ gắn kết của một cá nhân với các hình thức biểu đạt sáng tạo, đồng thời mô tả \\ncách thức nghệ thuật tác động và định hình bản sắc cá nhân."@vi .

persona:boi_canh_tham_gia_the_thao a owl:Class ;
    rdfs:label "Bối cảnh tham gia thể thao"@vi ;
    persona:dinh_hinh persona:boi_canh_giai_tri ;
    rdfs:comment "Hoàn cảnh và môi trường xã hội xung quanh việc tập luyện của cá nhân. \\nVí dụ: tập cùng bạn bè, trong cộng đồng khu phố, tại câu lạc bộ địa phương hay tự tập một mình."@vi ;
    rdfs:subClassOf persona:muc_do_tham_gia_the_thao .

persona:boi_canh_xa_hoi_truyen_thong a owl:Class ;
    rdfs:label "Bối cảnh xã hội truyền thống"@vi ;
    persona:dinh_hinh persona:anh_huong_nghe_thuat_den_the_gioi_quan,
        persona:gia_tri_cot_loi,
        persona:khau_vi_ca_nhan ;
    persona:tac_dong persona:hinh_thuc_to_chuc_hanh_trinh ;
    rdfs:comment "Môi trường sống bao gồm các chuẩn mực đạo đức, cấu trúc gia đình, hệ giá trị cộng đồng và các quy ước xã hội mang tính lâu đời tại địa phương hoặc quốc gia.\\nNơi cá nhân sinh ra, lớn lên hoặc chịu sự giáo dục trực tiếp."@vi ;
    rdfs:subClassOf persona:cultural_background .

persona:cach_thuc_tiep_can_cuoc_song a owl:Class ;
    rdfs:label "Cách thức tiếp cận cuộc sống"@vi ;
    persona:tac_dong persona:chuc_nang_giai_tri_doi_voi_ca_nhan ;
    rdfs:comment "Phương pháp, thái độ và hành động thực tế mà một cá nhân áp dụng để đối mặt, tương tác và xử lý các tình huống diễn ra trong đời sống hàng ngày.\\nThể hiện qua xu hướng chủ động hay bị động, lạc quan hay bi quan, thực tế hay lý tưởng hóa."@vi ;
    rdfs:subClassOf persona:persona .

persona:career_goals_and_ambitions a owl:Class ;
    rdfs:label "career_goals_and_ambitions"@vi ;
    rdfs:comment "Đoạn văn bản mô tả các khát vọng nghề nghiệp, định hướng phát triển bản thân và những mục tiêu công việc dài hạn mà cá nhân hướng tới trong sự nghiệp."@vi .

persona:culinary_persona a owl:Class ;
    rdfs:label "culinary_persona"@vi ;
    rdfs:comment "Hình mẫu ẩm thực mô tả cụ thể về khẩu vị, sở thích ăn uống cá nhân, năng lực nấu nướng cùng xu hướng và gu trải nghiệm văn hóa ẩm thực."@vi .

persona:cultural_background a owl:Class ;
    rdfs:label "cultural_background"@vi ;
    rdfs:comment "Mô tả chi tiết về bối cảnh, nguồn gốc hoặc nền tảng văn hóa, xã hội truyền thống có ảnh hưởng đến nhận thức và hành vi của một cá nhân."@vi .

persona:gia_tri_cot_loi a owl:Class ;
    rdfs:label "Giá trị cốt lõi"@vi ;
    persona:dinh_hinh persona:khat_vong_nghe_nghiep,
        persona:muc_dich_van_dong ;
    rdfs:comment "Hệ thống các nguyên tắc, niềm tin sâu sắc và tiêu chuẩn đạo đức nền tảng định hướng cho mọi suy nghĩ và hành động của một người.\\nĐây là kim chỉ nam không thay đổi theo thời gian và tác động trực tiếp đến việc lựa chọn ưu tiên trong cuộc sống."@vi ;
    rdfs:subClassOf persona:persona .

persona:gia_tri_phong_cach_song_an_hien a owl:Class ;
    rdfs:label "Giá trị phong cách sống ẩn hiện"@vi ;
    persona:tuong_quan persona:muc_do_chu_tam_nghe_thuat ;
    rdfs:comment "Các giá trị sống được bộc lộ gián tiếp qua cách kể chuyện về sở thích và thói quen, không được phát biểu trực tiếp nhưng có thể suy luận.\\nVí dụ thực tế từ dữ liệu: trân trọng truyền thống (vẫn nấu nồi đất dù có lò vi sóng), coi trọng gia đình (kể chuyện cho con cháu nghe), gắn bó cộng đồng địa phương (duy trì hội hoa phượng đỏ)."@vi ;
    rdfs:subClassOf persona:doan_van_ban_tu_su_phong_cach_song .

persona:hanh_vi_tham_gia_cong_dong a owl:Class ;
    rdfs:label "Hành vi tham gia cộng đồng"@vi ;
    persona:tuong_quan persona:quy_mo_nhom_du_lich ;
    rdfs:comment "Các hành động cụ thể thể hiện sự gắn bó và đóng góp của cá nhân vào đời sống tập thể của cộng đồng xung quanh.\\nVí dụ thực tế từ dữ liệu: tổ chức đèn hoa đăng sông Cấm, tham gia hội đua thuyền trong làng, dạy làm nem cua bể cho lớp trẻ, tham gia lớp múa quan họ sáng thứ Bảy tại sân đình."@vi ;
    rdfs:subClassOf persona:hanh_vi_ca_nhan_van_hoa .

persona:he_thong_bai_tap a owl:Class ;
    rdfs:label "Hệ thống bài tập"@vi ;
    rdfs:comment "Tập hợp các động tác, bài tập được sắp xếp có trật tự và logic nhằm tác động có chủ đích \\nlên các nhóm cơ, hệ thống năng lượng hoặc kỹ năng vận động cụ thể. \\nKhác với tập luyện ngẫu nhiên ở chỗ các bài tập bổ trợ và kế thừa lẫn nhau."@vi ;
    rdfs:subClassOf persona:phuong_phap_tap_luyen .

persona:hinh_thuc_bieu_dat_sang_tao a owl:Class ;
    rdfs:label "Hình thức biểu đạt sáng tạo"@vi ;
    rdfs:comment "Các phương thức, phương tiện hoặc loại hình nghệ thuật khác nhau mà con người sử dụng để truyền tải ý tưởng, cảm xúc.\\nVí dụ như hội họa, âm nhạc, văn học, điện ảnh hay nghệ thuật biểu diễn."@vi ;
    rdfs:subClassOf persona:arts_persona .

persona:hoat_dong_hanh_trinh_hoac_lu_hanh a owl:Class ;
    rdfs:label "Hoạt động hành trình hoặc lữ hành"@vi ;
    rdfs:comment "Toàn bộ các chuỗi hành động thực tế được thực hiện trong quá trình di chuyển và lưu trú ngoài nơi ở thường xuyên.\\nNhằm mục đích giải trí, nghỉ ngơi, khám phá hoặc công tác."@vi ;
    rdfs:subClassOf persona:travel_persona .

persona:hobbies_and_interests a owl:Class ;
    rdfs:label "Hobbies_and_interests"@vi ;
    rdfs:comment "Mô tả về các sở thích cá nhân, đam mê và hoạt động giải trí trong thời gian rảnh rỗi, được trình bày dưới dạng một đoạn văn bản tự sự nhằm thể hiện phong cách sống."@vi .

persona:ke_hoach_hoc_tap_nang_cao a owl:Class ;
    rdfs:label "Kế hoạch học tập nâng cao"@vi ;
    persona:cung_co persona:he_thong_ky_nang_chuyen_mon_cot_loi ;
    rdfs:comment "Các bước cụ thể mà cá nhân dự định thực hiện để nâng cao trình độ chuyên môn hoặc mở rộng kiến thức.\\nVí dụ thực tế từ dữ liệu: học chứng chỉ điều dưỡng tim mạch, học lên cao đẳng kỹ thuật, tham gia khóa học nhiếp ảnh, tham gia khóa quản lý và tổ chức sự kiện."@vi ;
    rdfs:subClassOf persona:dinh_huong_phat_trien_ban_than .

persona:khong_gian_vat_ly_lam_viec a owl:Class ;
    rdfs:label "Không gian vật lý làm việc"@vi ;
    persona:tac_dong persona:boi_canh_tham_gia_the_thao ;
    rdfs:comment "Địa điểm, cơ sở vật chất và điều kiện hạ tầng nơi cá nhân thực hiện công việc hàng ngày. \\nBao gồm văn phòng, không gian coworking, môi trường làm việc từ xa hoặc thực địa và ảnh hưởng của điều kiện vật lý đó đến hiệu suất cá nhân."@vi ;
    rdfs:subClassOf persona:moi_truong_lam_viec .

persona:kien_thuc_chuyen_nganh a owl:Class ;
    rdfs:label "Kiến thức chuyên ngành"@vi ;
    rdfs:comment "Hệ thống tri thức lý thuyết, nguyên lý, quy chuẩn và học thuật đặc thù của một ngành. \\nĐược tích lũy qua đào tạo bài bản và cập nhật liên tục để đáp ứng sự phát triển của lĩnh vực."@vi ;
    rdfs:subClassOf persona:he_thong_ky_nang_chuyen_mon_cot_loi .

persona:ky_nang_chuyen_mon_cot_loi a owl:Class ;
    rdfs:label "Kỹ năng chuyên môn cốt lõi"@vi ;
    persona:thuc_day persona:muc_tieu_vi_tri_nghe_nghiep ;
    rdfs:comment "Tập hợp các kiến thức kỹ thuật, nghiệp vụ và khả năng làm chủ công cụ chuyên ngành đóng vai trò quyết định trong công việc.\\nGiúp cá nhân thực hiện chính xác các tác vụ đặc thù của một ngành nghề cụ thể."@vi ;
    rdfs:subClassOf persona:skills_and_expertise .

persona:ky_nang_cong_nghe_va_cong_cu_so a owl:Class ;
    rdfs:label "Kỹ năng công nghệ và công cụ số"@vi ;
    persona:tuong_quan persona:phuong_tien_ky_thuat_so ;
    rdfs:comment "Khả năng vận hành các thiết bị điện tử, phần mềm hoặc nền tảng số trong công việc và sinh hoạt hàng ngày.\\nVí dụ thực tế từ dữ liệu: sử dụng máy tính xử lý hành chính, dùng điện thoại thông minh thanh toán và tìm kiếm, sử dụng phần mềm kỹ thuật chuyên ngành."@vi ;
    rdfs:subClassOf persona:ky_nang_chuyen_mon_cot_loi .

persona:ky_nang_the_thao a owl:Class ;
    rdfs:label "Kỹ năng thể thao"@vi ;
    rdfs:comment "Khả năng thực hiện thành thục các kỹ thuật, chiến thuật và phản xạ đặc thù của một môn thể thao nhất định. \\nĐược phát triển qua quá trình lặp lại, phản hồi và điều chỉnh liên tục trong tập luyện."@vi ;
    rdfs:subClassOf persona:phuong_phap_tap_luyen .

persona:ky_nang_thuc_hanh_nghe_nghiep a owl:Class ;
    rdfs:label "Kỹ năng thực hành nghề nghiệp"@vi ;
    rdfs:comment "Khả năng triển khai kiến thức vào hành động thực tế trong điều kiện công việc thực tiễn. \\nBao gồm độ chính xác, tốc độ xử lý và khả năng thích ứng khi đối mặt với các tình huống phát sinh ngoài lý thuyết."@vi ;
    rdfs:subClassOf persona:he_thong_ky_nang_chuyen_mon_cot_loi .

persona:muc_dich_ket_noi_xa_hoi a owl:Class ;
    rdfs:label "Mục đích kết nối xã hội"@vi ;
    persona:cung_co persona:hanh_vi_tham_gia_cong_dong,
        persona:vi_tri_ca_nhan_trong_the_gioi ;
    persona:thuc_day persona:moi_quan_he_xa_hoi_nghe_nghiep ;
    persona:tuong_quan persona:dong_luc_ket_noi_cong_dong_sang_tao ;
    rdfs:comment "Động lực tham gia thể thao xuất phát từ nhu cầu giao lưu, duy trì mối quan hệ \\nvà hòa nhập vào cộng đồng thông qua hoạt động thể chất chung. \\nVí dụ thực tế: chơi bóng đá cùng bạn bè, tham gia đội thể thao khu phố."@vi ;
    rdfs:subClassOf persona:muc_dich_van_dong .

persona:muc_dich_suc_khoe a owl:Class ;
    rdfs:label "Mục đích sức khỏe"@vi ;
    rdfs:comment "Động lực tham gia vận động xuất phát từ nhu cầu duy trì hoặc cải thiện các chỉ số thể chất \\nnhư tim mạch, xương khớp, hệ miễn dịch và tuổi thọ. \\nVí dụ thực tế: đi bộ buổi sáng để giữ sức khỏe, tập nhẹ nhàng để tránh bệnh."@vi ;
    rdfs:subClassOf persona:muc_dich_van_dong .

persona:muc_do_gan_ket_nghe_thuat a owl:Class ;
    rdfs:label "Mức độ gắn kết nghệ thuật"@vi ;
    rdfs:comment "Chỉ số đo lường tần suất, sự chú tâm và chiều sâu trong việc tương tác của một cá nhân đối với nghệ thuật.\\nBao gồm các hoạt động từ thưởng thức thụ động đến trực tiếp tham gia sáng tạo."@vi ;
    rdfs:subClassOf persona:arts_persona .

persona:muc_do_hoa_nhap_van_hoa_ban_dia a owl:Class ;
    rdfs:label "Mức độ hòa nhập văn hóa bản địa"@vi ;
    persona:thuc_day persona:su_coi_mo_voi_am_thuc_quoc_te,
        persona:the_gioi_quan ;
    persona:tuong_quan persona:ky_nang_giao_tiep_va_ung_xu ;
    rdfs:comment "Mức độ mà một cá nhân chủ động tìm hiểu, tương tác và trải nghiệm lối sống của người dân địa phương tại điểm đến.\\nVí dụ thực tế: học vài câu tiếng địa phương, ở homestay nhà dân, tham gia sinh hoạt cộng đồng thay vì chỉ tham quan bề mặt."@vi ;
    rdfs:subClassOf persona:xu_huong_trai_nghiem_du_lich .

persona:muc_do_kham_pha_tu_phat a owl:Class ;
    rdfs:label "Mức độ khám phá tự phát"@vi ;
    persona:thuc_day persona:dinh_huong_phat_trien_ban_than,
        persona:muc_do_chap_nhan_vi_la ;
    rdfs:comment "Xu hướng của cá nhân trong việc rời bỏ lịch trình cố định để tự do khám phá hoặc thử nghiệm những điều ngoài kế hoạch trong chuyến đi.\\nPhản ánh sự cân bằng giữa thích có kế hoạch chi tiết hay thích linh hoạt theo cảm hứng."@vi ;
    rdfs:subClassOf persona:xu_huong_trai_nghiem_du_lich .

persona:muc_do_kien_tri_dam_me a owl:Class ;
    rdfs:label "Mức độ kiên trì đam mê"@vi ;
    persona:cung_co persona:muc_do_cam_ket_nghe_nghiep,
        persona:muc_do_kham_pha_tu_phat ;
    rdfs:comment "Tính bền vững theo thời gian của đam mê — đam mê có duy trì qua các giai đoạn khó khăn, thay đổi cuộc sống hay không.\\nVí dụ thực tế từ dữ liệu: giữ gìn hội hoa phượng đỏ từ những năm 90, dù nghỉ hưu vẫn tiếp tục dạy nấu ăn truyền thống."@vi ;
    rdfs:subClassOf persona:dam_me_ca_nhan .

persona:muc_do_tham_gia_the_thao a owl:Class ;
    rdfs:label "Mức độ tham gia thể thao"@vi ;
    rdfs:comment "Mức độ và hình thức cụ thể mà một cá nhân thực sự tham gia vào các hoạt động thể thao trong cuộc sống thực tế. \\nBao gồm cả trường hợp không tham gia, tham gia thụ động (xem, cổ vũ) đến tham gia chủ động (tự tập, thi đấu)."@vi ;
    rdfs:subClassOf persona:sports_persona .

persona:muc_tieu_tai_chinh_ca_nhan a owl:Class ;
    rdfs:label "Mục tiêu tài chính cá nhân"@vi ;
    persona:tuong_quan persona:muc_do_dau_tu_thoi_gian_va_nguon_luc,
        persona:muc_do_dau_tu_vao_so_thich ;
    rdfs:comment "Các đích đến về tài chính gắn liền với sự nghiệp mà cá nhân đặt ra như kim chỉ nam hành động.\\nVí dụ thực tế từ dữ liệu: tăng thu nhập để cải thiện môi trường làm việc cho nhân viên, tích lũy đủ tiền mua căn nhà nhỏ, ổn định tài chính để chăm sóc bản thân và gia đình."@vi ;
    rdfs:subClassOf persona:muc_tieu_cong_viec_dai_han .

persona:nang_luc_nau_nuong a owl:Class ;
    rdfs:label "Năng lực nấu nướng"@vi ;
    persona:dinh_hinh persona:loai_hinh_so_thich ;
    persona:tuong_quan persona:ky_nang_thu_cong_va_nghe_truyen_thong ;
    rdfs:comment "Tập hợp kiến thức, kỹ năng thực hành và mức độ thuần thục của một cá nhân trong việc chế biến thực phẩm.\\nĐi từ mức độ cơ bản như chuẩn bị bữa ăn hàng ngày đến mức độ chuyên sâu như am hiểu kỹ thuật nấu phức tạp."@vi ;
    rdfs:subClassOf persona:culinary_persona .

persona:nguon_goc_hoac_nen_tang_van_hoa a owl:Class ;
    rdfs:label "Nguồn gốc hoặc nền tảng văn hóa"@vi ;
    persona:dinh_hinh persona:dong_luc_sang_tao_nghe_thuat,
        persona:so_thich_diem_den ;
    rdfs:comment "Hệ thống các phong tục, tập quán, ngôn ngữ, tín ngưỡng và di sản nghệ thuật mà một cá nhân được tiếp xúc và kế thừa từ gia đình hoặc cộng đồng gốc.\\nĐóng vai trò là cái nôi đầu tiên định hình nên thói quen và lối sống của người đó."@vi ;
    rdfs:subClassOf persona:cultural_background .

persona:nguon_hoc_nau_an a owl:Class ;
    rdfs:label "Nguồn học nấu ăn"@vi ;
    rdfs:comment "Cách thức mà cá nhân tiếp thu kiến thức và kỹ năng nấu ăn.\\nVí dụ thực tế: học từ bà hoặc mẹ truyền lại, tự học qua video YouTube, tham gia lớp học nấu ăn chính thức, hay thử nghiệm sáng tạo theo bản năng."@vi ;
    rdfs:subClassOf persona:nang_luc_nau_nuong .

persona:nguyen_tac_tap_luyen a owl:Class ;
    rdfs:label "Nguyên tắc tập luyện"@vi ;
    rdfs:comment "Các quy tắc và triết lý nền tảng chi phối cách thiết kế và điều chỉnh chương trình luyện tập. \\nVí dụ: nguyên tắc tăng tải dần, nguyên tắc phục hồi, nguyên tắc đặc hiệu hóa hay nguyên tắc cá nhân hóa."@vi ;
    rdfs:subClassOf persona:phuong_phap_tap_luyen .

persona:nhiem_vu_nghe_nghiep a owl:Class ;
    rdfs:label "Nhiệm vụ nghề nghiệp"@vi ;
    persona:tuong_quan persona:hinh_thuc_tham_gia_the_thao ;
    rdfs:comment "Các công việc, trách nhiệm và đầu ra cụ thể mà một cá nhân được giao hoặc tự xác định cần hoàn thành trong \\nphạm vi vai trò nghề nghiệp của mình. Là đơn vị cơ bản tạo nên giá trị đóng góp của cá nhân đối với tổ chức."@vi ;
    rdfs:subClassOf persona:moi_truong_lam_viec .

persona:persona a owl:Class ;
    rdfs:label "persona"@vi ;
    rdfs:comment "Hình mẫu tổng thể khái quát một cách ngắn gọn, đúc kết các giá trị cốt lõi trong thế giới quan, nhân sinh quan và cách thức tiếp cận cuộc sống của một cá nhân."@vi .

persona:phong_cach_giao_tiep_nghe_nghiep a owl:Class ;
    rdfs:label "Phong cách giao tiếp nghề nghiệp"@vi ;
    persona:tuong_quan persona:ky_nang_giao_tiep_va_ung_xu ;
    rdfs:comment "Cách thức một cá nhân truyền đạt, lắng nghe và trao đổi thông tin trong bối cảnh công việc. Thể hiện qua ngôn ngữ sử dụng, \\nkênh giao tiếp ưu tiên và khả năng điều chỉnh phong cách tùy theo đối tượng và mục đích giao tiếp."@vi ;
    rdfs:subClassOf persona:dac_diem_va_hanh_vi_dac_trung_cong_viec .

persona:phuong_tien_bieu_dat_nghe_thuat a owl:Class ;
    rdfs:label "Phương tiện biểu đạt nghệ thuật"@vi ;
    rdfs:comment "Chất liệu, công cụ hoặc nền tảng vật lý / kỹ thuật số được sử dụng để hiện thực hóa một tác phẩm nghệ thuật.\\nVí dụ: màu sơn dầu, nhạc cụ truyền thống, phần mềm chỉnh ảnh, sân khấu biểu diễn."@vi ;
    rdfs:subClassOf persona:hinh_thuc_bieu_dat_sang_tao .

persona:professional_persona a owl:Class ;
    rdfs:label "professional_persona"@vi ;
    rdfs:comment "Hình mẫu nghề nghiệp đại diện cho lĩnh vực làm việc chính, hệ thống kỹ năng chuyên môn cốt lõi, cùng các đặc điểm \\nvà hành vi đặc trưng trong môi trường làm việc của một cá nhân"@vi .

persona:skills_and_expertise a owl:Class ;
    rdfs:label "skills_and_expertise"@vi ;
    rdfs:comment "Tập hợp các kỹ năng cá nhân và chuyên môn cốt lõi, được trình bày chi tiết dưới dạng một đoạn văn bản tự sự nhằm khái quát năng lực và kinh nghiệm thực tế."@vi .

persona:so_thich_an_uong_ca_nhan a owl:Class ;
    rdfs:label "Sở thích ăn uống cá nhân"@vi ;
    rdfs:comment "Thiên hướng lựa chọn các loại nguyên liệu, món ăn hoặc chế độ dinh dưỡng cụ thể mang lại sự thỏa mãn cho cá nhân.\\nBao gồm cả việc ưu tiên các nhóm thực phẩm nhất định hoặc các thói quen kiêng khem."@vi ;
    rdfs:subClassOf persona:culinary_persona .

persona:so_thich_dac_trung_du_lich a owl:Class ;
    rdfs:label "Sở thích đặc trưng du lịch"@vi ;
    rdfs:comment "Những thiên hướng, lựa chọn ưu tiên mang tính cá nhân đối với các yếu tố trong chuyến đi.\\nBao gồm sở thích về điểm đến, ẩm thực bản địa, loại hình lưu trú hoặc phương tiện di chuyển."@vi ;
    rdfs:subClassOf persona:travel_persona .

persona:su_coi_mo_voi_am_thuc_quoc_te a owl:Class ;
    rdfs:label "Sự cởi mở với ẩm thực quốc tế"@vi ;
    rdfs:comment "Mức độ sẵn sàng của cá nhân trong việc khám phá và đánh giá cao các nền ẩm thực từ các quốc gia hoặc văn hóa khác.\\nVí dụ thực tế: thích thử sushi Nhật, đi tìm quán Thái hay Ý ở Hà Nội, hoặc hoàn toàn trung thành với ẩm thực Việt."@vi ;
    rdfs:subClassOf persona:gu_trai_nghiem_van_hoa_am_thuc .

persona:tan_suat_tham_gia_the_thao a owl:Class ;
    rdfs:label "Tần suất tham gia thể thao"@vi ;
    rdfs:comment "Mức độ đều đặn và số lần mà cá nhân thực hiện hoạt động thể chất trong một đơn vị thời gian nhất định. \\nVí dụ thực tế: đi bộ buổi sáng hàng ngày, đá bóng mỗi cuối tuần, thỉnh thoảng khi có dịp."@vi ;
    rdfs:subClassOf persona:muc_do_tham_gia_the_thao .

persona:tan_suat_va_gio_giac_an_uong a owl:Class ;
    rdfs:label "Tần suất và giờ giấc ăn uống"@vi ;
    rdfs:comment "Số bữa ăn trong ngày và thời điểm cố định mà cá nhân duy trì thói quen ăn uống.\\nVí dụ thực tế: ăn 3 bữa đúng giờ, bỏ bữa sáng, ăn khuya thường xuyên hoặc ăn vặt rải rác cả ngày."@vi ;
    rdfs:subClassOf persona:so_thich_an_uong_ca_nhan .

persona:tap_hop_nang_luc a owl:Class ;
    rdfs:label "Tập hợp năng lực"@vi ;
    persona:tuong_quan persona:nang_luc_can_phat_trien ;
    rdfs:comment "Bộ sưu tập có cấu trúc các khả năng, kiến thức và kỹ năng bổ trợ lẫn nhau mà một cá nhân sở hữu và có thể huy động để thực hiện công việc. \\nKhác với từng năng lực đơn lẻ ở chỗ chúng tương tác và khuếch đại hiệu quả của nhau."@vi ;
    rdfs:subClassOf persona:he_thong_ky_nang_chuyen_mon_cot_loi .

persona:tieu_chuan_lua_chon_quan_an a owl:Class ;
    rdfs:label "Tiêu chuẩn lựa chọn quán ăn"@vi ;
    rdfs:comment "Các yếu tố mà cá nhân cân nhắc khi quyết định chọn một địa điểm ăn uống.\\nVí dụ thực tế: ưu tiên quán vỉa hè bình dân đúng chất địa phương, chọn nhà hàng sạch sẽ có điều hòa, hay tìm kiếm trải nghiệm fine-dining cao cấp."@vi ;
    rdfs:subClassOf persona:gu_trai_nghiem_van_hoa_am_thuc .

persona:tinh_trang_tham_gia_the_thao a owl:Class ;
    rdfs:label "Tình trạng tham gia thể thao"@vi ;
    rdfs:comment "Xác nhận cá nhân có hay không tham gia bất kỳ hoạt động thể chất nào trong sinh hoạt thường ngày. \\nPhân biệt giữa người hoàn toàn không vận động và người có tham gia ở bất kỳ mức độ nào."@vi ;
    rdfs:subClassOf persona:muc_do_tham_gia_the_thao .

persona:travel_persona a owl:Class ;
    rdfs:label "travel_persona"@vi ;
    rdfs:comment "Hình mẫu du lịch định hình các sở thích đặc trưng, xu hướng trải nghiệm và phong cách dịch chuyển khi tham gia các hoạt động hành trình hoặc lữ hành của một cá nhân."@vi .

persona:vi_uu_tien_ca_nhan a owl:Class ;
    rdfs:label "Vị ưu tiên cá nhân"@vi ;
    rdfs:comment "Các tầng hương vị cụ thể mà một cá nhân chủ động tìm kiếm và cảm thấy thỏa mãn khi thưởng thức.\\nVí dụ thực tế: thích vị ngọt đậm, ưa cay nồng, chuộng vị thanh nhạt hoặc đặc biệt thích vị umami đậm đà."@vi ;
    rdfs:subClassOf persona:khau_vi_ca_nhan .

persona:xu_huong_phan_ung_tinh_huong a owl:Class ;
    rdfs:label "Xu hướng phản ứng tình huống"@vi ;
    rdfs:comment "Kiểu hành vi và cảm xúc mang tính bản năng hoặc học hỏi mà cá nhân thể hiện khi gặp các kích thích bất ngờ như \\náp lực thời hạn, phê bình từ cấp trên hay xung đột với đồng nghiệp."@vi ;
    rdfs:subClassOf persona:dac_diem_va_hanh_vi_dac_trung_cong_viec .

persona:xu_huong_va_so_thich_van_dong a owl:Class ;
    rdfs:label "Xu hướng và sở thích vận động"@vi ;
    rdfs:comment "Sự ưu tiên, thiên hướng lựa chọn và mức độ hứng thú của một cá nhân đối với các loại hình hoạt động thể chất \\nhoặc các môn thể thao cụ thể."@vi ;
    rdfs:subClassOf persona:sports_persona .

persona:cai_thien_the_luc a owl:Class ;
    rdfs:label "Cải thiện thể lực"@vi ;
    rdfs:comment "Quá trình nâng cao các chỉ số sức khỏe thể chất như sức mạnh cơ bắp, sức bền tim mạch, \\nđộ linh hoạt và tốc độ phản ứng. \\nLà kết quả đo lường được từ quá trình tập luyện có hệ thống và kiên trì."@vi ;
    rdfs:subClassOf persona:phuong_phap_tap_luyen .

persona:chi_so_hinh_the a owl:Class ;
    rdfs:label "Chỉ số hình thể"@vi ;
    rdfs:comment "Các thông số đo lường định lượng về cấu trúc cơ thể của một cá nhân. \\nBao gồm tỷ lệ mỡ cơ thể, cân nặng, vòng eo, chỉ số BMI \\nvà tỷ lệ cơ xương so với tổng khối lượng cơ thể."@vi ;
    rdfs:subClassOf persona:che_do_giu_gin_voc_dang .

persona:dac_diem_va_hanh_vi_dac_trung_cong_viec a owl:Class ;
    rdfs:label "Đặc điểm và hành vi đặc trưng công việc"@vi ;
    persona:dinh_hinh persona:hinh_anh_phong_cach_song_dac_trung ;
    rdfs:comment "Các thói quen, phong cách giao tiếp, phương pháp xử lý vấn đề và xu hướng phản ứng của một cá nhân được \\nthể hiện một cách nhất quán trong môi trường làm việc."@vi ;
    rdfs:subClassOf persona:professional_persona .

persona:dinh_huong_phat_trien_ban_than a owl:Class ;
    rdfs:label "Định hướng phát triển bản thân"@vi ;
    rdfs:comment "Lộ trình và chiến lược học tập, rèn luyện nhằm nâng cấp tư duy, kiến thức và kỹ năng của một người theo thời gian.\\nGiúp tối ưu hóa năng lực tiềm ẩn và thích ứng với những thay đổi, yêu cầu mới trong công việc và cuộc sống."@vi ;
    rdfs:subClassOf persona:career_goals_and_ambitions .

persona:hieu_qua_thuc_hien_cong_viec a owl:Class ;
    rdfs:label "Hiệu quả thực hiện công việc"@vi ;
    persona:thuc_day persona:dong_luc_phat_trien_su_nghiep ;
    persona:tuong_quan persona:ket_qua_do_luong_duoc_tu_kinh_nghiem ;
    rdfs:comment "Mức độ đạt được mục tiêu đề ra với mức tiêu hao thời gian, công sức và nguồn lực ở mức tối ưu nhất có thể. \\nĐược đánh giá qua chất lượng đầu ra, tốc độ hoàn thành và khả năng duy trì nhất quán."@vi ;
    rdfs:subClassOf persona:he_thong_ky_nang_chuyen_mon_cot_loi .

persona:hinh_thuc_to_chuc_hanh_trinh a owl:Class ;
    rdfs:label "Hình thức tổ chức hành trình"@vi ;
    rdfs:comment "Cách thức cá nhân lập kế hoạch và thực hiện chuyến đi: tự túc tự đặt từng hạng mục, đặt tour trọn gói, hay kết hợp linh hoạt cả hai.\\nPhản ánh mức độ kiểm soát và sự chủ động trong quá trình đi lại."@vi ;
    rdfs:subClassOf persona:phong_cach_dich_chuyen .

persona:hoat_dong_nghe_nghiep a owl:Class ;
    rdfs:label "Hoạt động nghề nghiệp"@vi ;
    rdfs:comment "Toàn bộ các hành động, nhiệm vụ và quy trình mà một cá nhân thực hiện thường xuyên trong phạm vi công việc chuyên môn của mình. \\nBao gồm cả công việc cốt lõi lẫn các hoạt động hỗ trợ, phối hợp với các bên liên quan."@vi ;
    rdfs:subClassOf persona:linh_vuc_lam_viec_chinh .

persona:khat_vong_nghe_nghiep a owl:Class ;
    rdfs:label "Khát vọng nghề nghiệp"@vi ;
    persona:dinh_hinh persona:linh_vuc_lam_viec_chinh,
        persona:quan_niem_y_nghia_cuoc_song ;
    rdfs:comment "Mong muốn mãnh liệt và động lực vươn lên để đạt được những thành tựu hoặc vị trí quan trọng trong lộ trình công việc.\\nLà yếu tố tinh thần thôi thúc cá nhân không ngừng nỗ lực, cống hiến và vượt qua giới hạn của bản thân."@vi ;
    rdfs:subClassOf persona:career_goals_and_ambitions .

persona:khau_vi_ca_nhan a owl:Class ;
    rdfs:label "Khẩu vị cá nhân"@vi ;
    rdfs:comment "Sự ưu tiên hoặc nhạy cảm đặc trưng của các giác quan đối với các tầng hương vị trong món ăn.\\nThể hiện qua thói quen thích ăn mặn, ngọt, chua, cay, nhạt hoặc xu hướng lựa chọn kết cấu thực phẩm."@vi ;
    rdfs:subClassOf persona:culinary_persona .

persona:lich_trinh_tap_luyen a owl:Class ;
    rdfs:label "Lịch trình tập luyện"@vi ;
    rdfs:comment "Kế hoạch phân bổ thời gian tập luyện theo ngày, tuần hoặc chu kỳ dài hạn. \\nXác định tần suất tập, thời lượng mỗi buổi, các ngày nghỉ phục hồi \\nvà sự luân phiên giữa các nhóm bài tập khác nhau."@vi ;
    rdfs:subClassOf persona:phuong_phap_tap_luyen .

persona:moi_truong_lam_viec a owl:Class ;
    rdfs:label "Môi trường làm việc"@vi ;
    persona:tac_dong persona:boi_canh_giai_tri,
        persona:hinh_thuc_to_chuc_hanh_trinh,
        persona:ky_nang_cong_nghe_va_cong_cu_so,
        persona:thoi_quen_sinh_hoat_hang_ngay ;
    rdfs:comment "Không gian vật lý, bối cảnh văn hóa doanh nghiệp, các mối quan hệ xã hội và điều kiện tổ chức \\nnơi cá nhân thực hiện các nhiệm vụ nghề nghiệp của mình."@vi ;
    rdfs:subClassOf persona:professional_persona .

persona:muc_do_dau_tu_vao_so_thich a owl:Class ;
    rdfs:label "Mức độ đầu tư vào sở thích"@vi ;
    persona:tuong_quan persona:muc_do_thuan_thuc_sang_tao,
        persona:tan_suat_tham_gia_the_thao ;
    rdfs:comment "Lượng thời gian, công sức và đôi khi tài chính mà cá nhân thực sự dành cho một sở thích.\\nPhân biệt giữa sở thích nhẹ (thỉnh thoảng làm khi có dịp) và sở thích sâu (dành hàng tuần, có mục tiêu rõ ràng).\\nVí dụ thực tế từ dữ liệu: mỗi sáng thứ Bảy tham gia lớp múa quan họ, mỗi cuối tuần đến công viên nhảy truyền thống."@vi ;
    rdfs:subClassOf persona:so_thich_ca_nhan .

persona:muc_do_hung_thu_van_dong a owl:Class ;
    rdfs:label "Mức độ hứng thú vận động"@vi ;
    rdfs:comment "Cường độ cảm xúc tích cực và động lực nội tại mà một cá nhân cảm nhận khi tham gia hoặc theo dõi các hoạt động thể chất. \\nĐược đo lường qua tần suất chủ động tham gia và mức độ kiên trì duy trì hoạt động theo thời gian."@vi ;
    rdfs:subClassOf persona:xu_huong_va_so_thich_van_dong .

persona:muc_do_thuan_thuc_sang_tao a owl:Class ;
    rdfs:label "Mức độ thuần thục sáng tạo"@vi ;
    persona:tuong_quan persona:ky_nang_thu_cong_va_nghe_truyen_thong ;
    rdfs:comment "Trình độ kỹ thuật và kinh nghiệm của cá nhân trong một hình thức nghệ thuật cụ thể.\\nTừ mức nghiệp dư (học để vui), bán chuyên (có kỹ năng rõ ràng) đến chuyên nghiệp (có thể biểu diễn hoặc triển lãm công khai)."@vi ;
    rdfs:subClassOf persona:hinh_thuc_bieu_dat_sang_tao .

persona:nang_luc_ky_thuat a owl:Class ;
    rdfs:label "Năng lực kỹ thuật"@vi ;
    persona:cung_co persona:ky_nang_ky_thuat_chuyen_nganh ;
    rdfs:comment "Khả năng vận hành, áp dụng và làm chủ các công cụ, phần mềm, quy trình hoặc phương pháp kỹ thuật chuyên biệt trong một lĩnh vực nghề nghiệp nhất định. \\nĐây là dạng kỹ năng cứng (hard skill) có thể đo lường và kiểm định trực tiếp."@vi ;
    rdfs:subClassOf persona:he_thong_ky_nang_chuyen_mon_cot_loi .

persona:nguon_goc_hinh_thanh_so_thich a owl:Class ;
    rdfs:label "Nguồn gốc hình thành sở thích"@vi ;
    rdfs:comment "Yếu tố hoặc hoàn cảnh khởi đầu đã khai sinh nên một sở thích cụ thể của cá nhân.\\nVí dụ thực tế từ dữ liệu: lớn lên gần chợ nổi nên thích chèo xuồng, gia đình có truyền thống nghệ thuật sân khấu nên gắn bó với hát chèo, cháu nội dạy dùng công nghệ nên tò mò về nhiếp ảnh kỹ thuật số."@vi ;
    rdfs:subClassOf persona:so_thich_ca_nhan .

persona:nhan_thuc_ca_nhan_van_hoa a owl:Class ;
    rdfs:label "Nhận thức cá nhân văn hóa"@vi ;
    rdfs:comment "Cách thức một người tư duy, hiểu, giải mã và đánh giá các hiện tượng, sự vật xung quanh dựa trên lăng kính văn hóa mà họ sở hữu.\\nẢnh hưởng trực tiếp đến tư duy đúng sai, tốt xấu và các định kiến cá nhân."@vi ;
    rdfs:subClassOf persona:cultural_background .

persona:phan_khuc_thi_truong a owl:Class ;
    rdfs:label "Phân khúc thị trường"@vi ;
    rdfs:comment "Tập hợp khách hàng mục tiêu hoặc nhóm nhu cầu cụ thể mà cá nhân hoặc tổ chức hướng đến phục vụ trong phạm vi ngành nghề của mình. \\nPhân chia theo yếu tố như quy mô doanh nghiệp, địa lý hoặc nhóm nhân khẩu học."@vi ;
    rdfs:subClassOf persona:linh_vuc_lam_viec_chinh .

persona:quan_niem_hanh_phuc a owl:Class ;
    rdfs:label "Quan niệm hạnh phúc"@vi ;
    persona:thuc_day persona:hoat_dong_giai_tri_cu_the,
        persona:muc_dich_giai_tri_tinh_than ;
    rdfs:comment "Định nghĩa cá nhân về trạng thái sống được xem là viên mãn và thỏa mãn nhất.\\nVí dụ thực tế: hạnh phúc là gia đình sum vầy, là tự do tài chính, là sức khỏe tốt, hay là được làm điều mình yêu thích mỗi ngày."@vi ;
    rdfs:subClassOf persona:nhan_sinh_quan .

persona:quan_niem_y_nghia_cuoc_song a owl:Class ;
    rdfs:label "Quan niệm ý nghĩa cuộc sống"@vi ;
    persona:thuc_day persona:khat_vong_dong_gop_xa_hoi ;
    rdfs:comment "Câu trả lời cá nhân cho câu hỏi mình sống vì điều gì và điều gì làm cho cuộc đời trở nên đáng sống.\\nCó thể là cống hiến cho xã hội, nuôi dạy con cái, tự hoàn thiện bản thân, hay tìm kiếm trải nghiệm phong phú."@vi ;
    rdfs:subClassOf persona:nhan_sinh_quan .

persona:quy_mo_nhom_du_lich a owl:Class ;
    rdfs:label "Quy mô nhóm du lịch"@vi ;
    rdfs:comment "Số lượng người cùng tham gia chuyến đi và mối quan hệ giữa các thành viên.\\nVí dụ thực tế: đi một mình để tự do tuyệt đối, đi cặp đôi, đi cùng gia đình nhỏ, hay đi theo nhóm bạn đông người."@vi ;
    rdfs:subClassOf persona:phong_cach_dich_chuyen .

persona:so_thich_diem_den a owl:Class ;
    rdfs:label "Sở thích điểm đến"@vi ;
    rdfs:comment "Loại địa điểm hoặc môi trường địa lý mà cá nhân ưu tiên lựa chọn khi lên kế hoạch chuyến đi.\\nVí dụ thực tế: thích biển hơn núi, ưa thành phố nhộn nhịp hơn vùng nông thôn yên tĩnh, hoặc đặc biệt quan tâm đến các điểm có giá trị lịch sử văn hóa."@vi ;
    rdfs:subClassOf persona:so_thich_dac_trung_du_lich .

persona:tan_suat_tiep_xuc_nghe_thuat a owl:Class ;
    rdfs:label "Tần suất tiếp xúc nghệ thuật"@vi ;
    rdfs:comment "Số lần và mức độ đều đặn mà một cá nhân chủ động hoặc bị động tiếp xúc với các sản phẩm, sự kiện hoặc hoạt động nghệ thuật trong một đơn vị thời gian.\\nVí dụ thực tế: xem phim mỗi tuần, thỉnh thoảng đi xem hòa nhạc, hiếm khi ghé triển lãm."@vi ;
    rdfs:subClassOf persona:muc_do_gan_ket_nghe_thuat .

persona:thoi_quen_lam_viec a owl:Class ;
    rdfs:label "Thói quen làm việc"@vi ;
    persona:tuong_quan persona:lich_trinh_tap_luyen,
        persona:loai_hinh_so_thich ;
    rdfs:comment "Các hành vi lặp đi lặp lại có tính tự động trong quá trình thực hiện công việc. Bao gồm cách tổ chức công việc, \\nlịch trình cá nhân, thứ tự ưu tiên nhiệm vụ và phương thức theo dõi tiến độ hàng ngày."@vi ;
    rdfs:subClassOf persona:dac_diem_va_hanh_vi_dac_trung_cong_viec .

persona:tieu_chuan_dao_duc_ca_nhan a owl:Class ;
    rdfs:label "Tiêu chuẩn đạo đức cá nhân"@vi ;
    rdfs:comment "Hệ thống phân biệt đúng — sai, tốt — xấu mà cá nhân áp dụng để đánh giá hành vi của bản thân và người khác.\\nHình thành từ văn hóa, tôn giáo, giáo dục gia đình và trải nghiệm cá nhân theo thời gian."@vi ;
    rdfs:subClassOf persona:gia_tri_cot_loi .

persona:tinh_nhat_quan_hanh_vi a owl:Class ;
    rdfs:label "Tính nhất quán hành vi"@vi ;
    persona:cung_co persona:muc_do_chu_dong_voi_bi_dong,
        persona:thoi_quen_lam_viec ;
    rdfs:comment "Mức độ ổn định và có thể dự đoán được trong cách một cá nhân hành động, phản ứng và ra quyết định qua các tình huống khác nhau theo thời gian. \\nLà biểu hiện của sự trưởng thành chuyên môn và độ tin cậy trong môi trường nghề nghiệp."@vi ;
    rdfs:subClassOf persona:dac_diem_va_hanh_vi_dac_trung_cong_viec .

persona:che_do_an_uong_ca_nhan a owl:Class ;
    rdfs:label "Chế độ ăn uống cá nhân"@vi ;
    persona:tuong_quan persona:che_do_giu_gin_voc_dang,
        persona:phong_tuc_tap_quan_gia_dinh ;
    rdfs:comment "Tổng thể các nguyên tắc, quy tắc hoặc thói quen định hướng cách cá nhân lựa chọn và tiêu thụ thực phẩm hàng ngày.\\nBao gồm cả việc kiêng khem (kiêng đường, ăn chay), ưu tiên dinh dưỡng hoặc ăn theo văn hóa truyền thống."@vi ;
    rdfs:subClassOf persona:so_thich_an_uong_ca_nhan .

persona:che_do_giu_gin_voc_dang a owl:Class ;
    rdfs:label "Chế độ giữ gìn vóc dáng"@vi ;
    persona:tuong_quan persona:nhan_sinh_quan ;
    rdfs:comment "Sự kết hợp giữa hoạt động thể chất và thói quen dinh dưỡng được duy trì đều đặn \\nnhằm kiểm soát cân nặng, phát triển cơ bắp và tối ưu hóa chỉ số hình thể."@vi ;
    rdfs:subClassOf persona:sports_persona .

persona:chuc_nang_giai_tri_doi_voi_ca_nhan a owl:Class ;
    rdfs:label "Chức năng giải trí đối với cá nhân"@vi ;
    rdfs:comment "Vai trò tâm lý hoặc xã hội mà hoạt động giải trí đảm nhận trong cuộc sống của cá nhân: giải tỏa stress, \\nduy trì kết nối xã hội, bảo tồn văn hóa, hay đơn giản là tìm niềm vui.\\nVí dụ thực tế từ dữ liệu: nhảy truyền thống để giữ sức khỏe lẫn giao lưu, nghe cải lương để hoài niệm, chăm vườn để tĩnh tâm."@vi ;
    rdfs:subClassOf persona:hoat_dong_giai_tri_thoi_gian_ranh .

persona:dieu_kien_to_chuc a owl:Class ;
    rdfs:label "Điều kiện tổ chức"@vi ;
    persona:tac_dong persona:tinh_trang_tham_gia_the_thao ;
    rdfs:comment "Các yếu tố cấu trúc và vận hành của tổ chức mà cá nhân phải làm việc trong đó. Bao gồm quy mô công ty, \\nmô hình quản trị, quy trình ra quyết định, nguồn lực được cấp phát và mức độ tự chủ trong công việc."@vi ;
    rdfs:subClassOf persona:moi_truong_lam_viec .

persona:hanh_vi_chia_se_am_thuc a owl:Class ;
    rdfs:label "Hành vi chia sẻ ẩm thực"@vi ;
    rdfs:comment "Cách thức cá nhân lan truyền trải nghiệm hoặc kiến thức ẩm thực cho người khác.\\nVí dụ thực tế từ dữ liệu: chia sẻ công thức trong gia đình, dạy cháu nấu ăn, đăng ảnh món ăn lên mạng xã hội, hay rủ bạn bè cùng đi thử quán mới."@vi ;
    rdfs:subClassOf persona:gu_trai_nghiem_van_hoa_am_thuc .

persona:hinh_thuc_tich_luy_kinh_nghiem a owl:Class ;
    rdfs:label "Hình thức tích lũy kinh nghiệm"@vi ;
    rdfs:comment "Cách thức cá nhân có được kinh nghiệm: học từ người thân, tự mày mò thử nghiệm, làm việc thực tế lâu năm hay được đào tạo bài bản.\\nVí dụ thực tế từ dữ liệu: mẹ dạy nấu ăn từ nhỏ, tự học làm bánh đa cua, học qua cháu nội về sửa điện tử cơ bản."@vi ;
    rdfs:subClassOf persona:kinh_nghiem_thuc_te .

persona:muc_dich_giai_tri_tinh_than a owl:Class ;
    rdfs:label "Mục đích giải trí tinh thần"@vi ;
    persona:dinh_hinh persona:hoat_dong_giai_tri_cu_the ;
    persona:tuong_quan persona:chuc_nang_giai_tri_doi_voi_ca_nhan ;
    rdfs:comment "Động lực tham gia thể thao nhằm thư giãn, giảm stress, tìm niềm vui hoặc duy trì tinh thần sôi động. \\nVí dụ thực tế: chơi cầu lông cùng bạn bè để thư giãn sau giờ làm."@vi ;
    rdfs:subClassOf persona:muc_dich_van_dong .

persona:muc_dich_van_dong a owl:Class ;
    rdfs:label "Mục đích vận động"@vi ;
    persona:tuong_quan persona:quan_niem_hanh_phuc ;
    rdfs:comment "Lý do và kỳ vọng cụ thể thúc đẩy một cá nhân tham gia các hoạt động thể chất. \\nĐịnh hướng cho việc lựa chọn môn thể thao, cường độ tập luyện \\nvà mức độ cam kết duy trì hoạt động theo thời gian."@vi ;
    rdfs:subClassOf persona:sports_persona .

persona:muc_tieu_chuyen_di a owl:Class ;
    rdfs:label "Mục tiêu chuyến đi"@vi ;
    rdfs:comment "Lý do và kỳ vọng cụ thể thúc đẩy cá nhân thực hiện một chuyến đi nhất định.\\nVí dụ thực tế: nghỉ ngơi tái tạo năng lượng, công tác kết hợp du lịch, kỷ niệm đặc biệt, hay khám phá địa danh trong danh sách ước mơ."@vi ;
    rdfs:subClassOf persona:hoat_dong_hanh_trinh_hoac_lu_hanh .

persona:nhan_sinh_quan a owl:Class ;
    rdfs:label "Nhân sinh quan"@vi ;
    rdfs:comment "Hệ thống các quan niệm mang tính triết lý của một cá nhân về ý nghĩa, mục đích, giá trị và cách sống của con người.\\nGiải quyết các câu hỏi cốt lõi về việc con người sống vì cái gì, sống như thế nào là hạnh phúc và đúng đắn."@vi ;
    rdfs:subClassOf persona:persona .

persona:pham_vi_chuyen_mon_hoa a owl:Class ;
    rdfs:label "Phạm vi chuyên môn hóa"@vi ;
    rdfs:comment "Mức độ tập trung chuyên sâu vào một mảng hẹp và cụ thể trong một ngành nghề rộng lớn hơn. Phản ánh sự lựa chọn \\nđi theo chiều sâu thay vì chiều rộng trong con đường phát triển nghề nghiệp."@vi ;
    rdfs:subClassOf persona:linh_vuc_lam_viec_chinh .

persona:phong_cach_dich_chuyen a owl:Class ;
    rdfs:label "Phong cách dịch chuyển"@vi ;
    rdfs:comment "Nhịp điệu, thói quen và phương thức tổ chức hành trình của một người khi đi lữ hành.\\nThể hiện qua việc thích đi tự túc hay theo tour, đi một mình hay theo nhóm, lịch trình dày đặc hay thong thả."@vi ;
    rdfs:subClassOf persona:travel_persona .

persona:phuong_phap_xu_ly_van_de a owl:Class ;
    rdfs:label "Phương pháp xử lý vấn đề"@vi ;
    persona:cung_co persona:ky_nang_giai_quyet_van_de_thuc_te ;
    rdfs:comment "Trình tự tư duy và các bước hành động mà một cá nhân áp dụng khi đối mặt với tình huống khó khăn, mâu thuẫn hoặc \\ncâu hỏi chưa có lời giải trong công việc. Phản ánh tư duy phân tích, sáng tạo hay kinh nghiệm tích lũy."@vi ;
    rdfs:subClassOf persona:dac_diem_va_hanh_vi_dac_trung_cong_viec .

persona:sports_persona a owl:Class ;
    rdfs:label "sports_persona"@vi ;
    rdfs:comment "Hình mẫu thể thao mô tả xu hướng và sở thích vận động, mức độ tham gia thể thao, \\nmục đích vận động, các câu lạc bộ hoặc đội tuyển thể thao yêu thích, \\ncùng phương pháp tập luyện và chế độ giữ gìn vóc dáng của một cá nhân."@vi .

persona:ban_sac_ca_nhan a owl:Class ;
    rdfs:label "Bản sắc cá nhân"@vi ;
    persona:dinh_hinh persona:gu_trai_nghiem_van_hoa_am_thuc,
        persona:nhan_sinh_quan,
        persona:phong_cach_dich_chuyen ;
    persona:tuong_quan persona:muc_do_tu_hao_ban_sac_van_hoa ;
    rdfs:comment "Tập hợp các đặc điểm, niềm tin, giá trị sống và nét tính cách độc nhất định hình nên cái tôi của một người.\\nGiúp cá nhân tự nhận thức và phân biệt bản thân trong xã hội."@vi ;
    rdfs:subClassOf persona:arts_persona .

persona:dong_luc_phat_trien_su_nghiep a owl:Class ;
    rdfs:label "Động lực phát triển sự nghiệp"@vi ;
    persona:thuc_day persona:muc_do_dau_tu_thoi_gian_va_nguon_luc ;
    persona:tuong_quan persona:muc_dich_thi_dau_canh_tranh,
        persona:muc_do_kien_tri_dam_me ;
    rdfs:comment "Lý do cốt lõi thôi thúc cá nhân theo đuổi và nỗ lực trong công việc, vượt qua khó khăn để tiến xa hơn.\\nVí dụ thực tế từ dữ liệu: muốn xây nhà cho mẹ, muốn lo được cho gia đình, muốn truyền nghề truyền thống cho lớp trẻ, muốn đóng góp cho phát triển nông nghiệp bền vững."@vi ;
    rdfs:subClassOf persona:khat_vong_nghe_nghiep .

persona:dong_luc_sang_tao_nghe_thuat a owl:Class ;
    rdfs:label "Động lực sáng tạo nghệ thuật"@vi ;
    persona:thuc_day persona:khat_vong_dong_gop_xa_hoi ;
    rdfs:comment "Nguồn thúc đẩy nội tâm khiến cá nhân theo đuổi hoặc thực hành một hình thức biểu đạt sáng tạo.\\nCó thể xuất phát từ nhu cầu giải tỏa cảm xúc, mong muốn truyền tải thông điệp, tìm kiếm niềm vui hoặc kết nối với cộng đồng sáng tạo."@vi ;
    rdfs:subClassOf persona:hinh_thuc_bieu_dat_sang_tao .

persona:gu_trai_nghiem_van_hoa_am_thuc a owl:Class ;
    rdfs:label "Gu trải nghiệm văn hóa ẩm thực"@vi ;
    persona:dinh_hinh persona:kieu_trai_nghiem_uu_tien ;
    persona:thuc_day persona:the_gioi_quan ;
    rdfs:comment "Phong cách và tiêu chuẩn mang tính thẩm mỹ của một cá nhân khi thưởng thức và khám phá các giá trị văn hóa gắn liền với món ăn.\\nThể hiện qua cách lựa chọn không gian quán ăn, sự hứng thú với ẩm thực truyền thống bản địa hoặc ẩm thực fine-dining tinh tế."@vi ;
    rdfs:subClassOf persona:culinary_persona .

persona:hinh_thuc_tham_gia_the_thao a owl:Class ;
    rdfs:label "Hình thức tham gia thể thao"@vi ;
    rdfs:comment "Cách thức cụ thể mà cá nhân tương tác với hoạt động thể thao. \\nBao gồm tự tập một mình, chơi cùng bạn bè, tham gia câu lạc bộ có tổ chức, \\nthi đấu chính thức hoặc chỉ theo dõi cổ vũ."@vi ;
    rdfs:subClassOf persona:muc_do_tham_gia_the_thao .

persona:kieu_trai_nghiem_uu_tien a owl:Class ;
    rdfs:label "Kiểu trải nghiệm ưu tiên"@vi ;
    persona:dinh_hinh persona:tieu_chuan_lua_chon_quan_an ;
    rdfs:comment "Loại hoạt động hoặc hình thức khám phá mà cá nhân chủ động tìm kiếm tại điểm đến.\\nVí dụ thực tế: du lịch nghỉ dưỡng (nằm biển thư giãn), du lịch khám phá (leo núi, lặn biển), du lịch văn hóa (thăm bảo tàng, làng nghề) hay du lịch ẩm thực (tour chợ, lớp nấu ăn)."@vi ;
    rdfs:subClassOf persona:xu_huong_trai_nghiem_du_lich .

persona:muc_do_dau_tu_thoi_gian_va_nguon_luc a owl:Class ;
    rdfs:label "Mức độ đầu tư thời gian và nguồn lực"@vi ;
    persona:tac_dong persona:muc_do_dau_tu_vao_so_thich,
        persona:nhip_do_hanh_trinh,
        persona:tan_suat_tham_gia_the_thao,
        persona:tan_suat_tiep_xuc_nghe_thuat ;
    persona:tuong_quan persona:moc_thoi_gian_muc_tieu ;
    rdfs:comment "Tỷ lệ và cường độ mà một cá nhân phân bổ quỹ thời gian, công sức và tài chính vào một lĩnh vực nghề nghiệp cụ thể. \\nLà chỉ số gián tiếp đo lường mức độ cam kết và ưu tiên nghề nghiệp."@vi ;
    rdfs:subClassOf persona:linh_vuc_lam_viec_chinh .

persona:phat_trien_su_nghiep a owl:Class ;
    rdfs:label "Phát triển sự nghiệp"@vi ;
    persona:dinh_hinh persona:hinh_thuc_tich_luy_kinh_nghiem,
        persona:muc_tieu_vi_tri_nghe_nghiep ;
    rdfs:comment "Quá trình tiến bộ có chủ đích của một cá nhân trong việc nâng cao vị trí, năng lực và danh tiếng nghề nghiệp theo thời gian. \\nBao gồm việc mở rộng mạng lưới quan hệ, thăng tiến vị trí, chuyển ngành hoặc tự khởi nghiệp."@vi ;
    rdfs:subClassOf persona:linh_vuc_lam_viec_chinh .

persona:phuong_phap_tap_luyen a owl:Class ;
    rdfs:label "Phương pháp tập luyện"@vi ;
    rdfs:comment "Hệ thống các bài tập, nguyên tắc, lịch trình và kỹ thuật vận động được áp dụng một cách có kế hoạch \\nnhằm cải thiện thể lực hoặc kỹ năng thể thao."@vi ;
    rdfs:subClassOf persona:sports_persona .

persona:van_hoa_doanh_nghiep a owl:Class ;
    rdfs:label "Văn hóa doanh nghiệp"@vi ;
    persona:dinh_hinh persona:gia_tri_phong_cach_song_an_hien,
        persona:kieu_trai_nghiem_uu_tien,
        persona:nhan_thuc_ca_nhan_van_hoa ;
    rdfs:comment "Hệ thống giá trị, chuẩn mực ứng xử, niềm tin và thực hành được chia sẻ trong một tổ chức. Định hình cách thức \\nthành viên tương tác với nhau và với khách hàng, đồng thời xác định tiêu chí đánh giá thành công hay thất bại trong nội bộ."@vi ;
    rdfs:subClassOf persona:moi_truong_lam_viec .

persona:he_thong_ky_nang_chuyen_mon_cot_loi a owl:Class ;
    rdfs:label "Hệ thống kỹ năng chuyên môn cốt lõi"@vi ;
    rdfs:comment "Tập hợp các năng lực kỹ thuật, kiến thức chuyên ngành và kỹ năng thực hành đóng vai trò quyết định, giúp \\ncá nhân thực hiện hiệu quả các tác vụ đặc thù trong công việc."@vi ;
    rdfs:subClassOf persona:professional_persona .

persona:linh_vuc_lam_viec_chinh a owl:Class ;
    rdfs:label "Lĩnh vực làm việc chính"@vi ;
    persona:dinh_hinh persona:dinh_huong_phat_trien_ban_than ;
    rdfs:comment "Ngành nghề, phân khúc thị trường hoặc phạm vi chuyên môn hóa cụ thể mà một cá nhân dành phần lớn thời gian \\nvà nguồn lực để hoạt động và phát triển sự nghiệp."@vi ;
    rdfs:subClassOf persona:professional_persona .

persona:loai_hinh_so_thich a owl:Class ;
    rdfs:label "Loại hình sở thích"@vi ;
    persona:dinh_hinh persona:kieu_trai_nghiem_uu_tien ;
    persona:tuong_quan persona:loai_hinh_nghe_thuat_thuc_hanh,
        persona:mon_the_thao_yeu_thich ;
    rdfs:comment "Nhóm hoạt động hoặc lĩnh vực mà sở thích của cá nhân thuộc về.\\nVí dụ thực tế từ dữ liệu: sở thích nghệ thuật thủ công (làm tranh thạch cao, vẽ tranh thủy mặc), sở thích thiên nhiên (nuôi chim bồ câu, chăm vườn rau sân thượng), sở thích cộng đồng (tham gia khiêu vũ truyền thống, sinh hoạt hội nhóm)."@vi ;
    rdfs:subClassOf persona:so_thich_ca_nhan .

persona:the_gioi_quan a owl:Class ;
    rdfs:label "Thế giới quan"@vi ;
    persona:dinh_hinh persona:nguon_goc_hinh_thanh_so_thich,
        persona:pham_vi_chuyen_mon_hoa ;
    rdfs:comment "Hệ thống quan điểm, khái niệm và cách nhìn nhận tổng thể của một cá nhân về toàn bộ thế giới xung quanh.\\nBao gồm cả nhận thức về tự nhiên, xã hội, các hiện tượng khách quan và vị trí của con người trong thế giới đó."@vi ;
    rdfs:subClassOf persona:persona .

